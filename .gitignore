# dependencies
# No trailing slash: also ignores a symlink named `node_modules` (a dir-only
# `node_modules/` pattern misses symlinks, which is how one was tracked once).
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/
playwright-report/
test-results/
.vitest-cache/

# next.js
.next/
out/
next-env.d.ts

# production
build/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# scratch — session-local notes, PR/issue bodies, throwaway artifacts.
# Was previously un-ignored, so a `git add -A` could sweep it into a commit.
tmp/

# environment files — NEVER commit
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# data dumps and ETL output — NEVER commit
data/
*.dump
*.sql.gz
*.csv
# JSONL dumps (e.g. etl:coi-gap:diagnose output — carries CWIDs + statement text)
*.jsonl
seed-output/
# Exception: §1.4 curated MeSH-anchor seed is intentionally checked in
# so curation-team edits flow through PR review.
!etl/mesh-anchors/curated.csv
# Exception: #642 curated MeSH-alias seed — checked in for the same reason
# (curation-team edits flow through PR review).
!etl/mesh-aliases/curated.csv
# Exception: #801 curated audience-gated family seed — checked in so the
# External-Affairs-approved subset flows through PR review (etl:family-sensitivity).
!etl/family-sensitivity/curated.csv
# Exception: #800 curated non-distinctive family suppression seed — checked in so
# the data-steward-approved hard-hide list flows through PR review (etl:family-suppression).
!etl/family-suppression/curated.csv
# Exception: VIVO pageview baseline raw New Relic exports (issue #595) — checked
# in so the baseline isn't a secondary analysis. Public URLs only (no PII).
!docs/data/vivo-pageview-baseline/*.csv
# Exception: overview-coverage scoping baselines — the ranked target list and
# crawl bio-metadata snapshots. Public faculty data only (cwid/name/title/metrics,
# no scraped bio prose); regenerable via the SQL + scripts in the same folder.
!docs/overview-coverage/*.csv
# Exception: B14 legacy-VIVO redirect set is build-time generated from ED
# (scripts/etl/generate-vivo-redirect-set.ts) and consumed by middleware as
# a static import. The file is intentionally checked in so prod deploys
# pick up the CI-built artifact rather than running an LDAP query in CI.
!data/
data/*
!data/vivo-redirects.json
# Exception: hand-built VIVO org-unit redirect crosswalk (runbook D-10..D-13).
# Reviewed by PR like data/vivo-redirects.json; consumed by etl:vivo-redirect.
!data/vivo-org-redirects.json
# Exception: curated homepage suggested-search chip master (the lay-term list
# behind lib/hero-search-suggestions.ts). Committed so chip edits flow through
# PR review; method + refresh recipe in docs/suggested-search-chips.md.
!data/suggested-searches.json
# Exception: the SEO rank-tracker query basket is the fixed instrument that
# makes before/after comparable, so it is committed and reviewed. SerpAPI
# *output* (data/seo/snapshots/*, any rank-diff.csv) stays ignored — it can be
# large and is re-derivable. (scripts/seo/*, lib/seo/rank-basket.ts)
!data/seo/
data/seo/*
!data/seo/rank-basket.json
# The rank-stratified name cohort (#684) is the same kind of fixed instrument.
!data/seo/rank-cohort-basket.json
# Same rationale for the rival-benchmark instrument: the generated rival basket
# plus its two hand-authored inputs are committed and reviewed; snapshots stay ignored.
!data/seo/rival-basket.json
!data/seo/flagship-queries.json
!data/seo/matched-researchers.json
# Exception: #692 curated deprioritized-terms list — the hand-reviewed query
# vocabulary that drives generic-term demotion (strip-before-resolve, BM25
# down-weight, highlight exclusion). Committed and reviewed by PR.
!data/search/
data/search/*
!data/search/deprioritized-terms.json
# #594 §3: the specific-subtopic LLM basket (derived from the DB subtopic taxonomy),
# the corrected "WCM presence" instrument alongside the broad flagship queries.
!data/seo/specific-queries.json
# Exception: Next.js dynamic route segment that happens to look like a CSV
# filename — the literal `citations.csv` directory is the route path that
# serves /api/publications/[pmid]/citations.csv. Brackets are escaped so
# Git doesn't interpret them as a character class.
!app/api/publications/\[pmid\]/citations.csv/
!app/api/publications/\[pmid\]/citations.csv/route.ts

# Phase 5 — VIVO redirect map output (contains CWIDs, never commit)
etl/vivo-redirect/output/

