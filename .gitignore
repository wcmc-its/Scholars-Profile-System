scripts/_*
scripts/debug-*.ts
scripts/probe-*.ts
scripts/query-reciterdb.ts
scripts/query-scholars.ts
.screenshots/

# Local-only dev auth route (uncommitted; double-gated, never shipped)
app/api/auth/dev-login/

