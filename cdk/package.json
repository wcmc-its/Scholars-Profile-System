{
  "name": "scholars-profile-system-cdk",
  "version": "0.1.0",
  "private": true,
  "description": "AWS CDK infrastructure for the Scholars Profile System — see docs/ADR-008-infrastructure-as-code.md.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.254.0",
    "constructs": "^10.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1122.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/test/**/*.test.ts"
    ],
    "snapshotFormat": {
      "printBasicPrototype": false,
      "escapeString": false
    }
  }
}
