        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "PublicAlbUnhealthyHostsAlarm114335BE": {
      "Properties": {
        "AlarmDescription": "Public ALB has zero healthy targets for 5 consecutive minutes (staging). Circuit-breaker did not catch it -- real outage.",
        "AlarmName": "sps-alb-unhealthy-hosts-staging",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 5,
        "Dimensions": [
          {
            "Name": "LoadBalancer",
            "Value": {
              "Fn::Join": [
                "",
                [
                  {
                    "Fn::Select": [
                      1,
                      {
                        "Fn::Split": [
                          "/",
                          {
                            "Fn::ImportValue": "Sps-App-staging:ExportsOutputRefPublicAlbPublicHttpListener8CAA0E9132EB9A1D",
                          },
                        ],
                      },
                    ],
                  },
                  "/",
                  {
                    "Fn::Select": [
                      2,
                      {
                        "Fn::Split": [
                          "/",
                          {
                            "Fn::ImportValue": "Sps-App-staging:ExportsOutputRefPublicAlbPublicHttpListener8CAA0E9132EB9A1D",
                          },
                        ],
                      },
                    ],
                  },
                  "/",
                  {
                    "Fn::Select": [
                      3,
                      {
                        "Fn::Split": [
                          "/",
                          {
                            "Fn::ImportValue": "Sps-App-staging:ExportsOutputRefPublicAlbPublicHttpListener8CAA0E9132EB9A1D",
                          },
                        ],
                      },
                    ],
                  },
                ],
              ],
            },
          },
          {
            "Name": "TargetGroup",
            "Value": {
              "Fn::ImportValue": "Sps-App-staging:ExportsOutputFnGetAttPublicAppTargetGroup68798009TargetGroupFullName72FE596A",
            },
          },
        ],
        "EvaluationPeriods": 5,
        "MetricName": "UnHealthyHostCount",
        "Namespace": "AWS/ApplicationELB",
        "Period": 60,
        "Statistic": "Maximum",
        "Threshold": 0,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
