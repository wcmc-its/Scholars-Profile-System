    },
    "OncallRelayErrorsD5425B8E": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "NotifyTopic5FFA0016",
          },
        ],
        "AlarmDescription": "On-call relay Lambda surfaced one or more invocation errors in the last minute (staging). Paging-path delivery is at risk -- check Lambda CloudWatch logs and the Teams workflow URL in Secrets Manager. Routed to the notify topic (email) because the page topic flows through this Lambda.",
