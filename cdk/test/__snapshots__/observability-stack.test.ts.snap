    },
    "OpenSearchJvmPressureAlarm9A9BC8E1": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "WarnTopicFEEED862",
          },
        ],
        "AlarmDescription": "OpenSearch JVM memory pressure > 85% for 15m (prod). GC pressure will cascade into query latency. Next: check shard count and query load on the dashboard; throttle heavy queries or scale the domain.",
        "AlarmName": "sps-opensearch-jvm-pressure-prod",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 3,
        "Dimensions": [
          {
            "Name": "ClientId",
            "Value": "123456789012",
          },
          {
            "Name": "DomainName",
            "Value": "opensearchshare-hr8gdfznbeww",
          },
        ],
        "EvaluationPeriods": 3,
        "MetricName": "JVMMemoryPressure",
        "Namespace": "AWS/ES",
        "Period": 300,
        "Statistic": "Maximum",
        "Threshold": 85,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "PublicAlb5xxRateAlarmC7D5139D": {
      "Properties": {
        "AlarmDescription": "Public ALB target 5xx rate exceeds 1% over 5m (prod). Burns the 99.5% availability SLO budget. See docs/SLOs.md. Next: check the ALB 5xx panel and the most recent deploy; roll back if the spike tracks a release, else pull app logs for the failing route.",
        "AlarmName": "sps-alb-5xx-rate-prod",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 2,
        "EvaluationPeriods": 2,
        "Metrics": [
          {
            "Expression": "IF(m5xx >= 5, (m5xx / IF(reqs > 0, reqs, 1)) * 100, 0)",
            "Id": "expr_1",
            "Label": "5xx rate (%) over 5m",
            "ReturnData": true,
          },
          {
            "Id": "m5xx",
            "MetricStat": {
              "Metric": {
                "Dimensions": [
                  {
                    "Name": "LoadBalancer",
                    "Value": "app/Sps-Ap-Publi-dZ0soKIosV6j/a43ae4ad91d52643",
                  },
                ],
                "MetricName": "HTTPCode_Target_5XX_Count",
                "Namespace": "AWS/ApplicationELB",
              },
              "Period": 300,
              "Stat": "Sum",
            },
            "ReturnData": false,
          },
          {
            "Id": "reqs",
            "MetricStat": {
              "Metric": {
                "Dimensions": [
                  {
                    "Name": "LoadBalancer",
                    "Value": "app/Sps-Ap-Publi-dZ0soKIosV6j/a43ae4ad91d52643",
                  },
                ],
                "MetricName": "RequestCount",
                "Namespace": "AWS/ApplicationELB",
              },
              "Period": 300,
              "Stat": "Sum",
            },
            "ReturnData": false,
          },
        ],
        "Threshold": 1,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "PublicAlbLatencyP99AlarmC30883BF": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "AlarmTopicD01E77F9",
          },
        ],
        "AlarmDescription": "Public ALB target response time p99 > 1500ms over 5m (prod). Burns the latency SLO budget. See docs/SLOs.md. Next: open the reliability dashboard latency and Aurora SelectLatency panels; look for a slow query, a cold cache, or an undersized task.",
        "AlarmName": "sps-alb-latency-p99-prod",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 3,
        "Dimensions": [
          {
            "Name": "LoadBalancer",
