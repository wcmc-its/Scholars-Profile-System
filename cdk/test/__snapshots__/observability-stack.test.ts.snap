    "OpenSearchBreakerAlarm0D13D3F1": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "WarnTopicFEEED862",
          },
        ],
        "AlarmDescription": "OpenSearch refused a query with circuit_breaking_exception (staging) -- the parent breaker tripped at 95% of heap and the app returned 502. Next: check JVMMemoryPressure Maximum on the domain; the node is undersized or a query burst (e.g. the sponsor-match fan-out) is too heavy for the heap.",
        "AlarmName": "sps-opensearch-breaker-staging",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 1,
        "EvaluationPeriods": 1,
        "MetricName": "OpenSearchCircuitBreaker",
        "Namespace": "SPS/Search",
        "Period": 300,
        "Statistic": "Sum",
        "Threshold": 0,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "OpenSearchBreakerMetricFilter2EF567D5": {
      "Properties": {
        "FilterName": "sps-opensearch-breaker-staging",
        "FilterPattern": ""circuit_breaking_exception"",
