      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "EditAuthzDeniedMetricFilterC5F6CB25": {
      "Properties": {
        "FilterName": "sps-edit-authz-denied-staging",
        "FilterPattern": "{ $.event = "edit_authz_denied" }",
        "LogGroupName": {
          "Fn::ImportValue": "Sps-App-staging:ExportsOutputRefAppLogGroup7D8CD9527CC48D3E",
        },
        "MetricTransformations": [
          {
            "DefaultValue": 0,
            "MetricName": "EditAuthzDenied",
            "MetricNamespace": "SPS/Auth",
            "MetricValue": "1",
          },
        ],
      },
      "Type": "AWS::Logs::MetricFilter",
    },
    "EtlFailuresRelaySubscriptionD17272A2": {
      "Properties": {
        "Endpoint": {
          "Fn::GetAtt": [
            "OncallRelayFunction9974C7E1",
            "Arn",
