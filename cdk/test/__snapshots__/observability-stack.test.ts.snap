        },
        "MetricTransformations": [
          {
            "DefaultValue": 0,
            "MetricName": "OpenSearchCircuitBreaker",
            "MetricNamespace": "SPS/Search",
            "MetricValue": "1",
          },
        ],
      },
      "Type": "AWS::Logs::MetricFilter",
    },
