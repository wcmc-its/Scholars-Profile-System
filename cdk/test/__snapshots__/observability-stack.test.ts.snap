        "Fn::GetAtt": [
          "OncallRelayFunction9974C7E1",
          "Arn",
        ],
      },
    },
    "WarnTopicArn": {
      "Description": "SNS topic for the P2 warn tier (data-freshness / reconciler / resource-pressure). Relayed to a separate Teams channel, falling back to the page channel if scholars/{env}/oncall/teams-webhook-url-warn is unset.",
