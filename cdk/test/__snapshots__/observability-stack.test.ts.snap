            "MetricName": "OpenSearchCircuitBreaker",
            "MetricNamespace": "SPS/Search",
            "MetricValue": "1",
          },
        ],
      },
      "Type": "AWS::Logs::MetricFilter",
    },
    "OpenSearchClusterRedAlarm2725A3FB": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "AlarmTopicD01E77F9",
          },
        ],
        "AlarmDescription": "OpenSearch cluster status is RED (prod). Shards unassigned -- searches affected. Next: check OpenSearch _cluster/health; reallocate or restore the affected index from snapshot.",
        "AlarmName": "sps-opensearch-cluster-red-prod",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 1,
        "Dimensions": [
          {
            "Name": "ClientId",
