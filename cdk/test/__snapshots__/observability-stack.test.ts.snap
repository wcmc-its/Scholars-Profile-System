        "MonitorType": "DIMENSIONAL",
      },
      "Type": "AWS::CE::AnomalyMonitor",
    },
    "AnomalySubscription": {
      "Properties": {
        "Frequency": "IMMEDIATE",
        "MonitorArnList": [
          {
            "Ref": "AnomalyMonitor",
          },
        ],
        "Subscribers": [
          {
            "Address": {
              "Ref": "NotifyTopic5FFA0016",
            },
            "Status": "CONFIRMED",
            "Type": "SNS",
          },
        ],
        "SubscriptionName": "sps-anomaly-subscription",
        "ThresholdExpression": "{"Dimensions":{"Key":"ANOMALY_TOTAL_IMPACT_ABSOLUTE","MatchOptions":["GREATER_THAN_OR_EQUAL"],"Values":["50"]}}",
      },
      "Type": "AWS::CE::AnomalySubscription",
    },
    "AppUnavailableAlarm128C3206": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "AlarmTopicD01E77F9",
          },
        ],
        "AlarmDescription": "Public serving is degraded or down (prod): one or more of 5xx-rate / zero-healthy-hosts / task-shortfall is in ALARM. Single P1 page for the serving cascade. See docs/SLOs.md. Next: open the reliability dashboard; if Aurora CPU/connections are also high, suspect DB connection-pool exhaustion; if it tracks the last deploy, roll back (DEPLOY-RUNBOOK.md).",
        "AlarmName": "sps-app-unavailable-prod",
        "AlarmRule": {
          "Fn::Join": [
            "",
            [
              "(ALARM("",
              {
                "Fn::GetAtt": [
                  "PublicAlb5xxRateAlarmC7D5139D",
                  "Arn",
                ],
              },
              "") OR ALARM("",
              {
                "Fn::GetAtt": [
                  "PublicAlbUnhealthyHostsAlarm114335BE",
                  "Arn",
                ],
              },
              "") OR ALARM("",
              {
                "Fn::GetAtt": [
                  "EcsTaskShortfallAlarm951444EC",
                  "Arn",
                ],
              },
              ""))",
            ],
          ],
        },
      },
      "Type": "AWS::CloudWatch::CompositeAlarm",
    },
    "AuroraConnectionsAlarm320D1F2B": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "WarnTopicFEEED862",
          },
        ],
        "AlarmDescription": "Aurora active connection count > 70 sustained over 10m (prod). Normal peak is 60; each leaked Prisma pool adds exactly 15, and the cluster caps near 90. Most likely a one-off ECS probe/eval task that never called db.$disconnect() and is still RUNNING long after printing its output. Next: aws ecs list-tasks --cluster sps-cluster-prod --family sps-etl-prod --desired-status RUNNING, stop the zombies (read-only probes are data-safe), and watch DatabaseConnections drain. See docs/performance-baseline.md.",
        "AlarmName": "sps-aurora-connections-prod",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 2,
        "Dimensions": [
          {
            "Name": "DBClusterIdentifier",
            "Value": "sps-data-prod-auroraclusterfromsnapshot7b6a45d8-ylbuldcja7bm",
          },
        ],
        "EvaluationPeriods": 2,
        "MetricName": "DatabaseConnections",
        "Namespace": "AWS/RDS",
        "Period": 300,
        "Statistic": "Maximum",
        "Threshold": 70,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "AuroraCpuAlarm999C031F": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "WarnTopicFEEED862",
          },
        ],
        "AlarmDescription": "Aurora cluster CPU > 80% sustained for 10m (prod). Likely a hot query loop or runaway analytic. Next: check Performance Insights or the slow-query log; scale ACUs only if the load is legitimate.",
        "AlarmName": "sps-aurora-cpu-prod",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 3,
        "Dimensions": [
          {
            "Name": "DBClusterIdentifier",
            "Value": "sps-data-prod-auroraclusterfromsnapshot7b6a45d8-ylbuldcja7bm",
          },
        ],
        "EvaluationPeriods": 3,
        "MetricName": "CPUUtilization",
        "Namespace": "AWS/RDS",
        "Period": 300,
        "Statistic": "Average",
        "Threshold": 80,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "DbPoolTimeoutAlarm06C9E04F": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "AlarmTopicD01E77F9",
          },
        ],
        "AlarmDescription": "A request could not get a DB connection from the pool (prod) -- users are seeing 500s right now. If the log line says active=0 idle=0, the Aurora cluster is at its connection cap and recycling the app will NOT help. Next: check DatabaseConnections on the cluster, then stop any zombie one-off ECS tasks holding pools (see the sps-aurora-connections-prod alarm and docs/performance-baseline.md).",
        "AlarmName": "sps-db-pool-timeout-prod",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 1,
        "EvaluationPeriods": 1,
        "MetricName": "DbPoolTimeout",
        "Namespace": "SPS/Data",
        "Period": 300,
        "Statistic": "Sum",
