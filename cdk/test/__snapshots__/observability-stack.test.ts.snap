    "WarnTopicFEEED862": {
      "Properties": {
        "DisplayName": "SPS prod warnings (P2)",
        "TopicName": "sps-warn-prod",
      },
      "Type": "AWS::SNS::Topic",
    },
  },
  "Rules": {
    "CheckBootstrapVersion": {
      "Assertions": [
        {
          "Assert": {
            "Fn::Not": [
              {
                "Fn::Contains": [
                  [
                    "1",
                    "2",
                    "3",
                    "4",
                    "5",
                  ],
                  {
                    "Ref": "BootstrapVersion",
                  },
                ],
              },
            ],
          },
          "AssertDescription": "CDK bootstrap stack version 6 required. Please run 'cdk bootstrap' with a recent version of the CDK CLI.",
        },
      ],
    },
  },
}
`;

exports[`SpsObservabilityStack staging matches the snapshot 1`] = `
{
  "Outputs": {
    "AlarmTopicArn": {
      "Description": "SNS topic every CloudWatch alarm publishes to (page). The Teams channel webhook is subscribed out-of-band per docs/oncall.md.",
      "Value": {
        "Ref": "AlarmTopicD01E77F9",
      },
    },
    "NotifyTopicArn": {
      "Description": "SNS topic for cost guardrails + low-urgency fan-out (notify). Operator email subscription lands here, not on the page topic.",
      "Value": {
        "Ref": "NotifyTopic5FFA0016",
      },
    },
    "OncallRelayFunctionArn": {
      "Description": "Lambda that relays page topic SNS events to a Teams workflow as Adaptive Card JSON (B27). Reads workflow URL from scholars/{env}/oncall/teams-webhook-url at cold start.",
      "Value": {
        "Fn::GetAtt": [
          "OncallRelayFunction9974C7E1",
          "Arn",
        ],
      },
    },
    "WarnTopicArn": {
      "Description": "SNS topic for the P2 warn tier (data-freshness / reconciler / resource-pressure). Relayed to a separate Teams channel, falling back to the page channel if scholars/{env}/oncall/teams-webhook-url-warn is unset.",
      "Value": {
        "Ref": "WarnTopicFEEED862",
      },
    },
  },
  "Parameters": {
    "BootstrapVersion": {
      "Default": "/cdk-bootstrap/hnb659fds/version",
      "Description": "Version of the CDK Bootstrap resources in this environment, automatically retrieved from SSM Parameter Store. [cdk:skip]",
      "Type": "AWS::SSM::Parameter::Value<String>",
    },
  },
  "Resources": {
    "AlarmTopicD01E77F9": {
      "Properties": {
        "DisplayName": "SPS staging alarms (page)",
        "TopicName": "sps-alarms-staging",
      },
      "Type": "AWS::SNS::Topic",
    },
    "AppUnavailableAlarm128C3206": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "AlarmTopicD01E77F9",
          },
        ],
        "AlarmDescription": "Public serving is degraded or down (staging): one or more of 5xx-rate / zero-healthy-hosts / task-shortfall is in ALARM. Single P1 page for the serving cascade. See docs/SLOs.md. Next: open the reliability dashboard; if Aurora CPU/connections are also high, suspect DB connection-pool exhaustion; if it tracks the last deploy, roll back (DEPLOY-RUNBOOK.md).",
        "AlarmName": "sps-app-unavailable-staging",
        "AlarmRule": {
          "Fn::Join": [
            "",
            [
              "(ALARM("",
              {
                "Fn::GetAtt": [
                  "PublicAlb5xxRateAlarmC7D5139D",
                  "Arn",
                ],
              },
              "") OR ALARM("",
              {
                "Fn::GetAtt": [
                  "PublicAlbUnhealthyHostsAlarm114335BE",
                  "Arn",
                ],
              },
              "") OR ALARM("",
              {
                "Fn::GetAtt": [
                  "EcsTaskShortfallAlarm951444EC",
                  "Arn",
                ],
              },
              ""))",
            ],
          ],
        },
      },
      "Type": "AWS::CloudWatch::CompositeAlarm",
    },
    "AuroraConnectionsAlarm320D1F2B": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "WarnTopicFEEED862",
          },
        ],
        "AlarmDescription": "Aurora active connection count > 70 sustained over 10m (staging). Normal peak is 60; each leaked Prisma pool adds exactly 15, and the cluster caps near 90. Most likely a one-off ECS probe/eval task that never called db.$disconnect() and is still RUNNING long after printing its output. Next: aws ecs list-tasks --cluster sps-cluster-staging --family sps-etl-staging --desired-status RUNNING, stop the zombies (read-only probes are data-safe), and watch DatabaseConnections drain. See docs/performance-baseline.md.",
        "AlarmName": "sps-aurora-connections-staging",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 2,
        "Dimensions": [
          {
            "Name": "DBClusterIdentifier",
            "Value": "sps-data-staging-auroraclusterfromsnapshot7b6a45d8-8kp4eh79cfrn",
          },
        ],
        "EvaluationPeriods": 2,
        "MetricName": "DatabaseConnections",
        "Namespace": "AWS/RDS",
        "Period": 300,
        "Statistic": "Maximum",
        "Threshold": 70,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "AuroraCpuAlarm999C031F": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "WarnTopicFEEED862",
          },
        ],
        "AlarmDescription": "Aurora cluster CPU > 80% sustained for 10m (staging). Likely a hot query loop or runaway analytic. Next: check Performance Insights or the slow-query log; scale ACUs only if the load is legitimate.",
        "AlarmName": "sps-aurora-cpu-staging",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 3,
        "Dimensions": [
          {
            "Name": "DBClusterIdentifier",
            "Value": "sps-data-staging-auroraclusterfromsnapshot7b6a45d8-8kp4eh79cfrn",
          },
        ],
        "EvaluationPeriods": 3,
        "MetricName": "CPUUtilization",
        "Namespace": "AWS/RDS",
        "Period": 300,
        "Statistic": "Average",
        "Threshold": 80,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "DbPoolTimeoutAlarm06C9E04F": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "AlarmTopicD01E77F9",
          },
        ],
        "AlarmDescription": "A request could not get a DB connection from the pool (staging) -- users are seeing 500s right now. If the log line says active=0 idle=0, the Aurora cluster is at its connection cap and recycling the app will NOT help. Next: check DatabaseConnections on the cluster, then stop any zombie one-off ECS tasks holding pools (see the sps-aurora-connections-staging alarm and docs/performance-baseline.md).",
        "AlarmName": "sps-db-pool-timeout-staging",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 1,
        "EvaluationPeriods": 1,
        "MetricName": "DbPoolTimeout",
        "Namespace": "SPS/Data",
        "Period": 300,
        "Statistic": "Sum",
        "Threshold": 0,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "DbPoolTimeoutMetricFilterEC77C148": {
      "Properties": {
        "FilterName": "sps-db-pool-timeout-staging",
        "FilterPattern": ""pool timeout"",
        "LogGroupName": {
          "Fn::ImportValue": "Sps-App-staging:ExportsOutputRefAppLogGroup7D8CD9527CC48D3E",
        },
        "MetricTransformations": [
          {
            "DefaultValue": 0,
            "MetricName": "DbPoolTimeout",
            "MetricNamespace": "SPS/Data",
            "MetricValue": "1",
          },
        ],
      },
      "Type": "AWS::Logs::MetricFilter",
    },
    "EcsTaskShortfallAlarm951444EC": {
      "Properties": {
        "AlarmDescription": "ECS service running task count is below desired for 5 consecutive minutes (staging). Tasks died and are not being replaced. Next: check ECS service events for image-pull, capacity, or IAM failures and the recent deploy.",
        "AlarmName": "sps-ecs-task-shortfall-staging",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 5,
        "EvaluationPeriods": 5,
        "Metrics": [
          {
            "Expression": "desired - running",
            "Id": "expr_1",
            "Label": "Desired - Running tasks (5m)",
            "ReturnData": true,
          },
          {
            "Id": "desired",
            "MetricStat": {
              "Metric": {
                "Dimensions": [
                  {
                    "Name": "ClusterName",
                    "Value": {
                      "Fn::ImportValue": "Sps-App-staging:ExportsOutputRefEcsCluster97242B84553A5D8F",
                    },
                  },
                  {
                    "Name": "ServiceName",
                    "Value": {
                      "Fn::ImportValue": "Sps-App-staging:ExportsOutputFnGetAttEcsService81FC6EF6Name1D81E5BE",
                    },
                  },
                ],
                "MetricName": "DesiredTaskCount",
                "Namespace": "ECS/ContainerInsights",
              },
              "Period": 60,
              "Stat": "Maximum",
            },
            "ReturnData": false,
          },
          {
            "Id": "running",
            "MetricStat": {
              "Metric": {
                "Dimensions": [
                  {
                    "Name": "ClusterName",
                    "Value": {
                      "Fn::ImportValue": "Sps-App-staging:ExportsOutputRefEcsCluster97242B84553A5D8F",
                    },
                  },
                  {
                    "Name": "ServiceName",
                    "Value": {
                      "Fn::ImportValue": "Sps-App-staging:ExportsOutputFnGetAttEcsService81FC6EF6Name1D81E5BE",
                    },
                  },
                ],
                "MetricName": "RunningTaskCount",
                "Namespace": "ECS/ContainerInsights",
              },
              "Period": 60,
              "Stat": "Minimum",
            },
            "ReturnData": false,
          },
        ],
        "Threshold": 0,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "EditAuthzDeniedAlarm19EBB8B8": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "WarnTopicFEEED862",
          },
        ],
        "AlarmDescription": "Edit-surface 403 (edit_authz_denied) count > 10 in any 5m window for 2 consecutive windows (staging). Sustained rate -- predicate bug or active probing. See docs/SLOs.md. Next: check for an authz-predicate regression in the last deploy, or active probing; review the edit_authz_denied logs for the actor and path.",
