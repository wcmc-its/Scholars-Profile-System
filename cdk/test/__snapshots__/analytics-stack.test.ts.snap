        "QueryString": "SELECT dimension AS region, SUM(cnt) AS hits
FROM daily_usage
WHERE metric = 'geo'
GROUP BY dimension
ORDER BY hits DESC",
        "WorkGroup": "sps-usage-prod",
      },
      "Type": "AWS::Athena::NamedQuery",
    },
    "QueryReferrers": {
