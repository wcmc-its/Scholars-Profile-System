    "DailyUsageTable": {
      "DependsOn": [
        "UsageDatabase",
      ],
      "Properties": {
        "CatalogId": {
          "Ref": "AWS::AccountId",
        },
        "DatabaseName": {
          "Ref": "UsageDatabase",
        },
        "TableInput": {
          "Description": "Pre-aggregated daily CloudFront usage (staging), TSV, partition-projected on dt. Aggregates only -- no client IPs.",
          "Name": "daily_usage",
          "Parameters": {
            "classification": "csv",
            "projection.dt.format": "yyyy-MM-dd",
            "projection.dt.range": "2026-05-22,NOW",
            "projection.dt.type": "date",
            "projection.enabled": "true",
            "storage.location.template": {
              "Fn::Join": [
                "",
                [
                  "s3://",
                  {
                    "Ref": "AnalyticsBucket39EAAEEA",
                  },
                  "/rollup/daily-usage/dt=\${dt}/",
                ],
              ],
            },
          },
          "PartitionKeys": [
            {
              "Name": "dt",
              "Type": "string",
            },
          ],
          "StorageDescriptor": {
            "Columns": [
              {
                "Name": "metric",
                "Type": "string",
              },
              {
                "Name": "dimension",
                "Type": "string",
              },
              {
                "Name": "cnt",
                "Type": "bigint",
              },
            ],
            "InputFormat": "org.apache.hadoop.mapred.TextInputFormat",
            "Location": {
              "Fn::Join": [
                "",
                [
                  "s3://",
                  {
                    "Ref": "AnalyticsBucket39EAAEEA",
                  },
                  "/rollup/daily-usage",
                ],
              ],
            },
            "OutputFormat": "org.apache.hadoop.hive.ql.io.HiveIgnoreKeyTextOutputFormat",
            "SerdeInfo": {
              "Parameters": {
                "field.delim": "	",
              },
              "SerializationLibrary": "org.apache.hadoop.hive.serde2.lazy.LazySimpleSerDe",
            },
          },
          "TableType": "EXTERNAL_TABLE",
        },
      },
      "Type": "AWS::Glue::Table",
    },
    "QueryDailyPageviews": {
      "DependsOn": [
        "UsageDatabase",
        "UsageWorkGroup",
      ],
      "Properties": {
        "Database": {
          "Ref": "UsageDatabase",
        },
        "Description": "Daily profile pageviews over the rollup.",
        "Name": "sps-usage-daily-pageviews-staging",
        "QueryString": "SELECT dt, SUM(cnt) AS pageviews
FROM daily_usage
WHERE metric = 'pageviews'
GROUP BY dt
ORDER BY dt DESC",
        "WorkGroup": "sps-usage-staging",
      },
      "Type": "AWS::Athena::NamedQuery",
    },
    "QueryDevice": {
      "DependsOn": [
        "UsageDatabase",
        "UsageWorkGroup",
      ],
      "Properties": {
        "Database": {
          "Ref": "UsageDatabase",
        },
        "Description": "Hits by device class (bot/tablet/mobile/desktop).",
        "Name": "sps-usage-device-staging",
        "QueryString": "SELECT dimension AS device, SUM(cnt) AS hits
FROM daily_usage
WHERE metric = 'device'
GROUP BY dimension
ORDER BY hits DESC",
        "WorkGroup": "sps-usage-staging",
      },
      "Type": "AWS::Athena::NamedQuery",
    },
    "QueryGeo": {
      "DependsOn": [
        "UsageDatabase",
        "UsageWorkGroup",
      ],
      "Properties": {
        "Database": {
          "Ref": "UsageDatabase",
        },
        "Description": "Hits by coarse continent (x-edge-location based).",
        "Name": "sps-usage-geo-staging",
        "QueryString": "SELECT dimension AS region, SUM(cnt) AS hits
FROM daily_usage
WHERE metric = 'geo'
GROUP BY dimension
ORDER BY hits DESC",
        "WorkGroup": "sps-usage-staging",
      },
      "Type": "AWS::Athena::NamedQuery",
    },
    "QueryReferrers": {
      "DependsOn": [
        "UsageDatabase",
        "UsageWorkGroup",
      ],
      "Properties": {
        "Database": {
          "Ref": "UsageDatabase",
        },
        "Description": "Referrers split internal/direct vs external host (dimension).",
        "Name": "sps-usage-referrers-staging",
        "QueryString": "SELECT dimension AS referrer, SUM(cnt) AS hits
FROM daily_usage
WHERE metric = 'referrer'
GROUP BY dimension
ORDER BY hits DESC",
        "WorkGroup": "sps-usage-staging",
      },
      "Type": "AWS::Athena::NamedQuery",
    },
    "QuerySearchTerms": {
      "DependsOn": [
        "UsageDatabase",
        "UsageWorkGroup",
      ],
      "Properties": {
        "Database": {
          "Ref": "UsageDatabase",
        },
        "Description": "Top 100 search terms (dimension = decoded q=).",
        "Name": "sps-usage-search-terms-staging",
        "QueryString": "SELECT dimension AS term, SUM(cnt) AS searches
FROM daily_usage
WHERE metric = 'search_term'
GROUP BY dimension
ORDER BY searches DESC
LIMIT 100",
        "WorkGroup": "sps-usage-staging",
      },
      "Type": "AWS::Athena::NamedQuery",
    },
    "QueryTopProfiles": {
      "DependsOn": [
        "UsageDatabase",
        "UsageWorkGroup",
      ],
      "Properties": {
        "Database": {
          "Ref": "UsageDatabase",
        },
        "Description": "Top 50 profiles by pageview (dimension = cwid).",
        "Name": "sps-usage-top-profiles-staging",
        "QueryString": "SELECT dimension AS cwid, SUM(cnt) AS views
FROM daily_usage
WHERE metric = 'profile'
GROUP BY dimension
ORDER BY views DESC
LIMIT 50",
        "WorkGroup": "sps-usage-staging",
      },
      "Type": "AWS::Athena::NamedQuery",
    },
    "RollupWorkGroup": {
      "Properties": {
        "Description": "SPS CloudFront usage rollup workgroup (staging). Nightly rollup Lambda only -- uncapped, scans the unpartitioned raw log table.",
        "Name": "sps-usage-rollup-staging",
        "RecursiveDeleteOption": true,
        "State": "ENABLED",
        "WorkGroupConfiguration": {
          "EnforceWorkGroupConfiguration": true,
          "PublishCloudWatchMetricsEnabled": true,
          "ResultConfiguration": {
            "EncryptionConfiguration": {
              "EncryptionOption": "SSE_S3",
            },
            "OutputLocation": {
              "Fn::Join": [
                "",
                [
                  "s3://",
                  {
                    "Ref": "AnalyticsBucket39EAAEEA",
                  },
                  "/athena-results",
                ],
              ],
            },
          },
        },
      },
      "Type": "AWS::Athena::WorkGroup",
    },
    "UsageDatabase": {
      "Properties": {
        "CatalogId": {
          "Ref": "AWS::AccountId",
        },
        "DatabaseInput": {
          "Description": "SPS CloudFront usage analytics (staging). Backs Athena queries over CloudFront access logs.",
          "Name": "sps_usage_staging",
        },
      },
      "Type": "AWS::Glue::Database",
    },
    "UsageWorkGroup": {
      "Properties": {
        "Description": "SPS CloudFront usage analytics workgroup (staging). Operator-restricted -- exposes client IPs via cf_access_logs.",
        "Name": "sps-usage-staging",
        "RecursiveDeleteOption": true,
        "State": "ENABLED",
        "WorkGroupConfiguration": {
          "BytesScannedCutoffPerQuery": 1073741824,
          "EnforceWorkGroupConfiguration": true,
          "PublishCloudWatchMetricsEnabled": true,
          "ResultConfiguration": {
            "EncryptionConfiguration": {
              "EncryptionOption": "SSE_S3",
            },
            "OutputLocation": {
              "Fn::Join": [
