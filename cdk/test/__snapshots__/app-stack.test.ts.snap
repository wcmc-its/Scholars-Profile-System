    "VerifyGrantsTaskDefinition82FF6836": {
      "Properties": {
        "ContainerDefinitions": [
          {
            "EntryPoint": [
              "npx",
              "tsx",
              "scripts/verify-db-grants.ts",
            ],
            "Environment": [
              {
                "Name": "VERIFY_ROLES",
                "Value": "app-ro,app-rw,sps_migrate,sps_bootstrap",
              },
            ],
            "Essential": true,
            "Image": {
              "Fn::Join": [
                "",
                [
                  {
                    "Fn::Select": [
