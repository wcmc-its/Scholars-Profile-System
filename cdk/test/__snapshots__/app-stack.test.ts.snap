    "VerifyGrantsLogGroupD90AC2C4": {
      "DeletionPolicy": "Retain",
      "Properties": {
        "LogGroupName": "/aws/ecs/sps-verify-grants-staging",
        "RetentionInDays": 30,
      },
      "Type": "AWS::Logs::LogGroup",
      "UpdateReplacePolicy": "Retain",
    },
    "VerifyGrantsTaskDefinition82FF6836": {
      "Properties": {
        "ContainerDefinitions": [
          {
            "EntryPoint": [
              "npx",
              "tsx",
              "scripts/verify-db-grants.ts",
            ],
            "Environment": [
              {
                "Name": "VERIFY_ROLES",
                "Value": "app-ro,app-rw,sps_migrate,sps_bootstrap",
              },
            ],
            "Essential": true,
            "Image": {
              "Fn::Join": [
                "",
                [
                  {
                    "Fn::Select": [
                      4,
                      {
                        "Fn::Split": [
                          ":",
                          {
                            "Fn::GetAtt": [
                              "EtlEcrRepository058F5EEC",
                              "Arn",
                            ],
                          },
                        ],
                      },
                    ],
                  },
                  ".dkr.ecr.",
                  {
                    "Fn::Select": [
                      3,
                      {
                        "Fn::Split": [
                          ":",
                          {
                            "Fn::GetAtt": [
                              "EtlEcrRepository058F5EEC",
                              "Arn",
                            ],
                          },
                        ],
                      },
                    ],
                  },
                  ".",
                  {
                    "Ref": "AWS::URLSuffix",
                  },
                  "/",
                  {
                    "Ref": "EtlEcrRepository058F5EEC",
                  },
                  ":latest",
                ],
              ],
            },
            "LogConfiguration": {
              "LogDriver": "awslogs",
              "Options": {
                "awslogs-group": {
                  "Ref": "VerifyGrantsLogGroupD90AC2C4",
                },
                "awslogs-region": "us-east-1",
                "awslogs-stream-prefix": "verify-grants",
              },
            },
            "Name": "verify-grants",
            "Secrets": [
              {
                "Name": "APP_RO_DSN",
                "ValueFrom": {
                  "Fn::Join": [
                    "",
                    [
                      "arn:",
                      {
                        "Ref": "AWS::Partition",
                      },
                      ":secretsmanager:us-east-1:123456789012:secret:scholars/staging/db/app-ro",
                    ],
                  ],
                },
              },
              {
                "Name": "APP_RW_DSN",
                "ValueFrom": {
                  "Fn::Join": [
                    "",
                    [
                      "arn:",
                      {
                        "Ref": "AWS::Partition",
                      },
                      ":secretsmanager:us-east-1:123456789012:secret:scholars/staging/db/app-rw",
                    ],
                  ],
                },
              },
              {
                "Name": "BOOTSTRAP_DSN",
                "ValueFrom": {
                  "Fn::Join": [
                    "",
                    [
                      "arn:",
                      {
                        "Ref": "AWS::Partition",
                      },
                      ":secretsmanager:us-east-1:123456789012:secret:scholars/staging/db/bootstrap",
                    ],
                  ],
                },
              },
              {
                "Name": "MIGRATE_DSN",
                "ValueFrom": {
                  "Fn::Join": [
                    "",
                    [
                      "arn:",
                      {
                        "Ref": "AWS::Partition",
                      },
                      ":secretsmanager:us-east-1:123456789012:secret:scholars/staging/db/migrate",
                    ],
                  ],
                },
              },
            ],
          },
        ],
        "Cpu": "512",
        "ExecutionRoleArn": {
          "Fn::GetAtt": [
            "DeployExecutionRoleBCBD9CEE",
            "Arn",
          ],
        },
        "Family": "sps-verify-grants-staging",
        "Memory": "1024",
        "NetworkMode": "awsvpc",
        "RequiresCompatibilities": [
          "FARGATE",
        ],
        "TaskRoleArn": {
          "Fn::GetAtt": [
            "TaskRole30FC0FBB",
            "Arn",
          ],
        },
      },
      "Type": "AWS::ECS::TaskDefinition",
    },
    "VpcEndpointSecurityGroup02EA44AC": {
      "Properties": {
        "GroupDescription": "SPS VPC interface endpoints (staging) -- HTTPS from app + ETL SGs.",
        "SecurityGroupEgress": [
          {
            "CidrIp": "255.255.255.255/32",
            "Description": "Disallow all traffic",
            "FromPort": 252,
            "IpProtocol": "icmp",
            "ToPort": 86,
          },
        ],
        "SecurityGroupIngress": [
          {
            "Description": "App SG to interface endpoints HTTPS (staging)",
            "FromPort": 443,
            "IpProtocol": "tcp",
            "SourceSecurityGroupId": {
              "Fn::ImportValue": "Sps-Network-staging:ExportsOutputFnGetAttAppSecurityGroupC396D536GroupId4ECD26A6",
            },
            "ToPort": 443,
          },
          {
            "Description": "ETL SG to interface endpoints HTTPS (staging)",
            "FromPort": 443,
            "IpProtocol": "tcp",
            "SourceSecurityGroupId": {
              "Fn::ImportValue": "Sps-Network-staging:ExportsOutputFnGetAttEtlSecurityGroup5D059AE5GroupId2BECA072",
            },
            "ToPort": 443,
          },
        ],
        "VpcId": {
          "Fn::ImportValue": "Sps-Network-staging:ExportsOutputRefVpc8378EB38272D6E3A",
        },
      },
      "Type": "AWS::EC2::SecurityGroup",
    },
  },
  "Rules": {
    "CheckBootstrapVersion": {
      "Assertions": [
        {
          "Assert": {
            "Fn::Not": [
              {
                "Fn::Contains": [
                  [
                    "1",
                    "2",
                    "3",
                    "4",
                    "5",
                  ],
                  {
                    "Ref": "BootstrapVersion",
                  },
                ],
              },
            ],
          },
          "AssertDescription": "CDK bootstrap stack version 6 required. Please run 'cdk bootstrap' with a recent version of the CDK CLI.",
        },
      ],
    },
  },
}
