    "HeartbeatStatusAlarm73A0D20E": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "EtlFailureTopic8361D0D0",
          },
        ],
        "AlarmDescription": "SPS ETL heartbeat (prod) -- execution failed. Next: check the Step Functions execution and the failing step's logs; data freshness lags until it reruns.",
        "AlarmName": "sps-etl-heartbeat-status-prod",
        "ComparisonOperator": "GreaterThanThreshold",
        "Dimensions": [
          {
            "Name": "StateMachineArn",
            "Value": {
              "Ref": "HeartbeatStateMachine01CA14FE",
            },
          },
        ],
        "EvaluationPeriods": 1,
        "MetricName": "ExecutionsFailed",
        "Namespace": "AWS/States",
        "Period": 3600,
        "Statistic": "Sum",
        "Threshold": 0,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "InternalAlbIngressFromEtl": {
      "Properties": {
        "Description": "ETL SG to SPS internal ALB HTTP (prod) -- /api/revalidate",
        "FromPort": 80,
        "GroupId": {
          "Fn::ImportValue": "Sps-App-prod-InternalAlbSecurityGroupId",
        },
        "IpProtocol": "tcp",
        "SourceSecurityGroupId": {
          "Fn::ImportValue": "Sps-Network-prod:ExportsOutputFnGetAttEtlSecurityGroup5D059AE5GroupId2BECA072",
        },
        "ToPort": 80,
      },
      "Type": "AWS::EC2::SecurityGroupIngress",
    },
    "NightlyCadenceAlarmD8AE0804": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "EtlFailureTopic8361D0D0",
          },
        ],
        "AlarmDescription": "SPS ETL nightly (prod) -- cadence missed (no execution started in period). Next: confirm the EventBridge schedule is enabled and the state-machine IAM is intact; the job never started.",
        "AlarmName": "sps-etl-nightly-cadence-prod",
        "ComparisonOperator": "LessThanThreshold",
        "Dimensions": [
          {
            "Name": "StateMachineArn",
            "Value": {
              "Ref": "NightlyStateMachineFAE492F4",
            },
          },
        ],
        "EvaluationPeriods": 1,
        "MetricName": "ExecutionsStarted",
        "Namespace": "AWS/States",
        "Period": 108000,
        "Statistic": "Sum",
        "Threshold": 1,
        "TreatMissingData": "breaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "NightlyScheduleRule901B3B59": {
      "Properties": {
        "Description": "SPS ETL nightly cadence (prod). D7.",
        "Name": "sps-etl-nightly-prod",
        "ScheduleExpression": "cron(0 7 * * ? *)",
        "State": "DISABLED",
        "Targets": [
          {
            "Arn": {
              "Ref": "NightlyStateMachineFAE492F4",
            },
            "Id": "Target0",
            "Input": "{}",
            "RoleArn": {
              "Fn::GetAtt": [
                "NightlyStateMachineEventsRole120CADDC",
                "Arn",
              ],
            },
          },
        ],
      },
      "Type": "AWS::Events::Rule",
    },
    "NightlyStateMachineEventsRole120CADDC": {
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Statement": [
            {
              "Action": "sts:AssumeRole",
              "Effect": "Allow",
              "Principal": {
                "Service": "events.amazonaws.com",
              },
            },
          ],
          "Version": "2012-10-17",
        },
      },
      "Type": "AWS::IAM::Role",
    },
