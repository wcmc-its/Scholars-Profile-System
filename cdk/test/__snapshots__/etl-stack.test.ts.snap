            "Ref": "EtlFailureTopic8361D0D0",
          },
        ],
        "AlarmDescription": "SPS reconciler (prod) -- run failed (>=1 suppression row could not be reflected into the index). Next: check the Step Functions execution for the failing row; it self-heals once the underlying write succeeds.",
        "AlarmName": "sps-reconcile-status-prod",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 2,
        "Dimensions": [
          {
            "Name": "StateMachineArn",
