                "arn:aws:s3:::wcmc-reciterai-artifacts/mentoring/*",
                "arn:aws:s3:::wcmc-reciterai-artifacts/citations/*",
                "arn:aws:s3:::wcmc-reciterai-artifacts/clinical-trials/*",
