    "NightlyCadenceAlarmD8AE0804": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "EtlFailureTopic8361D0D0",
          },
        ],
        "AlarmDescription": "SPS ETL nightly (staging) -- cadence missed (no execution started in period).",
        "AlarmName": "sps-etl-nightly-cadence-staging",
        "ComparisonOperator": "LessThanThreshold",
        "Dimensions": [
          {
            "Name": "StateMachineArn",
            "Value": {
              "Ref": "NightlyStateMachineFAE492F4",
            },
          },
        ],
        "EvaluationPeriods": 1,
        "MetricName": "ExecutionsStarted",
        "Namespace": "AWS/States",
        "Period": 108000,
        "Statistic": "Sum",
        "Threshold": 1,
        "TreatMissingData": "breaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "NightlyScheduleRule901B3B59": {
      "Properties": {
        "Description": "SPS ETL nightly cadence (staging). D7.",
