            "Ref": "EtlTaskRoleD514E3A1",
          },
        ],
      },
      "Type": "AWS::IAM::Policy",
    },
    "HeartbeatCadenceAlarm4771CCDE": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "EtlFailureTopic8361D0D0",
          },
        ],
        "AlarmDescription": "SPS ETL heartbeat (prod) -- cadence missed (no execution started in period). Next: confirm the EventBridge schedule is enabled and the state-machine IAM is intact; the job never started.",
        "AlarmName": "sps-etl-heartbeat-cadence-prod",
        "ComparisonOperator": "LessThanThreshold",
        "Dimensions": [
          {
            "Name": "StateMachineArn",
            "Value": {
              "Ref": "HeartbeatStateMachine01CA14FE",
            },
          },
        ],
        "EvaluationPeriods": 1,
        "MetricName": "ExecutionsStarted",
        "Namespace": "AWS/States",
        "Period": 108000,
        "Statistic": "Sum",
        "Threshold": 1,
        "TreatMissingData": "breaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "HeartbeatScheduleRuleF9DC8C97": {
      "Properties": {
        "Description": "SPS ETL heartbeat cadence (prod). D7.",
        "Name": "sps-etl-heartbeat-prod",
        "ScheduleExpression": "cron(0 13 * * ? *)",
        "State": "DISABLED",
        "Targets": [
          {
            "Arn": {
              "Ref": "HeartbeatStateMachine01CA14FE",
            },
            "Id": "Target0",
            "Input": "{}",
            "RoleArn": {
              "Fn::GetAtt": [
                "HeartbeatStateMachineEventsRole36C2FBF4",
                "Arn",
              ],
            },
          },
        ],
      },
      "Type": "AWS::Events::Rule",
    },
    "HeartbeatStateMachine01CA14FE": {
      "DeletionPolicy": "Delete",
      "DependsOn": [
        "HeartbeatStateMachineRoleDefaultPolicyA5FFE017",
        "HeartbeatStateMachineRole037956AD",
      ],
      "Properties": {
        "DefinitionString": {
          "Fn::Join": [
            "",
            [
              "{"StartAt":"HeartbeatStateMachineStartFromChoice","States":{"HeartbeatStateMachineStartFromChoice":{"Type":"Choice","Choices":[{"And":[{"Variable":"$.startFrom","IsPresent":true},{"Variable":"$.startFrom","StringEquals":"Freshness"}],"Next":"TaskFreshness"}],"Default":"TaskFreshness"},"TaskFreshness":{"End":true,"Retry":[{"ErrorEquals":["States.TaskFailed","States.Timeout"],"IntervalSeconds":30,"MaxAttempts":2,"BackoffRate":2}],"Catch":[{"ErrorEquals":["States.ALL"],"ResultPath":"$.error","Next":"NotifyFreshness"}],"Type":"Task","TimeoutSeconds":86400,"Resource":"arn:",
              {
                "Ref": "AWS::Partition",
              },
              ":states:::ecs:runTask.sync","Parameters":{"Cluster":"",
              {
                "Fn::ImportValue": "Sps-App-prod:ExportsOutputFnGetAttEcsCluster97242B84ArnEAEDD48A",
              },
              "","TaskDefinition":"sps-etl-prod","NetworkConfiguration":{"AwsvpcConfiguration":{"Subnets":["",
              {
                "Fn::ImportValue": "Sps-Network-prod:ExportsOutputRefVpcprivateSubnet1SubnetCEAD37168693D373",
              },
              "","",
              {
                "Fn::ImportValue": "Sps-Network-prod:ExportsOutputRefVpcprivateSubnet2Subnet2DE7549CDF5ACE3D",
              },
              ""],"SecurityGroups":["",
              {
                "Fn::ImportValue": "Sps-Network-prod:ExportsOutputFnGetAttEtlSecurityGroup5D059AE5GroupId2BECA072",
              },
              ""]}},"Overrides":{"ContainerOverrides":[{"Name":"etl","Command":["npm","run","etl:freshness"]}]},"LaunchType":"FARGATE","PlatformVersion":"LATEST"}},"NotifyFreshness":{"Next":"FailFreshness","Type":"Task","Resource":"arn:",
              {
                "Ref": "AWS::Partition",
              },
              ":states:::sns:publish","Parameters":{"TopicArn":"",
              {
                "Ref": "EtlFailureTopic8361D0D0",
              },
              "","Message":{"env":"prod","step":"Freshness","stateMachine.$":"$$.StateMachine.Name","execution.$":"$$.Execution.Name","error.$":"$.error"},"Subject":"SPS ETL prod -- Freshness failed"}},"FailFreshness":{"Type":"Fail","Cause":"Freshness failed"}},"TimeoutSeconds":86400}",
            ],
          ],
        },
        "LoggingConfiguration": {
          "Destinations": [
            {
              "CloudWatchLogsLogGroup": {
                "LogGroupArn": {
                  "Fn::GetAtt": [
                    "HeartbeatStateMachineLogGroup15CC0912",
                    "Arn",
                  ],
                },
              },
            },
          ],
          "IncludeExecutionData": false,
          "Level": "ERROR",
        },
        "RoleArn": {
          "Fn::GetAtt": [
            "HeartbeatStateMachineRole037956AD",
            "Arn",
          ],
        },
        "StateMachineName": "scholars-heartbeat-prod",
        "StateMachineType": "STANDARD",
        "TracingConfiguration": {
          "Enabled": true,
        },
      },
      "Type": "AWS::StepFunctions::StateMachine",
      "UpdateReplacePolicy": "Delete",
    },
