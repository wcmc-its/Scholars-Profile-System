        "Statistic": "Sum",
        "Threshold": 0,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "ReconcileTaskDefinitionDBA0B2ED": {
      "Properties": {
        "ContainerDefinitions": [
          {
            "Environment": [
              {
                "Name": "NODE_ENV",
                "Value": "production",
              },
              {
                "Name": "OPENSEARCH_NODE",
                "Value": {
                  "Fn::Join": [
                    "",
                    [
                      "https://",
                      {
                        "Fn::ImportValue": "Sps-Data-prod-OpenSearchDomainEndpoint",
                      },
                    ],
                  ],
                },
              },
            ],
            "Essential": true,
            "Image": {
              "Fn::Join": [
                "",
                [
                  {
                    "Fn::Select": [
                      4,
                      {
                        "Fn::Split": [
                          ":",
                          {
                            "Fn::ImportValue": "Sps-App-prod:ExportsOutputFnGetAttEtlEcrRepository058F5EECArn64168886",
                          },
                        ],
                      },
                    ],
                  },
                  ".dkr.ecr.",
                  {
                    "Fn::Select": [
                      3,
                      {
                        "Fn::Split": [
                          ":",
                          {
                            "Fn::ImportValue": "Sps-App-prod:ExportsOutputFnGetAttEtlEcrRepository058F5EECArn64168886",
                          },
                        ],
                      },
                    ],
                  },
                  ".",
                  {
                    "Ref": "AWS::URLSuffix",
                  },
                  "/",
                  {
                    "Fn::ImportValue": "Sps-App-prod:ExportsOutputRefEtlEcrRepository058F5EEC7A385183",
                  },
                  ":latest",
                ],
              ],
            },
            "LogConfiguration": {
              "LogDriver": "awslogs",
              "Options": {
                "awslogs-group": {
                  "Ref": "ReconcileLogGroup1B0AF242",
                },
                "awslogs-region": "us-east-1",
                "awslogs-stream-prefix": "reconcile",
              },
            },
            "Name": "reconcile",
            "Secrets": [
              {
                "Name": "DATABASE_URL",
                "ValueFrom": {
                  "Fn::Join": [
                    "",
                    [
                      "arn:",
                      {
                        "Ref": "AWS::Partition",
                      },
                      ":secretsmanager:us-east-1:123456789012:secret:scholars/prod/db/etl",
                    ],
                  ],
                },
              },
              {
                "Name": "OPENSEARCH_USER",
                "ValueFrom": {
                  "Fn::Join": [
                    "",
                    [
                      "arn:",
                      {
                        "Ref": "AWS::Partition",
                      },
                      ":secretsmanager:us-east-1:123456789012:secret:scholars/prod/opensearch/etl:username::",
                    ],
                  ],
                },
              },
              {
                "Name": "OPENSEARCH_PASS",
                "ValueFrom": {
                  "Fn::Join": [
                    "",
                    [
                      "arn:",
                      {
                        "Ref": "AWS::Partition",
                      },
                      ":secretsmanager:us-east-1:123456789012:secret:scholars/prod/opensearch/etl:password::",
                    ],
                  ],
                },
              },
            ],
          },
        ],
        "Cpu": "256",
        "ExecutionRoleArn": {
          "Fn::GetAtt": [
            "ReconcileTaskExecutionRole623CD9F3",
            "Arn",
          ],
        },
        "Family": "sps-reconcile-prod",
        "Memory": "512",
        "NetworkMode": "awsvpc",
        "RequiresCompatibilities": [
          "FARGATE",
        ],
        "TaskRoleArn": {
          "Fn::GetAtt": [
            "ReconcileTaskRoleAF128E4E",
            "Arn",
