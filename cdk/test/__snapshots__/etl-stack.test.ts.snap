        },
        "Description": "SPS ETL ECS task role (staging). ETL runtime identity; read-only access to the three ReciterAI-published IAM-based sources (DynamoDB table + spotlight/hierarchy artifact buckets).",
        "RoleName": "sps-etl-task-staging",
      },
      "Type": "AWS::IAM::Role",
    },
    "EtlTaskRoleDefaultPolicyB7A1E2B1": {
      "Properties": {
        "PolicyDocument": {
          "Statement": [
            {
              "Action": [
                "s3:PutObject",
                "s3:PutObjectLegalHold",
                "s3:PutObjectRetention",
                "s3:PutObjectTagging",
                "s3:PutObjectVersionTagging",
                "s3:Abort*",
              ],
              "Effect": "Allow",
              "Resource": {
                "Fn::Join": [
                  "",
                  [
                    {
                      "Fn::GetAtt": [
                        "CurationBackupBucketE5A802A9",
                        "Arn",
                      ],
                    },
                    "/*",
                  ],
                ],
              },
            },
            {
              "Action": "s3:PutObject",
              "Effect": "Allow",
              "Resource": "arn:aws:s3:::wcmc-reciterai-artifacts/ed/*",
            },
          ],
          "Version": "2012-10-17",
        },
        "PolicyName": "EtlTaskRoleDefaultPolicyB7A1E2B1",
        "Roles": [
          {
            "Ref": "EtlTaskRoleD514E3A1",
          },
        ],
      },
