          },
        ],
        "AlarmDescription": "SPS reconciler (staging) -- run failed (>=1 suppression row could not be reflected into the index). Next: check the Step Functions execution for the failing row; it self-heals once the underlying write succeeds.",
        "AlarmName": "sps-reconcile-status-staging",
        "ComparisonOperator": "GreaterThanThreshold",
        "DatapointsToAlarm": 2,
        "Dimensions": [
          {
            "Name": "StateMachineArn",
            "Value": {
              "Ref": "ReconcileStateMachine012717A8",
            },
          },
        ],
        "EvaluationPeriods": 2,
        "MetricName": "ExecutionsFailed",
        "Namespace": "AWS/States",
        "Period": 900,
        "Statistic": "Sum",
        "Threshold": 0,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "ReconcileTaskDefinitionDBA0B2ED": {
      "Properties": {
        "ContainerDefinitions": [
          {
            "Environment": [
              {
                "Name": "NODE_ENV",
                "Value": "production",
              },
              {
                "Name": "OPENSEARCH_NODE",
                "Value": {
                  "Fn::Join": [
                    "",
                    [
                      "https://",
                      {
                        "Fn::ImportValue": "Sps-Data-staging-OpenSearchDomainEndpoint",
                      },
                    ],
                  ],
                },
              },
            ],
            "Essential": true,
            "Image": {
              "Fn::Join": [
                "",
                [
                  {
                    "Fn::Select": [
                      4,
                      {
                        "Fn::Split": [
                          ":",
                          {
                            "Fn::ImportValue": "Sps-App-staging:ExportsOutputFnGetAttEtlEcrRepository058F5EECArn64168886",
                          },
                        ],
                      },
                    ],
                  },
                  ".dkr.ecr.",
                  {
                    "Fn::Select": [
                      3,
                      {
                        "Fn::Split": [
                          ":",
                          {
                            "Fn::ImportValue": "Sps-App-staging:ExportsOutputFnGetAttEtlEcrRepository058F5EECArn64168886",
                          },
                        ],
                      },
                    ],
                  },
                  ".",
                  {
                    "Ref": "AWS::URLSuffix",
                  },
                  "/",
                  {
                    "Fn::ImportValue": "Sps-App-staging:ExportsOutputRefEtlEcrRepository058F5EEC7A385183",
                  },
                  ":latest",
                ],
              ],
            },
            "LogConfiguration": {
              "LogDriver": "awslogs",
              "Options": {
                "awslogs-group": {
                  "Ref": "ReconcileLogGroup1B0AF242",
                },
                "awslogs-region": "us-east-1",
                "awslogs-stream-prefix": "reconcile",
              },
            },
            "Name": "reconcile",
            "Secrets": [
              {
                "Name": "DATABASE_URL",
                "ValueFrom": {
                  "Fn::Join": [
                    "",
                    [
                      "arn:",
                      {
                        "Ref": "AWS::Partition",
                      },
                      ":secretsmanager:us-east-1:123456789012:secret:scholars/staging/db/etl",
                    ],
                  ],
                },
              },
              {
                "Name": "OPENSEARCH_USER",
                "ValueFrom": {
                  "Fn::Join": [
                    "",
                    [
                      "arn:",
                      {
                        "Ref": "AWS::Partition",
                      },
                      ":secretsmanager:us-east-1:123456789012:secret:scholars/staging/opensearch/etl:username::",
                    ],
                  ],
                },
              },
              {
                "Name": "OPENSEARCH_PASS",
                "ValueFrom": {
                  "Fn::Join": [
                    "",
                    [
                      "arn:",
                      {
                        "Ref": "AWS::Partition",
                      },
                      ":secretsmanager:us-east-1:123456789012:secret:scholars/staging/opensearch/etl:password::",
                    ],
                  ],
                },
              },
            ],
          },
        ],
        "Cpu": "256",
        "ExecutionRoleArn": {
          "Fn::GetAtt": [
            "ReconcileTaskExecutionRole623CD9F3",
            "Arn",
          ],
        },
        "Family": "sps-reconcile-staging",
        "Memory": "512",
        "NetworkMode": "awsvpc",
        "RequiresCompatibilities": [
          "FARGATE",
