            "Ref": "EtlFailureTopic8361D0D0",
          },
        ],
        "AlarmDescription": "SPS ETL nightly (prod) -- execution failed. Next: check the Step Functions execution and the failing step's logs; data freshness lags until it reruns.",
        "AlarmName": "sps-etl-nightly-status-prod",
        "ComparisonOperator": "GreaterThanThreshold",
        "Dimensions": [
          {
            "Name": "StateMachineArn",
            "Value": {
              "Ref": "NightlyStateMachineFAE492F4",
            },
          },
        ],
        "EvaluationPeriods": 1,
        "MetricName": "ExecutionsFailed",
        "Namespace": "AWS/States",
        "Period": 3600,
        "Statistic": "Sum",
        "Threshold": 0,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "ReconcileCadenceAlarmDFE8B010": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "EtlFailureTopic8361D0D0",
          },
        ],
        "AlarmDescription": "SPS reconciler (prod) -- cadence missed (no execution started in 15 min = 3 missed 5 min fires). Next: confirm the rate(5 min) rule is enabled and the state-machine IAM is intact.",
        "AlarmName": "sps-reconcile-cadence-prod",
        "ComparisonOperator": "LessThanThreshold",
        "Dimensions": [
          {
            "Name": "StateMachineArn",
            "Value": {
              "Ref": "ReconcileStateMachine012717A8",
            },
          },
        ],
        "EvaluationPeriods": 1,
        "MetricName": "ExecutionsStarted",
        "Namespace": "AWS/States",
        "Period": 900,
        "Statistic": "Sum",
        "Threshold": 1,
        "TreatMissingData": "breaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
