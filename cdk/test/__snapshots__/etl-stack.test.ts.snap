    "NightlyStatusAlarm0D25751D": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "EtlFailureTopic8361D0D0",
          },
        ],
        "AlarmDescription": "SPS ETL nightly (staging) -- execution failed.",
        "AlarmName": "sps-etl-nightly-status-staging",
        "ComparisonOperator": "GreaterThanThreshold",
        "Dimensions": [
          {
            "Name": "StateMachineArn",
            "Value": {
              "Ref": "NightlyStateMachineFAE492F4",
            },
          },
        ],
        "EvaluationPeriods": 1,
        "MetricName": "ExecutionsFailed",
        "Namespace": "AWS/States",
        "Period": 3600,
        "Statistic": "Sum",
        "Threshold": 0,
        "TreatMissingData": "notBreaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "WeeklyCadenceAlarmDF1FE52B": {
      "Properties": {
        "AlarmActions": [
          {
            "Ref": "EtlFailureTopic8361D0D0",
          },
        ],
        "AlarmDescription": "SPS ETL weekly (staging) -- cadence missed (no execution started in period).",
        "AlarmName": "sps-etl-weekly-cadence-staging",
        "ComparisonOperator": "LessThanThreshold",
        "Dimensions": [
          {
            "Name": "StateMachineArn",
            "Value": {
              "Ref": "WeeklyStateMachineEC3FFB0B",
            },
          },
        ],
        "EvaluationPeriods": 1,
        "MetricName": "ExecutionsStarted",
        "Namespace": "AWS/States",
        "Period": 777600,
        "Statistic": "Sum",
        "Threshold": 1,
        "TreatMissingData": "breaching",
      },
      "Type": "AWS::CloudWatch::Alarm",
    },
    "WeeklyScheduleRule1CC9B0E6": {
      "Properties": {
        "Description": "SPS ETL weekly cadence (staging). D7.",
        "Name": "sps-etl-weekly-staging",
        "ScheduleExpression": "cron(0 8 ? * SUN *)",
        "State": "ENABLED",
        "Targets": [
