    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "typescript": "^5.7.3",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.5.1",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.5.15",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.10",
    "vitest": "^3.0.2",
    "@vitejs/plugin-react": "^4.3.4",
