// Scholars Profile System — local prototype schema.
// All FKs reference scholar.cwid (Q2': CWID-canonical).
// Soft-delete via scholar.deleted_at (Q4': 60-day retention window).
// cwid_aliases populated from ED replacement_cwid (Q2').
// slug_history records every former slug for 301 redirects (Q3').

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

/// One row per actively-affiliated WCM scholar. PK is CWID.
/// deleted_at != NULL marks a soft-deleted scholar; cleanup job hard-deletes after 60 days.
model Scholar {
  cwid                   String    @id @db.VarChar(32)
  preferredName          String    @map("preferred_name") @db.VarChar(255)
  fullName               String    @map("full_name") @db.VarChar(255)
  /// Pre-concatenated degree string from `weillCornellEduDegree` on the WOOFA
  /// faculty SOR (e.g. "MD", "MD, MPH"). Appended after preferredName as a
  /// postnominal credential at render time. Null for scholars with no SOR
  /// row (postdocs, doctoral students, non-faculty).
  postnominal            String?   @db.VarChar(64)
  primaryTitle           String?   @map("primary_title") @db.VarChar(255)
  primaryDepartment      String?   @map("primary_department") @db.VarChar(255)
  email                  String?   @db.VarChar(255)
  /// Effective email release audience derived from the multi-valued Web Directory
  /// attribute `weillCornellEduReleaseCode;mail` (most-permissive-wins, fail-closed).
  /// 'public' | 'institution' | 'none'. NULL until the first ED ETL backfill; treated
  /// as 'none' (fail-closed) by the display/export gate.
  emailVisibility        String?   @map("email_visibility") @db.VarChar(16)
  headshotUrl            String?   @map("headshot_url") @db.VarChar(512)
  overview               String?   @db.Text
  overviewUpdatedAt      DateTime? @map("overview_updated_at")
  slug                   String    @unique @db.VarChar(255)
  status                 String    @default("active") @db.VarChar(32) // 'active' | 'suppressed'
  // Phase 2: derived in ED ETL per design-spec-v1.7.1.md:352-356.
  // Drives the algorithmic-surface eligibility carve (lib/eligibility.ts).
  // Nullable so the additive migration applies cleanly to existing rows;
  // ED ETL backfills on next refresh.
  roleCategory           String?   @map("role_category") @db.VarChar(32)
  // #1034 — professorial rank derived from the ASMS-authoritative ED person-type
  // leaf (academic-faculty-assistant|associate|fullprofessor; probe #1036), one of
  // 'Assistant Professor' | 'Associate Professor' | 'Professor'. NULL for
  // instructor/lecturer/non-faculty. Persisted here by the ED ETL and read by the
  // Jenzabar GS import to tie Grad-School appointment titles to ASMS rank (Rule B).
  // Nullable so the additive migration applies cleanly; backfilled on next ED ETL run.
  professorialRank       String?   @map("professorial_rank") @db.VarChar(32)
  // Phase 3: org-unit FKs from ED LDAP. Nullable so additive migration applies cleanly;
  // backfilled on next ED ETL run. Joins on codes only per LOCKED constraint.
  deptCode               String?   @map("dept_code") @db.VarChar(64)
  divCode                String?   @map("div_code") @db.VarChar(64)
  /// Derived from LDAP personTypeCodes — true when the scholar carries a
  /// clinical or NYP-credentialed signal, indicating they likely have a
  /// public physician profile at weillcornell.org. Drives whether the
  /// "Clinical profile →" link appears in the profile sidebar (absence-as-
  /// default per design spec v1.7.1). Backfilled on next ED ETL run.
  hasClinicalProfile     Boolean   @default(false) @map("has_clinical_profile")
  /// Issue #165 — canonical per-scholar weillcornell.org clinical profile
  /// URL, sourced from the ED `labeledURI;pops` attribute on the ou=people
  /// entry (e.g. https://weillcornell.org/matthewfink). When present, the
  /// profile sidebar uses this URL directly; when null and
  /// hasClinicalProfile is true, the sidebar falls back to a surname-search
  /// URL on weillcornell.org/doctors-directory. Normalized to https:// at
  /// ETL time even when LDAP returns http://.
  clinicalProfileUrl     String?   @map("clinical_profile_url") @db.VarChar(512)
  /// Issue #5 — postdoc mentor (manager) CWID, populated only when
  /// roleCategory === 'postdoc'. Sourced from the `manager` attribute on
  /// the scholar's ou=employees,ou=sors entry (parsed by parseManagerCwid).
  /// Self-referential nullable FK with onDelete: SetNull so removing the
  /// mentor scholar doesn't cascade-delete the postdoc.
  postdoctoralMentorCwid String?   @map("postdoctoral_mentor_cwid") @db.VarChar(32)
  /// Issue #171 — ORCID iD (https://orcid.org/0000-0002-1825-0097 form,
  /// stored as the bare 19-char identifier "0000-0002-1825-0097"). Sourced
  /// from the WCM Identity DynamoDB table (etl/identity), keyed on `uid`
  /// (= cwid). Null when the scholar has not registered an ORCID. Used by
  /// `lib/seo/jsonld.ts` to append an `https://orcid.org/<id>` URL to the
  /// scholar's Person.sameAs for AI/LLM crawler entity resolution.
  orcid                  String?   @db.VarChar(19)
  /// Issue #742 v3.1 C3 — ReciterAI FACULTY# rollup metrics (DynamoDB), for the
  /// overview generator's faculty-scale framing. Nullable so the additive
  /// migration applies cleanly; backfilled by etl/dynamodb on next run.
  hIndex                 Int?      @map("h_index")
  firstAuthorCount       Int?      @map("first_author_count")
  lastAuthorCount        Int?      @map("last_author_count")
  scoredPubCount         Int?      @map("scored_pub_count")
  /// Headshot presence, backfilled weekly by etl/headshot — which probes the WCM
  /// directory (`identityImageEndpoint`, `returnGenericOn404=false`) that 404s when
  /// no photo exists. The dormant `headshot_url` column above is NOT read at render
  /// (the app always derives the directory URL from the cwid); this is the persisted
  /// presence signal the Data Quality dashboard (#data-quality-dashboard) sorts and
  /// filters on. NULL = never probed; backfilled on the next etl:headshot run.
  hasHeadshot            Boolean?  @map("has_headshot")
  headshotCheckedAt      DateTime? @map("headshot_checked_at")
  deletedAt              DateTime? @map("deleted_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  appointments         Appointment[]
  educations           Education[]
  grants               Grant[]
  authorships          PublicationAuthor[]
  topicAssignments     TopicAssignment[]
  publicationScores    PublicationScore[]
  publicationTopics    PublicationTopic[]
  cwidAliasesAsCurrent CwidAlias[]          @relation("AliasCurrent")
  slugHistoryAsCurrent SlugHistory[]        @relation("SlugHistoryCurrent")
  coiActivities        CoiActivity[]
  coiGapCandidates     CoiGapCandidate[]
  nihProfiles          PersonNihProfile[]
  overviewGenerations  OverviewGeneration[]
  overviewProvenance   OverviewProvenance?
  scholarTools         ScholarTool[]
  scholarFamilies      ScholarFamily[]
  department           Department?          @relation(fields: [deptCode], references: [code], onDelete: SetNull)
  division             Division?            @relation(fields: [divCode], references: [code], onDelete: SetNull)
  postdoctoralMentor   Scholar?             @relation("PostdocMentor", fields: [postdoctoralMentorCwid], references: [cwid], onDelete: SetNull)
  postdocMentees       Scholar[]            @relation("PostdocMentor")

  @@index([deletedAt])
  @@index([status])
  @@index([roleCategory])
  @@index([deptCode])
  @@index([divCode])
  @@index([postdoctoralMentorCwid])
  @@map("scholar")
}

/// Per-scholar appointments from Enterprise Directory.
/// Display logic per spec line 43: primary first, active only by default,
/// interim excluded if any non-interim exists.
model Appointment {
  id              String    @id @default(uuid()) @db.VarChar(64)
  cwid            String    @db.VarChar(32)
  scholar         Scholar   @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  title           String    @db.VarChar(255)
  organization    String    @db.VarChar(255)
  startDate       DateTime? @map("start_date") @db.Date
  endDate         DateTime? @map("end_date") @db.Date // NULL = current
  isPrimary       Boolean   @default(false) @map("is_primary")
  isInterim       Boolean   @default(false) @map("is_interim")
  externalId      String    @unique @map("external_id") @db.VarChar(128) // ED appointment ID; #352 reconcile key
  source          String    @default("ED") @db.VarChar(32)
  lastRefreshedAt DateTime  @default(now()) @map("last_refreshed_at")

  @@index([cwid])
  @@index([cwid, isPrimary, endDate])
  @@map("appointment")
}

/// Education and training entries from ASMS.
model Education {
  id              String   @id @default(uuid()) @db.VarChar(64)
  cwid            String   @db.VarChar(32)
  scholar         Scholar  @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  degree          String   @db.VarChar(255)
  institution     String   @db.VarChar(255)
  year            Int?
  field           String?  @db.VarChar(255)
  externalId      String   @unique @map("external_id") @db.VarChar(128)
  source          String   @default("ASMS") @db.VarChar(32)
  lastRefreshedAt DateTime @default(now()) @map("last_refreshed_at")

  @@index([cwid])
  @@map("education")
}

/// PhD primary-mentor (thesis advisor) relationships from Jenzabar's Graduate
/// School view `WCN_IDM_GS_ADVISOR_ADVISEE_View` filtered to ADVISOR_TYPE='MAJSP'.
/// Complements `reciterdb.reporting_students_mentors` (MD AOC/ECR mentors) —
/// the two sources are unioned by lib/api/mentoring.ts but cover disjoint
/// populations (PhD students vs MD students).
///
/// Truncate-and-rebuild on every ETL run; no FK to Scholar (mentees may be
/// alumni not present in the local Scholar table, identical to how AOC mentees
/// are handled today).
model PhdMentorRelationship {
  id                Int      @id @default(autoincrement())
  mentorCwid        String   @map("mentor_cwid") @db.VarChar(32)
  menteeCwid        String   @map("mentee_cwid") @db.VarChar(32)
  mentorFirstName   String?  @map("mentor_first_name") @db.VarChar(64)
  mentorLastName    String?  @map("mentor_last_name") @db.VarChar(64)
  mentorEmail       String?  @map("mentor_email") @db.VarChar(128)
  mentorDepartment  String?  @map("mentor_department") @db.VarChar(128)
  mentorInstitution String?  @map("mentor_institution") @db.VarChar(255)
  menteeFirstName   String?  @map("mentee_first_name") @db.VarChar(64)
  menteeLastName    String?  @map("mentee_last_name") @db.VarChar(64)
  conferralYear     Int?     @map("conferral_year")
  majorDesc         String?  @map("major_desc") @db.VarChar(128)
  advisorStatus     String   @map("advisor_status") @db.Char(1)
  /// "PhD" or "MD-PhD" — resolved at ETL time by joining mentee CWID against
  /// Scholar.roleCategory. Pre-LDAP-era alumni not in Scholar default to "PhD".
  programType       String   @map("program_type") @db.VarChar(16)
  externalId        String   @unique @map("external_id") @db.VarChar(64)
  source            String   @default("JENZABAR-MAJSP") @db.VarChar(32)
  lastRefreshedAt   DateTime @default(now()) @map("last_refreshed_at")

  @@index([mentorCwid])
  @@index([menteeCwid])
  @@map("phd_mentor_relationship")
}

/// Issue #183 — Postdoc primary-mentor relationships sourced from WCM ED
/// `weillCornellEduSORRoleRecord` entries under `ou=employees,ou=sors`
/// filtered to `weillCornellEduRoleCode=06` (Post Doc. Assoc-Sal) or
/// `title=Postdoctoral*`. Includes expired role records so alumni postdocs
/// surface alongside currently-active ones on the mentor's profile.
///
/// Mentor is the postdoc's reporting manager (LDAP `manager` DN → CWID via
/// `parseManagerCwid`). The role record carries appointment start/end dates,
/// so `getMenteesForMentor` can render postdoc chips with a real date range
/// ("2013–2019" or "since 2023") rather than the "Class of N" string used
/// for student mentees.
///
/// Truncate-and-rebuild on every ETL run; no FK to Scholar (mentees may be
/// alumni not present in the local Scholar table, identical to how AOC and
/// Jenzabar PhD mentees are handled).
model PostdocMentorRelationship {
  id              Int       @id @default(autoincrement())
  mentorCwid      String    @map("mentor_cwid") @db.VarChar(32)
  menteeCwid      String    @map("mentee_cwid") @db.VarChar(32)
  menteeFirstName String?   @map("mentee_first_name") @db.VarChar(64)
  menteeLastName  String?   @map("mentee_last_name") @db.VarChar(64)
  /// `weillCornellEduStartDate` on the role record (LDAP generalizedTime
  /// parsed to Date). Null when ED omits the attribute.
  startDate       DateTime? @map("start_date") @db.Date
  /// `weillCornellEduEndDate` on the role record. Null when ED returns the
  /// 2099 sentinel (= open-ended / currently active), which the LDAP parser
  /// already maps to null.
  endDate         DateTime? @map("end_date") @db.Date
  /// Raw `title` attribute from the role record ("Postdoctoral Associate",
  /// "Postdoctoral Fellow", etc.). Kept for debugging / future chip enrichment
  /// — not used by the current UI surface.
  title           String?   @db.VarChar(128)
  /// `weillCornellEduStatus` at last ETL run — "employee:active" or
  /// "employee:expired". The read layer uses this to decide whether the
  /// chip's date range renders as "since YYYY" (active) or "YYYY–YYYY"
  /// (expired) without re-reading endDate sentinels.
  status          String    @db.VarChar(32)
  /// Always "POSTDOC" — defaulted so `bucketProgramType` /
  /// `formatProgramLabel` can branch on this column with the same shape as
  /// the AOC and Jenzabar sources.
  programType     String    @default("POSTDOC") @map("program_type") @db.VarChar(16)
  /// `ED-POSTDOC-<weillCornellEduSORID>`. Stable across ETL reruns; SORID
  /// is the role record's own ID, not the parent employee record's.
  externalId      String    @unique @map("external_id") @db.VarChar(64)
  source          String    @default("ED-EMPLOYEE-SOR") @db.VarChar(32)
  lastRefreshedAt DateTime  @default(now()) @map("last_refreshed_at")

  @@index([mentorCwid])
  @@index([menteeCwid])
  @@map("postdoc_mentor_relationship")
}

/// Issue #443 — Pre-computed per-(mentor, mentee) co-publication counts, bridged
/// from WCM ReciterDB via S3 because the SPS VPC can't reach ReciterDB to run the
/// live co-pub query at request time (`getMenteesForMentor`). The export step
/// (`etl:mentoring:export-copubs`, run WCM-side) computes the count + a 3-pub
/// preview from `analysis_summary_author`/`_article` and writes NDJSON to S3; the
/// import step (`etl:mentoring:import-copubs`, run in-VPC) upserts this table.
/// The read layer reads this instead of the live query when
/// `MENTORING_COPUB_BRIDGE=on` (import-then-flip).
///
/// No FK to Scholar — mentees are frequently unlinked alumni with no local
/// Scholar row (~75% of co-pub-bearing mentees, GH #181), identical to how the
/// mentor-relationship tables are handled. Composite PK (mentor, mentee); the
/// read query filters mentor= + mentee IN(), served by the PK's leading column.
model MenteeCopublication {
  mentorCwid  String   @map("mentor_cwid") @db.VarChar(32)
  menteeCwid  String   @map("mentee_cwid") @db.VarChar(32)
  /// Number of publications co-authored by the mentor and this mentee.
  count       Int      @map("copub_count")
  /// Up to 3 most-recent shared publications for the inline chip expansion
  /// (#185), shape `[{ pmid, title, journal, year }]` (matches `CoPublication`).
  preview     Json
  refreshedAt DateTime @default(now()) @map("refreshed_at")

  @@id([mentorCwid, menteeCwid])
  @@map("mentee_copublication")
}

/// Issue #928 — AOC / med-student mentee bridge. Mirrors ReciterDB
/// `reporting_students_mentors` rows into Aurora so the in-VPC app can render
/// AOC mentee chips without the request-time ReciterDB query that
/// `getMenteesForMentor` / `getMentorMenteePair` otherwise run (the SPS VPC
/// can't reach ReciterDB, so that query silently drops AOC chips in-VPC).
/// Exported WCM-side (`etl:mentoring:export-copubs` → `mentoring/aoc-mentees.ndjson`)
/// and loaded in-VPC by `etl:mentoring:import-aoc`; read when
/// `MENTORING_COPUB_BRIDGE=on` (import-then-flip).
///
/// Raw mirror: a (mentor, mentee) pair can appear under several programs
/// (e.g. AOC + AOC-2025), so rows are NOT collapsed here — the read path
/// collapses per-CWID exactly as it does for the live query. No natural
/// per-pair key, so a surrogate `id` PK plus a full truncate-and-load import.
/// No FK to Scholar — AOC students are frequently unlinked alumni (GH #181).
model AocMentee {
  id             Int      @id @default(autoincrement())
  mentorCwid     String   @map("mentor_cwid") @db.VarChar(32)
  menteeCwid     String   @map("mentee_cwid") @db.VarChar(32)
  firstName      String?  @map("first_name") @db.VarChar(255)
  lastName       String?  @map("last_name") @db.VarChar(255)
  graduationYear Int?     @map("graduation_year")
  programType    String?  @map("program_type") @db.VarChar(64)
  refreshedAt    DateTime @default(now()) @map("refreshed_at")

  @@index([mentorCwid], map: "aoc_mentee_mentor_cwid_idx")
  @@index([mentorCwid, menteeCwid], map: "aoc_mentee_mentor_mentee_idx")
  @@map("aoc_mentee")
}

/// Issue #928 — full mentor↔mentee co-publication list bridge. One row per
/// (mentor, mentee, pmid); `pub` holds the raw `CoPublicationFull` JSON
/// (title/journal/year/doi/pmcid/citation count/abstract + the full author
/// list). Stored PRE-suppression — the read path re-applies local publication
/// suppression (`loadPublicationSuppressions`/`resolveDarkPmids`/`isAuthorHidden`)
/// since suppression is env-specific and changes independently of this bridge.
/// Exported WCM-side (`etl:mentoring:export-copubs` → `mentoring/copub-list.ndjson`)
/// and loaded in-VPC by `etl:mentoring:import-copub-list`; read by
/// `getCoPublications` when `MENTORING_COPUB_BRIDGE=on`. `pubYear` is
/// denormalized for DB-side ordering (year desc, pmid desc — matches the live
/// query). No FK to Scholar/Publication (alumni mentees, GH #181).
model MenteeCopublicationPub {
  mentorCwid  String   @map("mentor_cwid") @db.VarChar(32)
  menteeCwid  String   @map("mentee_cwid") @db.VarChar(32)
  pmid        Int
  pubYear     Int?     @map("pub_year")
  pub         Json
  refreshedAt DateTime @default(now()) @map("refreshed_at")

  @@id([mentorCwid, menteeCwid, pmid])
  @@index([mentorCwid, menteeCwid], map: "mentee_copublication_pub_pair_idx")
  @@map("mentee_copublication_pub")
}

/// Issue #928 — publication-modal cited-by BRIDGE. The modal's "Cited by" list +
/// total are a LIVE WCM ReciterDB query (`analysis_nih_cites` joined to
/// `analysis_summary_article`, `lib/api/publication-detail.ts`) the in-VPC app
/// can't reach, so they degrade to "temporarily unavailable" in staging/prod
/// (#443). This pre-computes ONE row per CITED pmid: the full NIH-cite `total`
/// plus the same ≤500-most-recent citing-pub list the modal renders, stored as
/// JSON — NOT the full `(cited, citing)` edge list (tens of millions of rows).
/// Exported WCM-side (`etl:mentoring:export-citing` → `citations/citing.ndjson`)
/// and loaded in-VPC by `etl:mentoring:import-citing`; read by
/// `getPublicationDetail`/`getCitingPublicationsForCsv` when
/// `PUBLICATION_CITING_BRIDGE=on`. An empty table degrades honestly back to
/// "temporarily unavailable" (the read does one cheap global existence probe),
/// so a flag flipped before the import never shows fake zeros. No FK to
/// Publication: `citingPubs` are citer pmids that need not be WCM publications.
model PublicationCiting {
  /// The CITED pmid (matches `Publication.pmid` numerically; int form of the
  /// reciterdb `analysis_nih_cites.cited_pmid` column).
  pmid        Int      @id
  /// Full count of rows in `analysis_nih_cites` for this `cited_pmid` (may exceed
  /// the ≤500 stored in `citingPubs` — drives the "N total" subhead).
  total       Int
  /// Up to 500 most-recent citing pubs `[{ pmid, title, journal, year }]`,
  /// publicationDate desc — the exact shape `PublicationDetailCitingPub` renders.
  citingPubs  Json     @map("citing_pubs")
  refreshedAt DateTime @default(now()) @map("refreshed_at")

  @@map("publication_citing")
}

/// Issue #195 — Per-CWID PhD program record sourced from ED's
/// `weillCornellEduSORRoleRecord` class under `ou=students,ou=sors` filtered
/// to `weillCornellEduDegreeCode=PHD`. Includes expired rows so alumni
/// mentees (e.g. graduated 2022) still resolve to their program of study.
///
/// One row per CWID. When ED returns multiple PHD role records for a single
/// person (re-enrollment, dual programs), the ETL collapses to the most
/// recently ended record so the chip reflects their terminal program.
///
/// Populated by `npm run etl:ed:student-programs`. Consumed by the mentoring
/// chip subtitle (lib/api/mentoring.ts) and a planned student-profile
/// education enrichment.
model StudentPhdProgram {
  cwid             String    @id @db.VarChar(32)
  /// Human-readable program name from `weillCornellEduProgram`
  /// (e.g. "Immunology & Microbial Pathogenesis").
  program          String    @db.VarChar(255)
  /// Short program code from `weillCornellEduProgramCode` (e.g. "IMP").
  programCode      String?   @map("program_code") @db.VarChar(32)
  /// `weillCornellEduExpectedGradYear`. Persisted separately from the
  /// Jenzabar conferralYear so the chip can show "Class of YYYY" for
  /// current students who haven't graduated yet.
  expectedGradYear Int?      @map("expected_grad_year")
  /// `weillCornellEduStatus` — e.g. "student:active", "student:expired".
  status           String?   @db.VarChar(64)
  /// `weillCornellEduExitReason` — e.g. "Graduated", "Withdrawn". Only
  /// populated when status is expired.
  exitReason       String?   @map("exit_reason") @db.VarChar(128)
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  lastRefreshedAt  DateTime  @default(now()) @map("last_refreshed_at")

  @@map("student_phd_program")
}

/// Issue #90 — mapping from a WCM scholar to their NIH RePORTER PI
/// profile_id, for the outbound "View NIH portfolio on RePORTER" link
/// in the Funding section header.
///
/// A small fraction of researchers carry more than one profile_id (legacy
/// duplicate eRA Commons accounts), so the natural key is composite —
/// (cwid, nihProfileId). Exactly one row per scholar carries
/// `isPreferred = true` and is what the UI link uses; non-preferred rows
/// surface to a curator review queue for upstream cleanup.
///
/// Populated by `npm run etl:nih-profile`, which reads
/// `principal_investigators[]` from NIH RePORTER's /projects/search and
/// resolves each profile_id back to a WCM cwid via grant-join (primary)
/// + fuzzy name match against scholars with NIH grants (fallback).
model PersonNihProfile {
  cwid             String   @db.VarChar(32)
  scholar          Scholar  @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  /// NIH eRA Commons profile_id — stable across institutions, so it
  /// captures pre-WCM funding history too. UI tooltip warns the user
  /// that the linked view is NIH-funding-only.
  nihProfileId     Int      @map("nih_profile_id")
  /// Exactly one row per cwid carries this. When a scholar has a single
  /// profile_id this is trivially true; when multiple, the resolver
  /// picks the one with the most recent project activity.
  isPreferred      Boolean  @default(false) @map("is_preferred")
  firstSeen        DateTime @default(now()) @map("first_seen")
  lastVerified     DateTime @default(now()) @map("last_verified")
  source           String   @default("RePORTER") @db.VarChar(32)
  /// 'grant_join' (project core_project_num matched a WCM Grant row) or
  /// 'name_match' (fallback fuzzy match against scholars-with-NIH-grants
  /// pool). Tracked so the curator review queue can surface low-confidence
  /// matches without re-running the resolver.
  resolutionSource String   @map("resolution_source") @db.VarChar(32)

  @@id([cwid, nihProfileId])
  @@index([cwid, isPreferred])
  @@map("person_nih_profile")
}

/// Grants from InfoEd, filtered per spec line 125 (Confidential != 'Y',
/// program_type != 'Contract without funding', valid roles, valid dates).
model Grant {
  id              String   @id @default(uuid()) @db.VarChar(64)
  cwid            String   @db.VarChar(32)
  scholar         Scholar  @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  title           String   @db.Text
  role            String   @db.VarChar(64) // PI | PI-Subaward | Co-PI | Co-I | Key Personnel
  /// Pre-rendered display string (e.g. "NCI" or "NCI via Duke University").
  /// Retained for transition; UI is migrating to the structured fields below
  /// (issue #78 Wave C). Will be removed once all surfaces migrate.
  funder          String   @db.VarChar(255)
  startDate       DateTime @map("start_date") @db.Date
  endDate         DateTime @map("end_date") @db.Date
  externalId      String   @unique @map("external_id") @db.VarChar(128)
  /// Sponsor-issued award number (e.g. NIH "R01 AG067497"). Nullable —
  /// many grants don't have one (industry contracts, internal awards).
  /// Populated from InfoEd CONSOLIDATED_QUERY's Award_Number column.
  awardNumber     String?  @map("award_number") @db.VarChar(128)
  source          String   @default("InfoEd") @db.VarChar(32)
  lastRefreshedAt DateTime @default(now()) @map("last_refreshed_at")

  /// Issue #78 — InfoEd `program_type`. Possible values: Grant, Contract
  /// with funding, Fellowship, Career, Training, BioPharma Alliance
  /// Agreement, Equipment. Contract without funding is excluded at the
  /// ETL filter stage (issue #78 decision Q3).
  programType String @default("Grant") @map("program_type") @db.VarChar(64)

  /// Issue #78 F6 — original source of funds. Canonical short name
  /// (resolved via lib/sponsor-lookup) when matched; null when the raw
  /// sponsor isn't in the canonical lookup. Raw form is always populated
  /// in `primeSponsorRaw`.
  primeSponsor    String? @map("prime_sponsor") @db.VarChar(64)
  primeSponsorRaw String? @map("prime_sponsor_raw") @db.VarChar(255)

  /// Issue #78 F6 — institution that issued the subaward to WCM. Equal
  /// to prime when WCM holds the prime directly. Canonical short name
  /// when matched; raw form in `directSponsorRaw`.
  directSponsor    String? @map("direct_sponsor") @db.VarChar(64)
  directSponsorRaw String? @map("direct_sponsor_raw") @db.VarChar(255)

  /// Issue #78 F2 — derived from award-number prefix. NIH-funded only;
  /// null otherwise. e.g. "R01", "K23", "U01".
  mechanism String? @db.VarChar(16)

  /// Issue #78 F2 — derived from award-number IC infix. NIH-funded only;
  /// null otherwise. e.g. "NCI", "NHLBI".
  nihIc String? @map("nih_ic") @db.VarChar(8)

  /// Issue #78 F6 — true when the direct sponsor differs from the prime.
  isSubaward Boolean @default(false) @map("is_subaward")

  /// Issue #85/#86 — RePORTER application ID for this grant. Most recent
  /// appl_id matching the core_project_num parsed from `awardNumber`.
  /// Null for non-NIH grants and for NIH grants RePORTER doesn't have yet.
  /// Use for outbound RePORTER deep-links (reporter.nih.gov/project-details/<applId>).
  applId Int? @map("appl_id")

  /// Issue #85/#86 — RePORTER project abstract. Populated for NIH grants
  /// where the core_project_num parsed from `awardNumber` matches a
  /// reciterdb.grant_reporter_project row. Surfaced inline in the Funding
  /// section's expanded grant view; also indexed in OpenSearch for
  /// `/search?type=funding` topic matches.
  abstract          String?   @db.Text
  abstractFetchedAt DateTime? @map("abstract_fetched_at")
  /// Issue #92 — origin of the current `abstract`. One of 'reporter',
  /// 'nsf', 'pcori', 'cdmrp', 'gates'. Null when no abstract has been
  /// fetched. Surfaces as small "Source: NSF" attribution in the
  /// expanded grant view.
  abstractSource    String?   @map("abstract_source") @db.VarChar(32)

  /// Issue #291 — NIH-curated project keywords from RePORTER, parsed from the
  /// project's `pref_terms` (preferred) or `terms`. A `string[]`; null for
  /// non-NIH grants and NIH grants RePORTER returns no terms for. Indexed in
  /// OpenSearch (`keywords` facet + `keywordsText`) as a topical search
  /// signal, parallel to MeSH descriptors on publications.
  keywords          Json?     @map("keywords")
  /// Issue #291 — provenance of `keywords`. 'reporter' for now; extensible to
  /// 'nlm-tagger' / 'extracted' if NLP-derived keywords are added later.
  keywordsSource    String?   @map("keywords_source") @db.VarChar(32)
  /// Issue #291 — when `keywords` was last written. Mirrors `abstractFetchedAt`.
  keywordsFetchedAt DateTime? @map("keywords_fetched_at")

  /// Issue #295 — `keywords` resolved to NLM MeSH descriptor UIs (Dnnnnnnn).
  /// A `string[]`; null when `keywords` is null/empty or no term resolves.
  /// Indexed in OpenSearch (`meshDescriptorUi`) so a resolved-MeSH query
  /// matches NIH grants by descriptor, mirroring the publications index.
  meshDescriptorUis      Json?     @map("mesh_descriptor_uis")
  /// Issue #295 — resolved-term count / deduped-post-normalization input
  /// count (stopwords excluded from both). For resolution-rate monitoring;
  /// null when the grant has no non-stopword keyword.
  meshResolutionCoverage Float?    @map("mesh_resolution_coverage")
  /// Issue #295 — when the MeSH resolver pass last wrote this grant.
  /// Mirrors `keywordsFetchedAt`.
  meshResolvedAt         DateTime? @map("mesh_resolved_at")

  publications GrantPublication[]

  @@index([cwid])
  @@index([cwid, endDate]) // active-first ordering
  @@index([primeSponsor])
  @@index([programType])
  @@index([applId])
  @@map("grant")
}

/// Publications are global (shared across authors). Keyed by PMID.
/// citationCount refreshes from reciter-db (spec line 78: weekly minimum).
/// authorsString holds the full pre-rendered author list including externals,
/// in canonical order (from analysis_summary_article.authors). PublicationAuthor
/// rows are inserted only for WCM scholars; profile rendering overlays
/// hyperlinks onto the matching substrings in authorsString.
model Publication {
  pmid                String    @id @db.VarChar(32)
  title               String    @db.Text
  authorsString       String?   @map("authors_string") @db.VarChar(2000)
  /// Full author list (no truncation) sourced from
  /// `reciterdb.analysis_summary_author_all.authors` and reformatted
  /// from pipe-separated `Lastname, Initials` to comma-separated
  /// `Lastname Initials`. Used by the Word bibliography export (#89)
  /// where citations need every author present, including middle
  /// authors that the truncated `authorsString` drops.
  fullAuthorsString   String?   @map("full_authors_string") @db.Text
  journal             String?   @db.VarChar(512)
  year                Int?
  publicationType     String?   @map("publication_type") @db.VarChar(64) // publicationTypeCanonical
  citationCount       Int       @default(0) @map("citation_count")
  dateAddedToEntrez   DateTime? @map("date_added_to_entrez") @db.Date
  doi                 String?   @db.VarChar(255)
  /// PubMed Central identifier including the `PMC` prefix (e.g. "PMC11098699").
  /// Sourced from `analysis_summary_article.pmcid`. Surfaced on publication
  /// cards alongside DOI/PMID; signals NIH public-access compliance.
  pmcid               String?   @db.VarChar(32)
  /// Issue #89 — Vancouver-style citation fields. Sourced from
  /// `analysis_summary_article.{volume,issue,pages}`. Stored as varchar
  /// since they're free-form ("12", "Suppl 1", "S5", "538-40").
  volume              String?   @db.VarChar(64)
  issue               String?   @db.VarChar(128)
  pages               String?   @db.VarChar(128)
  /// NLM/Index Medicus journal abbreviation (e.g., "Proc Natl Acad Sci U S A").
  /// Sourced from `reciterdb.person_article.journalTitleISOabbreviation` —
  /// despite the field name, the values are the standard NLM abbreviation
  /// form (no periods between abbreviated words). Used by the Word
  /// bibliography export; falls back to `journal` (full title) when null.
  journalAbbrev       String?   @map("journal_abbrev") @db.VarChar(200)
  pubmedUrl           String?   @map("pubmed_url") @db.VarChar(512)
  /// MeSH keywords from accepted publications, used by the profile Topics
  /// section (issue #73). Format: `[{ ui: "D015316", label: "Genetic Therapy" }, ...]`.
  /// `ui` is null for the rare label that doesn't resolve to a `mesh.DescriptorUI`
  /// in reciterdb. Source: `reciterdb.person_article_keyword` joined to
  /// `reciterdb.mesh`. Keyword sets are per-PMID, not per-(person, pmid) —
  /// verified during ETL design.
  meshTerms           Json?     @map("mesh_terms")
  /// Plain-text article abstract from ReciterDB.reporting_abstracts.abstractVarchar
  /// (capped at 15000 chars at the source). Used by the search-index ETL to
  /// emit `publicationAbstracts` on the people document for thematic-query
  /// recall (issue #21). Nullable — many older publications and many
  /// non-research article types have no abstract.
  abstract            String?   @db.Text
  /// Issue #329 — one-line plain-language synopsis from DynamoDB
  /// TOPIC#.synopsis. Lives on `Publication` because the value is per-pmid;
  /// the upstream denormalizes it across the N TOPIC# rows for one pmid
  /// (same anti-pattern that #325 avoided for `top_topic_id`). The DDB ETL
  /// reads any one row's value and writes once here. Surfaced in the
  /// publication detail modal (#288 PR-B) as the "Plain-language synopsis"
  /// section. Distinct from `abstract` (raw PubMed text); synopsis is a
  /// GPT-generated reader-facing summary.
  synopsis            String?   @db.Text
  /// ReCiterAI per-publication impact score (0-100, GPT-rubric). Sourced from
  /// DynamoDB `IMPACT#pmid_<pmid>` records by the DynamoDB ETL (issue #316).
  /// Global per-pmid — no scholar or topic dimension. `PublicationTopic.impactScore`
  /// is a denormalized mirror kept for the transition; readers should migrate
  /// to this field, then the mirror can retire in a follow-up.
  impactScore         Decimal?  @map("impact_score") @db.Decimal(8, 4)
  /// GPT-generated natural-language justification for `impactScore` citing
  /// novelty / methodology / influence / translational relevance. Surfaced in
  /// hover tooltips by PR-C of issue #316.
  impactJustification String?   @map("impact_justification") @db.Text
  /// Model identifier used to generate `impactScore` / `impactJustification`
  /// (e.g. "gpt-5.1"). Stored for ETL traceability and to flag regenerations
  /// when the upstream model bumps.
  impactScoreModel    String?   @map("impact_score_model") @db.VarChar(64)
  impactRefreshedAt   DateTime? @map("impact_refreshed_at")
  /// Issue #325 — per-paper "top topic" (argmax of the topic-score vector
  /// among topics above the 0.3 floor; deterministic tiebreak upstream).
  /// Sourced from DynamoDB TOPIC# `top_topic_id`. Per-paper, not
  /// per-(pmid, cwid, topic) — denormalized across TOPIC# rows by the
  /// producer; the ETL reads any one row's value and writes once here.
  /// NULL when the upstream hasn't backfilled this pmid yet (rare post
  /// ReciterAI #68 rollout). Consumed by #327's inline "Top topic: X"
  /// label on /topics/<slug> citations.
  topTopicId          String?   @map("top_topic_id") @db.VarChar(128)
  topTopic            Topic?    @relation("PublicationTopTopic", fields: [topTopicId], references: [id], onDelete: SetNull)
  source              String    @default("ReCiter") @db.VarChar(32)
  lastRefreshedAt     DateTime  @default(now()) @map("last_refreshed_at")

  authors           PublicationAuthor[]
  publicationScores PublicationScore[]
  publicationTopics PublicationTopic[]
  grants            GrantPublication[]
  conflictStatement PublicationConflictStatement?

  @@index([year])
  @@index([dateAddedToEntrez])
  @@index([topTopicId])
  @@map("publication")
}

/// Per-PMID PubMed competing-interest ("Competing interests:") statement text,
/// backfilled from `reciterdb.reporting_conflicts.conflictsVarchar` by
/// `etl/reciter/backfill-coi-statements.ts`. One row per publication that
/// carries a non-empty COI statement (sparse — a separate table avoids widening
/// the hot `publication` row and keeps this sensitive text isolated).
///
/// The statement is PAPER-LEVEL (shared by all co-authors of the PMID); the
/// per-author attribution that decides whether a named relationship belongs to a
/// given scholar is computed at request time by `lib/coi-gap`, never persisted
/// as a verdict (see docs/coi-pubmed-unmatched-feasibility.md). Consumed only by
/// the self-only /edit "relationships in your publications" surface.
model PublicationConflictStatement {
  pmid            String      @id @db.VarChar(32)
  publication     Publication @relation(fields: [pmid], references: [pmid], onDelete: Cascade)
  statementText   String      @map("statement_text") @db.Text
  source          String      @default("PubMed") @db.VarChar(32)
  lastRefreshedAt DateTime    @default(now()) @map("last_refreshed_at")

  @@map("publication_conflict_statement")
}

/// Issue #85/#86 — materialized join between Grant and Publication.
/// Bridges reciterdb.grant_provenance (where pub-grant linkages live, keyed
/// by (personIdentifier, pmid, core_project_num)) into Postgres so the
/// Funding API can serve pub counts and pub lists per grant without a
/// runtime cross-DB query. Refreshed nightly by etl/reporter/index.ts.
///
/// sourceReporter / sourceReciterdb mirror the provenance flags:
///   - both true     → high confidence (RePORTER + PubMed agree)
///   - reporter only → high (RePORTER curated by grantee)
///   - reciter only  → unconfirmed by RePORTER; UI shows "Lower confidence"
///                     badge if reciterdbFirstSeen is older than 12 months
///
/// The unique key is (grantId, pmid). A pub may appear under many grants;
/// a grant may have many pubs.
model GrantPublication {
  id                 String      @id @default(uuid()) @db.VarChar(64)
  grantId            String      @map("grant_id") @db.VarChar(64)
  grant              Grant       @relation(fields: [grantId], references: [id], onDelete: Cascade)
  pmid               String      @db.VarChar(32)
  publication        Publication @relation(fields: [pmid], references: [pmid], onDelete: Cascade)
  sourceReporter     Boolean     @default(false) @map("source_reporter")
  sourceReciterdb    Boolean     @default(false) @map("source_reciterdb")
  reporterFirstSeen  DateTime?   @map("reporter_first_seen")
  reciterdbFirstSeen DateTime?   @map("reciterdb_first_seen")
  lastRefreshedAt    DateTime    @default(now()) @map("last_refreshed_at")

  @@unique([grantId, pmid])
  @@index([grantId])
  @@index([pmid])
  @@map("grant_publication")
}

/// Join between scholars and publications. cwid is NULLABLE for non-WCM authors
/// (Q2' refinement; spec line 200 — render as plain text without profile link).
model PublicationAuthor {
  id              String      @id @default(uuid()) @db.VarChar(64)
  pmid            String      @db.VarChar(32)
  publication     Publication @relation(fields: [pmid], references: [pmid], onDelete: Cascade)
  cwid            String?     @db.VarChar(32) // NULL for non-WCM authors
  scholar         Scholar?    @relation(fields: [cwid], references: [cwid], onDelete: SetNull)
  externalName    String?     @map("external_name") @db.VarChar(255) // for non-WCM authors
  position        Int // 1-based author position
  totalAuthors    Int         @map("total_authors")
  isFirst         Boolean     @default(false) @map("is_first")
  isLast          Boolean     @default(false) @map("is_last")
  isPenultimate   Boolean     @default(false) @map("is_penultimate")
  isConfirmed     Boolean     @default(true) @map("is_confirmed") // ReCiter authorship-confirmation (spec line 118)
  lastRefreshedAt DateTime    @default(now()) @map("last_refreshed_at")

  @@index([cwid])
  @@index([pmid])
  @@index([cwid, isConfirmed])
  @@map("publication_author")
}

/// ReCiterAI topic assignments per scholar (Q6 minimal projection).
/// One of two fields that flow DynamoDB to MySQL via the projection Lambda.
model TopicAssignment {
  id              String   @id @default(uuid()) @db.VarChar(64)
  cwid            String   @db.VarChar(32)
  scholar         Scholar  @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  topic           String   @db.VarChar(255)
  score           Float
  source          String   @default("ReCiterAI-DynamoDB") @db.VarChar(64)
  lastRefreshedAt DateTime @default(now()) @map("last_refreshed_at")

  @@unique([cwid, topic])
  @@index([cwid])
  @@map("topic_assignment")
}

/// Parent topic catalog — projected 1:1 from TAXONOMY#taxonomy_v2.topics[].
/// 67 rows. Subtopics are NOT modeled as Topic rows under D-02 candidate (e);
/// they live as embedded fields on PublicationTopic. See 02-SCHEMA-DECISION.md.
model Topic {
  id               String   @id @db.VarChar(128) // slug, e.g. "cancer_genomics"
  label            String   @db.VarChar(255) // from TAXONOMY#.topics[].label
  description      String?  @db.Text // from TAXONOMY#.topics[].description
  /// Issue #325 — per-topic second threshold above the 0.3 score_floor.
  /// Sourced from `hierarchy.json` topic node `display_threshold` (per
  /// ReciterAI #69). Papers with `score >= displayThreshold` render in
  /// the "Strongly relevant" tier on /topics/<id>; papers between the
  /// floor and this threshold render in the collapsible "Also relevant"
  /// tier (#326 PR-1). NULL = untuned; consumer falls back to the spec
  /// default of 0.5 via `topic.displayThreshold ?? 0.5`. Storing NULL
  /// (rather than defaulting at the column level) keeps "untuned" and
  /// "tuned to 0.5" distinguishable for the upstream tuning workstream.
  displayThreshold Float?   @map("display_threshold")
  source           String   @db.VarChar(64) // "reciterai-taxonomy_v2"
  refreshedAt      DateTime @default(now()) @map("refreshed_at")

  publications           PublicationTopic[]
  subtopics              Subtopic[]
  publicationsAsTopTopic Publication[]      @relation("PublicationTopTopic")

  @@map("topic")
}

/// Subtopic catalog. Sole writer: Hierarchy ETL (etl/hierarchy/index.ts), which
/// fetches s3://wcmc-reciterai-hierarchy/latest/hierarchy.json (a co-published JSON
/// Schema 2020-12 contract — see ~/Dropbox/GitHub/ReciterAI/docs/hierarchy-contract.md).
/// `display_name` and `short_description` are D-19 LOCKED UI fields; `label` and
/// `description` are LLM-canonical (synthesis-injected, no LLM use in SPS today).
/// NO FK from PublicationTopic.primarySubtopicId / subtopicIds — old slugs flush
/// out on the next Hierarchy ETL refresh (Phase 8 contract D-06: subtopic IDs are
/// NOT stable across annual recomputes; PublicationTopic FK remediation deferred
/// per CONTEXT.md A1-D1).
model Subtopic {
  id               String   @id @db.VarChar(128) // slug, e.g. "breast_screening_risk_prediction"
  parentTopicId    String   @map("parent_topic_id") @db.VarChar(128)
  parentTopic      Topic    @relation(fields: [parentTopicId], references: [id], onDelete: Cascade)
  label            String   @db.VarChar(255) // LLM-canonical label from artifact (synthesis-injected, no LLM use in SPS today)
  description      String?  @db.Text // null for long tail (D-06)
  displayName      String?  @map("display_name") @db.VarChar(255) // D-19 / D-05: UI card title; falls back to `label` when null/empty
  shortDescription String?  @map("short_description") @db.Text // D-19 / D-05: UI subtitle; rendered silently when null/empty (Phase 3 D-06 absence-as-default)
  activityCount    Int?     @map("activity_count") // D-05: ReCiterAI seed-PMID count; advisory only (D-06 keeps PublicationTopic count for rail order)
  totalWeight      Float?   @map("total_weight") // D-05: ReCiterAI sum of articleScores; advisory only
  source           String   @db.VarChar(64) // "reciterai-taxonomy_v2"
  refreshedAt      DateTime @default(now()) @map("refreshed_at")

  @@index([parentTopicId])
  @@map("subtopic")
}

/// NLM MeSH descriptor catalog. Sole writer: MeSH ETL (etl/mesh-descriptors/index.ts),
/// which yearly fetches the desc<year>.xml release from
/// https://nlmpubs.nlm.nih.gov/projects/mesh/MESH_FILES/xmlmesh/ (NLM publishes
/// in November; mid-year files run on demand). One row per DescriptorUI.
///
/// `entryTerms` and `treeNumbers` are JSON string arrays (MariaDB JSON column,
/// matching the Publication.meshTerms convention at line 427). `entryTerms`
/// stores every Term/String under every Concept of the descriptor EXCEPT the
/// descriptor's own preferred name. The synonym-collision filter (spec §1.3 step
/// 4: terms that map to >1 descriptor get dropped from synonyms.txt) runs at
/// synonym-emission time, not at row write time — the raw entry-term list stays
/// intact in the table so future resolution logic (§1.5) and downstream
/// telemetry can still see the full set.
///
/// `localLeadAuthorScholarCoverage` (spec §2.x) is deliberately NOT modeled
/// here yet — it depends on Phase 2 lead-author fields and lands in its own
/// migration when that phase ships.
model MeshDescriptor {
  descriptorUi     String    @id @map("descriptor_ui") @db.VarChar(10) // e.g. "D057286"
  name             String    @db.VarChar(255) // Descriptor's preferred-concept preferred term
  entryTerms       Json      @map("entry_terms") // string[] — every Term/String except `name`
  treeNumbers      Json      @map("tree_numbers") // string[] — e.g. ["E05.318.308.250", ...]
  scopeNote        String?   @map("scope_note") @db.Text // From preferred Concept/ScopeNote
  dateRevised      DateTime? @map("date_revised") @db.Date // NLM DateRevised
  /// Spec §1.7 — fraction of `publication` rows whose `mesh_terms` JSON
  /// contains this descriptor's `ui`. Range [0, 1]. NULL = not yet
  /// computed (e.g., between a MeSH-descriptor full-replace ETL and the
  /// next `etl:mesh-coverage` run). Updated daily by
  /// `etl/mesh-coverage/index.ts`; consumed by `resolveMeshDescriptor`
  /// (§1.5) as a tiebreaker and reserved for §3.3's too-broad cutoff.
  localPubCoverage Float?    @map("local_pub_coverage")
  refreshedAt      DateTime  @default(now()) @map("refreshed_at")

  @@index([name])
  @@map("mesh_descriptor")
}

/// Spec §1.4 — anchor between a NLM MeSH descriptor and one or more
/// ReciterAI parent topics. Read by `resolveMeshDescriptor` (§1.5) to
/// populate `MeshResolution.curatedTopicAnchors`; the populated array is
/// then consumed by §1.6's OR-of-evidence publication filter and §1.11's
/// resolved-concept chip. One row per (descriptor_ui, parent_topic_id)
/// pair. A descriptor may anchor to multiple parent topics and a parent
/// topic may anchor to many descriptors.
///
/// `confidence` is 'curated' for hand-authored rows (top concept queries
/// from access logs, maintained by the curation team via the CSV at
/// `data/mesh-anchors/curated.csv`) or 'derived' for ETL-emitted rows
/// produced by the co-occurrence calculation. Curated wins on conflict.
///
/// No Prisma FKs:
///   - To `MeshDescriptor.descriptorUi`: the MeSH ETL full-replaces the
///     descriptor table inside a transaction; a cascading FK would wipe
///     all anchors on every MeSH refresh. Stale `descriptor_ui` values
///     become inert — the resolver never finds them.
///   - To `Topic.id`: matches the existing PublicationTopic.primarySubtopicId
///     "no FK" pattern; stale parent_topic_id rows are surfaced by audit
///     query A5 in PLAN-issue-259-phase-1.4-anchor-table.md.
model MeshCuratedTopicAnchor {
  descriptorUi  String   @map("descriptor_ui") @db.VarChar(10)
  parentTopicId String   @map("parent_topic_id") @db.VarChar(128)
  confidence    String   @db.VarChar(16) // 'curated' | 'derived'
  sourceNote    String?  @map("source_note") @db.Text
  refreshedAt   DateTime @default(now()) @map("refreshed_at")

  @@id([descriptorUi, parentTopicId])
  @@map("mesh_curated_topic_anchor")
}

/// Issue #642 — curated query→descriptor alias. Maps a free-text surface
/// form that NLM itself lacks (e.g. "Cardiothoracic Surgery") onto an
/// existing MeSH descriptor so `resolveMeshDescriptor` (§1.5) resolves it
/// as `confidence: "entry-term"`. Merged into the resolver's `byForm` map
/// AFTER descriptor names + entry terms, so a real NLM surface form always
/// wins; aliases only fill gaps. `alias` is the human-readable form;
/// the resolver normalizes it (lowercase + strip non-alphanumeric) at load
/// time, matching the query-time key.
///
/// No Prisma FK to `MeshDescriptor.descriptorUi` — same rationale as
/// `MeshCuratedTopicAnchor`: the MeSH ETL full-replaces the descriptor table
/// inside a transaction, so a cascading FK would wipe aliases on every
/// refresh (the ETL-wipe hazard #642 calls out). A stale `descriptor_ui`
/// becomes inert — the resolver skips aliases whose UI is absent.
///
/// Seeded from the committed CSV at `etl/mesh-aliases/curated.csv`, loaded
/// by `npm run etl:mesh-aliases` (truncate + insert).
model MeshCuratedAlias {
  alias        String   @id @db.VarChar(255)
  descriptorUi String   @map("descriptor_ui") @db.VarChar(10)
  sourceNote   String?  @map("source_note") @db.Text
  refreshedAt  DateTime @default(now()) @map("refreshed_at")

  @@index([descriptorUi])
  @@map("mesh_curated_alias")
}

/// WCM department from ED LDAP `weillCornellEduOrgUnit` level1.
/// `code` is the stable org-unit code from LDAP — joined on, never display names.
/// `chairCwid` is identified from appointment.title LIKE 'Chairman%' (D-03).
/// `slug` is derived via deriveSlug() from `name`. ETL upsert refreshes scholarCount.
model Department {
  code         String   @id @db.VarChar(64)
  name         String   @db.VarChar(255)
  slug         String   @unique @db.VarChar(255)
  description  String?  @db.Text
  /// Curated outbound website URL (#1021). Optional; null = nothing rendered.
  /// https-only, ≤ 512 chars (validateUnitUrl). Surfaced as a small inline
  /// external-link arrow beside the department NAME on the public page. Edited
  /// via the dept/div `field_override(url)` row (ED-preserving), merged at read
  /// time alongside `description`.
  url          String?  @db.VarChar(512)
  /// Curated full / ceremonial display name (e.g. ED `name` "Library" ->
  /// "Samuel J. Wood Library"). NULL = use `name`. Seeded on CREATE from
  /// lib/department-names.ts; the ED ETL NEVER writes it on UPDATE, so renames
  /// survive every refresh. Resolved via lib/org-unit-names.ts:officialUnitName.
  officialName String?  @map("official_name") @db.VarChar(255)
  /// Curated short / common display name for facet chips (e.g. "Medicine").
  /// NULL = use `name`. Same ED-preserving contract as officialName.
  compactName  String?  @map("compact_name") @db.VarChar(255)
  /// Browse-page grouping bucket. Hand-curated via lib/department-categories.ts;
  /// the ED ETL preserves existing values rather than overwriting, so manual
  /// reclassification sticks across refreshes. Display label mapping ("mixed"
  /// renders as "Basic & Clinical") lives at the UI layer.
  /// Allowed values: "clinical" | "basic" | "mixed" | "administrative".
  category     String   @default("clinical") @map("category") @db.VarChar(32)
  chairCwid    String?  @map("chair_cwid") @db.VarChar(32)
  scholarCount Int      @default(0) @map("scholar_count")
  source       String   @default("ED") @db.VarChar(32)
  refreshedAt  DateTime @default(now()) @map("refreshed_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  divisions Division[]
  scholars  Scholar[]

  @@index([slug])
  @@map("department")
}

/// WCM division from ED LDAP `weillCornellEduOrgUnit` level2.
/// `code` is the stable division code from LDAP. `deptCode` FK enforces
/// the level2-belongs-to-level1 invariant. The two Cardiology divisions
/// (Medicine vs. Pediatrics) disambiguated by deptCode + slug per D-12.
model Division {
  code         String     @id @db.VarChar(64)
  deptCode     String     @map("dept_code") @db.VarChar(64)
  department   Department @relation(fields: [deptCode], references: [code], onDelete: Cascade)
  name         String     @db.VarChar(255)
  slug         String     @db.VarChar(255)
  description  String?    @db.Text
  /// Curated outbound website URL (#1021). Same contract as Department.url —
  /// https-only, ≤ 512 chars, edited via the `field_override(url)` row and
  /// merged at read time; null = nothing rendered beside the division NAME.
  url          String?    @db.VarChar(512)
  chiefCwid    String?    @map("chief_cwid") @db.VarChar(32)
  scholarCount Int        @default(0) @map("scholar_count")
  source       String     @default("ED") @db.VarChar(32)
  refreshedAt  DateTime   @default(now()) @map("refreshed_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  scholars Scholar[]

  @@unique([deptCode, slug])
  @@index([deptCode])
  @@index([slug])
  @@map("division")
}

/// Cross-disciplinary research centers and institutes that span departments.
/// Faculty appointments roll up to a Department; center affiliations are
/// layered on top (no FK from Scholar — membership lives in a separate table
/// when sources land, e.g. reporting_cancer_center for the Meyer Cancer Center).
/// `code` is a stable slug-like identifier (e.g. "englander_ipm").
model Center {
  code          String   @id @db.VarChar(64)
  name          String   @db.VarChar(255)
  slug          String   @unique @db.VarChar(255)
  description   String?  @db.Text
  /// Curated outbound website URL (#1021). Same contract as Department.url —
  /// https-only, ≤ 512 chars; null = nothing rendered beside the center NAME.
  /// A center has no `field_override`; this column is edited in-row via
  /// `/api/edit/unit` op:"update" alongside `description`.
  url           String?  @db.VarChar(512)
  /// Curated names, symmetric with Department (lib/org-unit-names.ts). A center
  /// is manually-owned — no ETL fights its `name` — so `name` already serves as
  /// the official name and `officialName` is typically NULL (resolver falls back
  /// to `name`). `compactName` carries the short facet label (e.g. "Precision
  /// Medicine" for "Englander Institute for Precision Medicine").
  officialName  String?  @map("official_name") @db.VarChar(255)
  compactName   String?  @map("compact_name") @db.VarChar(255)
  /// Presentation kind: "center" (default) or "institute". Drives the badge
  /// color in autocomplete and search results — institutes (typically NCI/NIH-
  /// designated, larger, more endowed) get their own teal badge; centers get
  /// purple. Backfilled by name match in 20260508120000_add_center_type.
  centerType    String   @default("center") @map("center_type") @db.VarChar(16)
  directorCwid  String?  @map("director_cwid") @db.VarChar(32)
  /// Interim/acting qualifier for the director — renders "Interim Director".
  /// Center-only column because the center row is manually-owned and no ETL
  /// writes it; departments/divisions express the same qualifier as a
  /// columnless `field_override(leaderInterim)` row instead.
  /// Added by #540 Phase 1 (ADR-005 Amendment 1 § A1.1).
  leaderInterim Boolean  @default(false) @map("leader_interim")
  scholarCount  Int      @default(0) @map("scholar_count")
  sortOrder     Int      @default(0) @map("sort_order")
  source        String   @default("seed") @db.VarChar(32)
  refreshedAt   DateTime @default(now()) @map("refreshed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  members  CenterMembership[]
  programs CenterProgram[]

  @@index([slug])
  @@index([sortOrder])
  @@map("center")
}

/// Per-center program taxonomy (#552). Empty for centers that don't use
/// programs (most). The Meyer Cancer Center seeds five rows (CB, CGE, CPC, CT,
/// ZY). Other centers may opt in later by inserting their own rows — no schema
/// change. `membershipType` + `programCode` on a membership are surfaced in the
/// roster editor ONLY for centers that have ≥1 row here (the Cancer-Center-only
/// gate is data-driven, not a hardcoded center code).
model CenterProgram {
  centerCode String @map("center_code") @db.VarChar(64)
  code       String @db.VarChar(16)
  label      String @db.VarChar(255)
  sortOrder  Int    @default(0) @map("sort_order")

  center  Center             @relation(fields: [centerCode], references: [code], onDelete: Cascade)
  members CenterMembership[]

  @@id([centerCode, code])
  @@map("center_program")
}

/// Research vs clinical membership flavor — a Cancer-Center concept (#552). Set
/// alongside a program; independent of it at the schema level, but the roster
/// editor only exposes it for centers that have a program taxonomy.
enum CenterMembershipType {
  research
  clinical

  @@map("center_membership_type")
}

/// Per-scholar membership in a Center. Sourced from manual exports
/// (e.g. data/center-members/meyer-cancer-center.txt) until upstream
/// systems land. Composite unique on (centerCode, cwid). Scholars deleted
/// from `scholar` cascade-remove the row; centers cascade-remove their
/// memberships.
///
/// #552 added `membershipType`/`programCode`/`startDate`/`endDate` (all
/// nullable). Legacy rows read as (null,null,null,null) = "active forever,
/// unclassified". The active-filter predicate (start<=today<=end, inclusive,
/// nulls open) drives the public roster + the editor's Active/Pending/Inactive
/// status.
model CenterMembership {
  centerCode      String                @map("center_code") @db.VarChar(64)
  cwid            String                @db.VarChar(32)
  membershipType  CenterMembershipType? @map("membership_type")
  programCode     String?               @map("program_code") @db.VarChar(16)
  startDate       DateTime?             @map("start_date") @db.Date
  endDate         DateTime?             @map("end_date") @db.Date
  source          String                @default("manual") @db.VarChar(64)
  lastRefreshedAt DateTime              @default(now()) @map("last_refreshed_at")

  center  Center         @relation(fields: [centerCode], references: [code], onDelete: Cascade)
  // RESTRICT (not the spec's SET NULL): the FK is composite (centerCode,
  // programCode) and centerCode is NOT NULL, so SET NULL is invalid in both
  // Prisma and MySQL — it would null centerCode too. There is no program-delete
  // surface in v1; a future one must clear members' programCode in-app first
  // (with audit), then delete the program. (#552 §9 row 2 deviation.)
  program CenterProgram? @relation(fields: [centerCode, programCode], references: [centerCode, code], onDelete: NoAction, onUpdate: NoAction)

  @@id([centerCode, cwid])
  @@index([cwid])
  @@index([centerCode, programCode])
  @@map("center_membership")
}

/// Per-scholar membership in a manually-created Division (`Division.source =
/// 'manual'`). Mirrors `CenterMembership` exactly — added rows carry
/// `source='manual-ui'`. No FK to `Scholar` (a roster row may exist before the
/// scholar's ED record arrives; ADR-003 / ADR-005 Amendment 1 § A1.1). The
/// write path enforces `Division.source='manual'` — LDAP-sourced division
/// membership stays on `Scholar.divCode` and is not represented here.
/// Added by #540 Phase 1.
model DivisionMembership {
  divisionCode    String   @map("division_code") @db.VarChar(64)
  cwid            String   @db.VarChar(32)
  source          String   @default("manual-ui") @db.VarChar(64)
  lastRefreshedAt DateTime @default(now()) @map("last_refreshed_at")

  @@id([divisionCode, cwid])
  @@index([cwid])
  @@map("division_membership")
}

/// Per-unit administrator grant (ADR-005 Amendment 1 § A1.1 / #540). One row
/// per (unit, cwid) — `@@unique([entityType, entityId, cwid])` is implicit via
/// the compound `@@id`. Inserted on grant, **hard-deleted** on revoke (B03
/// audits both). `role` is a `UnitRole` enum (owner subsumes curator).
/// `grantedBy` is the actor CWID whose own role + scope made the grant legal
/// (Amendment 1 § A1.2: authority ≤ own role, scope ⊆ own subtree).
/// `entityType` is `department`, `division`, or `center` (a dept-level grant
/// cascades to that dept's divisions; division-level does not cascade upward).
/// No FK to the unit tables — a grant is a separate access fact, not a child
/// row, and an Owner of a not-yet-coded informal subunit references a
/// synthetic `code` only the manual layer knows about.
model UnitAdmin {
  entityType EntityType @map("entity_type")
  entityId   String     @map("entity_id") @db.VarChar(64) // unit code
  cwid       String     @db.VarChar(32) // grantee
  role       UnitRole
  grantedBy  String     @map("granted_by") @db.VarChar(32) // actor CWID (or "ED-ETL" sentinel)
  // #728 — provenance. "manual" for human grants; "ED:DA" | "ED:DivA" | "ED:IAMDELA" |
  // "ED:DivA-IAMDELA" for ED-imported grants. Lets the per-source reconcile spare manual
  // rows (and other populations' rows) and lets the Administrators tab lock ED-sourced rows.
  source     String     @default("manual") @db.VarChar(32)
  createdAt  DateTime   @default(now()) @map("created_at")

  @@id([entityType, entityId, cwid])
  @@index([cwid])
  @@index([source]) // #728 — per-source reconcile + Administrators-tab provenance filter
  @@map("unit_admin")
}

/// Scholar-assigned proxy editor grant (scholar-proxy-spec.md / #779, ADR-005
/// Amendment 3). One row per (scholarCwid, proxyCwid): a scholar names a specific
/// individual to edit THEIR profile on their behalf, scoped to exactly what the
/// scholar could self-edit (overview + hiding the scholar's own misattributed
/// publications). The grant reaches EXACTLY that one scholar — it is NOT the
/// #540 unit-role "proxy editing" (which is role-derived and reaches a whole
/// unit subtree); the two authorization axes are kept distinct in code and audit.
///
/// Inserted on grant (self-assign, or superuser-assign on the scholar's behalf),
/// HARD-DELETED on revoke; B03 audits both (`proxy_grant` / `proxy_revoke`). No
/// soft-revoke column — a grant is crisply present or absent, matching the
/// UnitAdmin precedent (ADR-005 Amendment 1 § A1.1); the append-only audit log is
/// the sole revoke history. The per-edit authorization checks ROW EXISTENCE only
/// (no `revokedAt` filter — there is no such column).
///
/// `grantedBy` is the REAL grantor cwid (the scholar self-assigning, or a
/// superuser acting on their behalf) — written from `realCwid`, never the
/// effective/impersonated cwid. A historical breadcrumb, not a live FK: the grant
/// stands even if the grantor is later deprovisioned.
///
/// No FK to Scholar on EITHER column. `proxyCwid` is by design NOT a Scholar (the
/// proxy holds no other role — enforced in application code, not the DB);
/// `scholarCwid` carries no FK so a grant outlives a soft-deleted scholar inertly
/// (unexercisable while the scholar is deleted — see lib/edit/proxy-authz.ts).
model ScholarProxy {
  scholarCwid String   @map("scholar_cwid") @db.VarChar(32) // the granted scholar
  proxyCwid   String   @map("proxy_cwid") @db.VarChar(32) // the designee (holds NO other role)
  grantedBy   String   @map("granted_by") @db.VarChar(32) // REAL grantor cwid (scholar self, or superuser)
  createdAt   DateTime @default(now()) @map("created_at")

  @@id([scholarCwid, proxyCwid])
  @@index([proxyCwid]) // reverse lookup: which scholars does this proxy serve? (landing redirect, drift audit)
  @@map("scholar_proxy")
}

/// Per-publication × scholar × parent_topic triple, projected from TOPIC# rows.
/// One PublicationTopic row per `TOPIC#<parent_topic_id>` item in DynamoDB.
/// Subtopic data lives as embedded JSON fields here (no separate subtopic table).
model PublicationTopic {
  pmid                String  @db.VarChar(32)
  cwid                String  @db.VarChar(32)
  parentTopicId       String  @map("parent_topic_id") @db.VarChar(128)
  primarySubtopicId   String? @map("primary_subtopic_id") @db.VarChar(128) // slug; NO FK
  subtopicIds         Json?   @map("subtopic_ids") // ["slug1","slug2",...]
  subtopicConfidences Json?   @map("subtopic_confidences") // {slug: score}
  score               Decimal @db.Decimal(8, 4) // ReciterAI parent-topic score
  /// Natural-language "why this paper maps to this topic" from TOPIC#.rationale.
  /// Per-(pmid, cwid, parent_topic) — different scope from the global
  /// `Publication.impactJustification`. Surfaced in topic-chip tooltips by
  /// PR-C of issue #316.
  rationale           String? @db.Text
  authorPosition      String  @map("author_position") @db.VarChar(16)
  year                Int     @db.SmallInt

  publication Publication @relation(fields: [pmid], references: [pmid], onDelete: Cascade)
  scholar     Scholar     @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  topic       Topic       @relation(fields: [parentTopicId], references: [id], onDelete: Cascade)

  @@id([pmid, cwid, parentTopicId])
  @@index([cwid, parentTopicId, score(sort: Desc)]) // profile Selected highlights + chip-row aggregations
  @@index([parentTopicId, year(sort: Desc), score(sort: Desc)]) // /topics/{slug} Recent highlights
  @@index([cwid, year(sort: Desc)]) // profile most-recent feed (with D-16 dedup)
  @@index([parentTopicId, cwid]) // Top scholars chip row group-by
  @@map("publication_topic")
}

/// ReCiterAI publication scores per scholar+pmid pair (Q6 minimal projection).
/// The other of the two fields that flow DynamoDB to MySQL.
model PublicationScore {
  id              String      @id @default(uuid()) @db.VarChar(64)
  cwid            String      @db.VarChar(32)
  scholar         Scholar     @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  pmid            String      @db.VarChar(32)
  publication     Publication @relation(fields: [pmid], references: [pmid], onDelete: Cascade)
  score           Float
  source          String      @default("ReCiterAI-DynamoDB") @db.VarChar(64)
  lastRefreshedAt DateTime    @default(now()) @map("last_refreshed_at")

  @@unique([cwid, pmid])
  @@index([cwid])
  @@index([pmid])
  @@map("publication_score")
}

/// COI disclosures from v_coi_vivo_activity_group. Phase 1 spec amendment
/// (the spec didn't enumerate a Disclosures section but VIVO had one).
model CoiActivity {
  id                    String   @id @default(uuid()) @db.VarChar(64)
  cwid                  String   @db.VarChar(32)
  scholar               Scholar  @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  entity                String?  @db.VarChar(255)
  activityType          String?  @map("activity_type") @db.VarChar(255)
  value                 String?  @db.VarChar(64) // e.g. "0-$4,999"
  activityRelatesTo     String?  @map("activity_relates_to") @db.VarChar(64)
  wcmcFacilities        String?  @map("wcmc_facilities") @db.VarChar(8)
  purchasingProcurement String?  @map("purchasing_procurement") @db.VarChar(8)
  chairApproval         String?  @map("chair_approval") @db.VarChar(64)
  activityGroup         String?  @map("activity_group") @db.VarChar(128) // vivo_pops_activity_group
  description           String?  @db.Text
  source                String   @default("COI") @db.VarChar(32)
  lastRefreshedAt       DateTime @default(now()) @map("last_refreshed_at")

  @@index([cwid])
  @@index([cwid, activityGroup])
  @@map("coi_activity")
}

/// Persisted COI-gap candidates produced by the daily `etl:coi-gap` job: a
/// relationship named in the scholar's own PubMed COI statement that was NOT
/// found in their disclosed set (`coi_activity`, Self). Persisted — rather than
/// computed ephemerally — so the daily job is incremental (only re-process
/// scholars whose statements/disclosures changed), the same nudge isn't shown
/// twice, and the scholar can DISAVOW a bad match (status='dismissed') durably.
///
/// GOVERNANCE (see docs/coi-pubmed-unmatched-feasibility.md): this is a
/// candidate + the scholar's own review status, NOT a verdict. There is no
/// "undisclosed" boolean, no ranking, and it is surfaced ONLY to the scholar
/// themselves on /edit (self-only) — never to curators, superusers, the public,
/// or any compliance feed. `status` is the scholar's lifecycle, not an
/// accusation. The match confidence is the qualitative `tier` (never a %).
model CoiGapCandidate {
  id               String    @id @default(uuid()) @db.VarChar(64)
  cwid             String    @db.VarChar(32)
  scholar          Scholar   @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  pmid             String    @db.VarChar(32)
  /// Raw extracted relationship entity, shown verbatim to the scholar.
  entity           String    @db.VarChar(512)
  /// Normalized form — the dedupe key within (cwid, pmid).
  normalizedEntity String    @map("normalized_entity") @db.VarChar(512)
  tier             String    @db.VarChar(16) // High | Medium
  attribution      String    @db.VarChar(32) // scholar | unattributed
  entityScore      Decimal?  @map("entity_score") @db.Decimal(4, 3)
  category         String    @db.VarChar(16) // personal
  /// Verbatim source sentence — always shown so the human, not the score,
  /// adjudicates (the non-negotiable rendering rule from the risk review).
  sourceSentence   String    @map("source_sentence") @db.Text
  /// Scholar's lifecycle: new (surfaced) | acknowledged (will add) |
  /// dismissed (disavowed — never re-nag) | resolved (now disclosed / gone).
  status           String    @default("new") @db.VarChar(16)
  firstSeenAt      DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt       DateTime  @default(now()) @map("last_seen_at")
  /// When the scholar acted (feedback recorded). Null until reviewed.
  reviewedAt       DateTime? @map("reviewed_at")
  /// Research-grade reason captured with a terminal feedback action (PURE SIGNAL —
  /// records intent + stops the nag, no workflow/hand-off). will_disclose → status
  /// `acknowledged`; historical | invalid → status `dismissed`. Null for system
  /// states (new/resolved) and until the scholar responds. Splitting historical
  /// vs invalid is what makes the data usable for a suggestion-quality paper —
  /// see `docs/coi-gap-feedback-spec.md` and `lib/coi-gap/feedback.ts`.
  feedbackReason   String?   @map("feedback_reason") @db.VarChar(24)

  @@unique([cwid, pmid, normalizedEntity], name: "cwid_pmid_entity")
  @@index([cwid, status])
  @@map("coi_gap_candidate")
}

/// CWID aliases for redirects (Q2'). Auto-populated from ED replacement_cwid.
/// On detection: FKs migrate to current_cwid, old scholar row drops, alias row inserted.
model CwidAlias {
  oldCwid     String   @id @map("old_cwid") @db.VarChar(32)
  currentCwid String   @map("current_cwid") @db.VarChar(32)
  current     Scholar  @relation("AliasCurrent", fields: [currentCwid], references: [cwid], onDelete: Cascade)
  source      String   @default("ed_replacement_cwid") @db.VarChar(64) // 'ed_replacement_cwid' | 'admin_manual'
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([currentCwid])
  @@map("cwid_alias")
}

/// Slug history for 301 redirects (Q3'). Every former slug points to its current scholar.
model SlugHistory {
  oldSlug     String   @id @map("old_slug") @db.VarChar(255)
  currentCwid String   @map("current_cwid") @db.VarChar(32)
  current     Scholar  @relation("SlugHistoryCurrent", fields: [currentCwid], references: [cwid], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([currentCwid])
  @@map("slug_history")
}

/// ETL run log (Q5'). Tracks per-source success/failure for monitoring.
/// CloudWatch alarm trigger in production: max(completed_at) per source < now - 26h.
/// ED-sourced display names for `comms_steward` CWIDs that have no `Scholar`
/// row of their own (e.g. external-affairs staff like dwd2001). Populated by the
/// steward-name bridge (`etl:ed:import-steward-names`, fed by the WCM-side
/// export), read by the "View as" banner + candidate list so a steward shows a
/// name instead of a bare CWID. comms-steward-profile-editing-spec.md §5.
model StewardDirectory {
  cwid        String   @id @db.VarChar(32)
  displayName String   @map("display_name") @db.VarChar(255)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("steward_directory")
}

model EtlRun {
  id                      String    @id @default(uuid()) @db.VarChar(64)
  source                  String    @db.VarChar(64) // ED | ASMS | InfoEd | ReCiter | COI | PubMedRetractions | ReCiterAI-projection | OpenSearch-index | MeSH | MeshAnchor | MeshAlias
  startedAt               DateTime  @default(now()) @map("started_at")
  completedAt             DateTime? @map("completed_at")
  status                  String    @db.VarChar(16) // 'running' | 'success' | 'failed'
  rowsProcessed           Int       @default(0) @map("rows_processed")
  errorMessage            String?   @map("error_message") @db.Text
  manifestSha256          String?   @map("manifest_sha256") @db.VarChar(64) // D-02 / Claude's Discretion: hex sha256 of last successful Hierarchy run's hierarchy.json bytes
  manifestTaxonomyVersion String?   @map("manifest_taxonomy_version") @db.VarChar(64) // D-02: persists manifest.taxonomy_version for drift detection (loud WARN on diff)

  @@index([source, startedAt])
  @@index([source, status, completedAt])
  @@map("etl_run")
}

/// Cross-ETL coordination state — a single row (id = 1).
/// `last_topic_rebuild_at`: set by etl/reciter at run start, cleared by
/// etl/dynamodb on success. Drives the profile "topics updating" placeholder
/// during the reciter→dynamodb consistency window (#118 / B19). The window
/// also auto-expires 30 min after the rebuild start if dynamodb never clears it.
model EtlState {
  id                 Int       @id @default(1)
  lastTopicRebuildAt DateTime? @map("last_topic_rebuild_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("etl_state")
}

/// Phase 6 ANALYTICS-03 — weekly profile completeness snapshot.
/// One row per weekly cron run (D-03). Historical rows kept for trending.
/// `belowThreshold` = true when completenessPercent < COMPLETENESS_THRESHOLD (70).
/// Read by /api/health/refresh-status (latest row only) per D-09; the
/// production CloudWatch alarm wires the boolean to PagerDuty.
model CompletenessSnapshot {
  id                  String   @id @default(uuid()) @db.VarChar(64)
  snapshotAt          DateTime @default(now()) @map("snapshot_at")
  totalScholars       Int      @map("total_scholars")
  completeCount       Int      @map("complete_count")
  completenessPercent Float    @map("completeness_percent")
  belowThreshold      Boolean  @map("below_threshold")

  @@index([snapshotAt(sort: Desc)])
  @@map("completeness_snapshot")
}

/// Phase 9 SPOTLIGHT-01 — projection of the ReciterAI spotlight artifact.
/// Sole writer is `etl/spotlight/index.ts` (Plan 09-02), which fetches
/// s3://wcmc-reciterai-artifacts/spotlight/latest/spotlight.json and treats
/// each publish as a full replacement.
///
/// `subtopicId` is the artifact's `subtopic_id`. NOT a Prisma FK to
/// `Subtopic.id`: the spotlight publish cycle is independent of the hierarchy
/// publish cycle, and a transient mismatch during a hierarchy recompute /
/// dual-publish window must not break inserts. D-06 (subtopic ID instability
/// across recomputes) carries through — never persist `subtopicId` as a FK in
/// other tables that outlive a single publish cycle.
///
/// `papers` stores the artifact's per-paper payload verbatim (PMID, title,
/// journal, year, first_author + last_author each shaped
/// `{personIdentifier, displayName, position}`). The DAL resolves
/// `personIdentifier` → Scholar headshot at read time.
///
/// D-19 LOCKED: `displayName`, `shortDescription`, and `lede` are UI-facing
/// only. NEVER pass them to an LLM, retrieval, or embedding path. The
/// LLM-canonical fields are `label` (here) and `description` (on `Subtopic`).
model Spotlight {
  subtopicId       String   @id @map("subtopic_id") @db.VarChar(128)
  parentTopicId    String   @map("parent_topic_id") @db.VarChar(128)
  label            String   @db.VarChar(255)
  displayName      String   @map("display_name") @db.VarChar(255)
  shortDescription String   @map("short_description") @db.Text
  lede             String   @db.Text
  papers           Json     @map("papers")
  artifactVersion  String   @map("artifact_version") @db.VarChar(32)
  refreshedAt      DateTime @map("refreshed_at")

  @@index([parentTopicId])
  @@map("spotlight")
}

// Manual-override layer (ADR-005) — two ETL-immune tables holding human-entered
// data, keyed on stable entity identifiers and merged into responses at read
// time. The ETL never writes either table, so the manual layer survives every
// rebuild by construction. See docs/ADR-005-manual-override-layer.md. The B03
// audit log (#102) is a separate artefact in a separate schema and is
// deliberately NOT a Prisma model.

/// Stable entity identifiers the manual layer can target. A Prisma enum — not a
/// bare string — so a typo is a compile error, not a silently-unread row. v1
/// uses only `scholar` and `publication` (plus the (publication, author) pair);
/// grant/education/appointment are reserved but blocked on the ETL stable-key
/// refactor (#352).
enum EntityType {
  scholar
  publication
  grant
  education
  appointment
  // + ADR-005 Amendment 1 (#540): org-unit curation. Units key on a stable
  // `code` PK that survives every ETL run, so they qualify for the manual
  // layer with no #352 stable-key prerequisite.
  department
  division
  center
  // + #160 follow-up: a derived mentor↔mentee relationship the mentor may
  // hide from their profile. `entityId` is `"{mentorCwid}:{menteeCwid}"`; the
  // mentor (before the colon) is the owner. Suppression-only — mentees are
  // never field_override or unit_admin targets.
  mentee
}

/// Per-unit administrator role (ADR-005 Amendment 1 § A1.2 / #540). One row
/// per (unit, cwid) in `UnitAdmin`; `owner` subsumes `curator`. Owner adds
/// access-management within the owned subtree; Curator edits only. Both are
/// per-unit and data-derived (not an SSO group), re-checked per POST.
enum UnitRole {
  owner
  curator
}

/// Manual scalar-field overrides applied over ETL-managed data at read time.
/// One row per (entity, field): the current value, upserted in place. Change
/// history is the B03 audit log's responsibility, not this table's. No FK to
/// the entity tables — a slug override must be settable before the scholar's
/// ED record exists (#29 reservation case).
model FieldOverride {
  id         String     @id @default(uuid()) @db.VarChar(64)
  entityType EntityType @map("entity_type")
  entityId   String     @map("entity_id") @db.VarChar(64) // Scholar.cwid for v1
  fieldName  String     @map("field_name") @db.VarChar(64) // 'overview' | 'slug' | 'selectedHighlightPmids' (#836) — EDITABLE_FIELDS allowlist
  value      String     @db.Text // scalar text for overview/slug; #836 stores a JSON array of PMID strings for selectedHighlightPmids
  actorCwid  String     @map("actor_cwid") @db.VarChar(32)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  /// DB-managed uniqueness guard for slug overrides — a STORED generated column
  /// holding the override `value` for (scholar, slug) rows and NULL elsewhere,
  /// with a UNIQUE index, so two CWIDs cannot hold the same slug override (the
  /// application collision check is not atomic). See migration
  /// add_slug_override_uniqueness_guard. @ignore keeps it out of the Prisma
  /// client — application code must never write a generated column.
  slugGuard String? @unique @map("slug_guard") @ignore @db.VarChar(64)

  @@unique([entityType, entityId, fieldName])
  @@map("field_override")
}

/// Manual suppression of an entity, or of one contributor on a record.
/// Revocable, never deleted: a target is suppressed iff a matching row exists
/// with revokedAt IS NULL, so re-suppressing after a revoke is legitimate and
/// the table carries no uniqueness constraint. No FK, so a suppression row can
/// outlive a hard-deleted target.
model Suppression {
  id                String     @id @default(uuid()) @db.VarChar(64)
  entityType        EntityType @map("entity_type")
  entityId          String     @map("entity_id") @db.VarChar(64) // stable identifier — see ADR-005 § Keying
  contributorCwid   String?    @map("contributor_cwid") @db.VarChar(32) // NULL = whole entity; CWID = one contributor
  reason            String     @db.Text
  createdBy         String     @map("created_by") @db.VarChar(32)
  createdAt         DateTime   @default(now()) @map("created_at")
  revokedBy         String?    @map("revoked_by") @db.VarChar(32)
  revokedAt         DateTime?  @map("revoked_at")
  /// ADR-005 failure-model layer 3 reconciler sentinel (#393). A freshness
  /// flag, not a timestamp of record: NULL means "this row's latest state
  /// transition has not been reflected into the OpenSearch index." It defaults
  /// NULL on create and is RESET to NULL on revoke; a successful
  /// `reflectSearchSuppression` stamps it to now(). The reconciler treats any
  /// scholar/publication row with NULL past a short grace as stale and
  /// re-reflects it. Scoped to scholar/publication — other entity types have no
  /// OpenSearch fast-path, so this stays NULL for them and the reconciler
  /// excludes them by entity type.
  searchReflectedAt DateTime?  @map("search_reflected_at")

  @@index([entityType, entityId])
  @@map("suppression")
}

/// ADR-005 failure-model layer-3 outbox for a failed CloudFront invalidation
/// (#353) — the CDN analogue of the #393 search-index reconciler, and the
/// durable backstop the `invalidateCloudFront` best-effort path (see
/// `lib/edit/revalidation.ts`) names as its retry mechanism.
///
/// Layer 1 is the synchronous `CreateInvalidation` issued in the write request;
/// it is best-effort and never throws, so a crash, an outage, or an SDK error
/// between the DB commit and the edge purge leaves the suppressed/renamed page
/// edge-cached up to the ≤24h CloudFront TTL — exactly the staleness the
/// urgency split exists to eliminate. This row is layer 3: a worker
/// (`lib/edit/cdn-reconcile.ts`) drains pending rows on a ≤5 min cadence and
/// retries the invalidation until it lands.
///
/// CRITICAL difference from #393's sentinel: #393 re-derives its OpenSearch
/// payload from CURRENT DB state, so it persists nothing and only flags a
/// NULL-sentinel column. #353 CANNOT do that — the paths-to-purge are NOT
/// recomputable. A slug flip, a `PROFILE_CANONICAL` change, or a mutated author
/// set means the exact path that was edge-cached at write time can no longer be
/// derived later. So this outbox REMEMBERS the literal paths in `paths` (a JSON
/// array), and the reconciler replays them verbatim.
///
/// Sentinel: `invalidatedAt` is NULL while pending and is stamped now() by a
/// successful `CreateInvalidation` — mirroring the #393 NULL-timestamp pattern
/// (NULL = "not yet delivered"). `attempts` / `lastError` carry the retry
/// bookkeeping; the reconciler caps retries at `maxAttempts` and emits an
/// alarm-shaped log when a row is exhausted.
///
/// Dormancy: rows are only ever written when
/// `SCHOLARS_CLOUDFRONT_DISTRIBUTION_ID` is set (production edge). Pre-launch /
/// local, the invalidation path early-returns before enqueue and the reconciler
/// no-ops, so this table stays empty — exactly as the synchronous invalidation
/// is dormant. Lives in the main schema so the app role's existing DML grant
/// already covers it (no separate-schema GRANT to forget at deploy, cf. the
/// #493 audit-grant gap).
model CdnInvalidation {
  id            String    @id @default(uuid()) @db.VarChar(64)
  /// The EXACT edge paths to purge, JSON-encoded (`JSON.stringify(paths)`).
  /// Persisted — not recomputable — because a later slug/canonical/author-set
  /// change makes the original path underivable. The reconciler replays these
  /// verbatim. This is the deliberate point of difference from #393.
  paths         String    @db.Text
  /// Sentinel: NULL = pending; stamped now() on a successful CreateInvalidation.
  invalidatedAt DateTime? @map("invalidated_at")
  attempts      Int       @default(0)
  lastError     String?   @map("last_error") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([invalidatedAt])
  @@map("cdn_invalidation")
}

/// Durable intent for the self-edit "Not mine" reject → ReCiter flow (#746).
/// One row per rejected (uid, pmid), written in the reject route's transaction
/// alongside the local suppression + B03 audit row. `goldstandard_sent_at` NULL
/// means the reject hasn't reached ReCiter's gold standard yet; the route fires
/// it best-effort inline and `etl/reciter-refresh` retries the stragglers.
/// `feature_generator_sent_at` NULL means the uid still needs the delayed,
/// coalesced engine re-score (`analysisRefreshFlag=true`). Mirrors the ADR-005
/// layer-3 sentinel/reconciler pattern (#393): a NULL timestamp is "not yet
/// delivered" and the scanner converges it. Lives in the main schema so the app
/// role's DML grant already covers it (no separate-schema GRANT, cf. #493).
model ReciterPendingRefresh {
  id                     String    @id @default(uuid()) @db.VarChar(64)
  uid                    String    @db.VarChar(32) // ReCiter uid == scholar CWID being rejected-as
  pmid                   String    @db.VarChar(32)
  rejectedBy             String    @map("rejected_by") @db.VarChar(32) // the real human actor (#637)
  createdAt              DateTime  @default(now()) @map("created_at")
  goldstandardSentAt     DateTime? @map("goldstandard_sent_at")
  featureGeneratorSentAt DateTime? @map("feature_generator_sent_at")
  attempts               Int       @default(0)
  lastError              String?   @map("last_error") @db.Text

  @@index([goldstandardSentAt])
  @@index([uid, featureGeneratorSentAt])
  @@map("reciter_pending_refresh")
}

/// Per-cwid fixed-window rate limit for the "Request a change" server send
/// (#160 Phase 2, docs/self-edit-request-change-modal.md § 5 abuse controls).
/// One row per (actor cwid, UTC hour-window); the hot-path increment is a raw
/// `INSERT ... ON DUPLICATE KEY UPDATE count = count + 1`, atomic on the PK row
/// lock — Prisma `upsert` is read-then-write and would double-count concurrent
/// requests, which is exactly the adversary (a parallel spam loop). Rows accrete
/// (one per cwid per active hour); volume is negligible and stale windows can be
/// pruned out-of-band. Deliberately NOT a distributed store (Redis/ElastiCache):
/// standing up new infra for one soft control on a low-frequency, authenticated
/// endpoint is over-engineering — the DB is already here and won't notice. Kept
/// in the main schema so the app role's existing DML covers it, with no separate-
/// schema GRANT to forget at deploy time (cf. the #493 audit-grant gap).
model RequestChangeRateLimit {
  cwid        String   @db.VarChar(32)
  windowStart DateTime @map("window_start") // start of the UTC hour-window
  count       Int      @default(0)

  @@id([cwid, windowStart])
  @@map("request_change_rate_limit")
}

/// One generated overview candidate (#742 v2, overview-statement-generator-spec.md).
/// Written on EVERY Generate; it is never the published value (that stays in
/// FieldOverride(overview)) — this is the version HISTORY the scholar browses,
/// loads, and regenerates from. `model` + `params` record exactly which model and
/// which controls produced the draft. In the main schema so the app role's existing
/// DML covers it, with no separate-schema GRANT to forget at deploy (cf. the #493
/// audit-grant gap).
model OverviewGeneration {
  id            String   @id @default(uuid()) @db.VarChar(64)
  cwid          String   @db.VarChar(32)
  text          String   @db.Text // sanitized HTML draft
  model         String   @db.VarChar(64) // gateway model string used
  params        Json // { voice, tone, length, elements[], instructions }
  createdByCwid String   @map("created_by_cwid") @db.VarChar(32) // actor (self today)
  createdAt     DateTime @default(now()) @map("created_at")

  scholar Scholar @relation(fields: [cwid], references: [cwid], onDelete: Cascade)

  @@index([cwid, createdAt(sort: Desc)]) // the scholar's drafts, newest first
  @@map("overview_generation")
}

/// Provenance of the CURRENTLY PUBLISHED overview (#742 v2). One row per scholar,
/// upserted whenever the overview is saved. Answers "is the live bio authored,
/// generated, or generated-then-edited, and by which model / which generation?"
/// Surfaced in /edit only (never public). `sourceGenerationId` is a SOFT pointer to
/// the OverviewGeneration the saved text derived from (no FK — a draft may be pruned
/// later; null for a hand-authored save). In the main schema so the app role's
/// existing DML covers it (cf. the #493 audit-grant gap).
model OverviewProvenance {
  cwid               String   @id @db.VarChar(32)
  origin             String   @db.VarChar(24) // 'authored' | 'generated' | 'generated_edited'
  model              String?  @db.VarChar(64) // null when authored
  sourceGenerationId String?  @map("source_generation_id") @db.VarChar(64)
  updatedByCwid      String   @map("updated_by_cwid") @db.VarChar(32)
  updatedAt          DateTime @updatedAt @map("updated_at")

  scholar Scholar @relation(fields: [cwid], references: [cwid], onDelete: Cascade)

  @@map("overview_provenance")
}

/// Per-(scholar, tool) rollup of ReciterAI `TOOL#` method/instrument extractions
/// (#742 v3.1 C3). Written by etl/dynamodb (Block 5) from the DynamoDB TOOL#
/// items (one item per tool×pmid×cwid), aggregated to one row per (cwid, tool).
/// Grounds the overview generator's `methods` and powers a future public
/// "Methods & Tools" view. `pmids` retains the publication linkage (which papers
/// the tool appears in) so the view can show usage; the bio reads name/category.
/// Main-schema table — the app role's existing DML grant covers it (cf. #493).
model ScholarTool {
  id            String   @id @default(uuid()) @db.VarChar(64)
  cwid          String   @db.VarChar(32)
  /// Canonical tool / method / instrument name (from the TOOL# PK).
  toolName      String   @map("tool_name") @db.VarChar(255)
  /// Functional category (e.g. "imaging", "vector platform"); null when absent.
  category      String?  @db.VarChar(128)
  /// Distinct publications the tool was observed in (drives "used in N papers").
  pmidCount     Int      @map("pmid_count")
  /// Max extraction confidence across the tool's activities, in [0,1].
  maxConfidence Decimal  @map("max_confidence") @db.Decimal(5, 4)
  /// A representative context snippet from one extraction (nullable).
  sampleContext String?  @map("sample_context") @db.Text
  /// The contributing PMIDs — publication linkage for the future view.
  pmids         Json
  refreshedAt   DateTime @default(now()) @map("refreshed_at")

  scholar Scholar @relation(fields: [cwid], references: [cwid], onDelete: Cascade)

  @@unique([cwid, toolName])
  @@index([cwid, pmidCount(sort: Desc)])
  @@map("scholar_tool")
}

/// Per-(scholar, method-family) rollup from the A2 canonical taxonomy (#799).
/// The family-primary "Methods & tools" lens shows these families as the entity,
/// expandable to member tools. Written by etl/tools (the S3 loader, alongside
/// `scholar_tool`) from the per-scholar `faculty{<cwid>}.families[]` rollup in the
/// A2 `tools.json` artifact; dormant until `SCHOLAR_TOOL_SOURCE=s3` (the same
/// flag that gates the tool rollup). Full-replacement each run — the uuid `id` and
/// `family_id` are both unstable across A2 rebuilds (families are re-minted on
/// every relabel), so this is a rebuild keyed by (cwid, family_id), never an
/// upsert; downstream overlays (#800 suppression, #801 gating) key on
/// (supercategory, label), NOT family_id. Contract: faculty.families[] carries
/// exactly { family_id, label, supercategory, pub_count, exemplar_tool_ids[] };
/// `pub_count` is the per-scholar, C-tier-reconciled distinct-publication count
/// computed upstream (read directly, never re-aggregated SPS-side).
model ScholarFamily {
  id                String   @id @default(uuid()) @db.VarChar(64)
  cwid              String   @db.VarChar(32)
  /// A2 family id (e.g. "fam_0042"). NOT stable across A2 rebuilds — re-keyed on
  /// every full-replacement load; safe only as the (cwid, family_id) rebuild key.
  familyId          String   @map("family_id") @db.VarChar(64)
  /// Display-grade family label from the A2 taxonomy (#799a — surfaced directly).
  familyLabel       String   @map("family_label") @db.VarChar(255)
  /// One of the A2 supercategory ids (e.g. "animal_cell_models"). The #801 gating
  /// key and the #800 group key. Open set (drifted 13→14); guard, don't hard-enum.
  supercategory     String   @db.VarChar(128)
  /// Per-scholar, C-reconciled distinct-publication count (drives ranking + the
  /// "All work" count). Read directly from the artifact; never re-aggregated.
  pmidCount         Int      @map("pmid_count")
  /// Up to ~3 representative member-tool DISPLAY NAMES (e.g. "CheXpert"),
  /// resolved at ETL time from the per-scholar `exemplar_tool_ids` via the
  /// canonical tools[] index — scholar_tool has no canonical id to join on, so
  /// the lens cannot resolve ids→names at read time. Refreshed every load.
  exemplarTools     Json     @map("exemplar_tools")
  /// The distinct PMIDs that put this scholar in this family (#819 — the
  /// click-to-filter membership). Read directly from `faculty[].families[].pmids`
  /// in the A2 `tools.json` artifact (ReciterAI#175), where the invariant
  /// `len(distinct pmids) === pub_count` holds. Co-located on the family payload so
  /// the lens filters the publication list client-side (like Topics' meshTerms),
  /// no endpoint. Nullable: the ALTER adds it to a possibly-populated table and a
  /// MySQL JSON column takes no default; the next full-replace ETL backfills it.
  pmids             Json?
  /// The `manifest.sha256` of the artifact this row was loaded from — lets a
  /// family-id renumber be detected per refresh (no semantic taxonomy_version).
  sourceArtifactSha String?  @map("source_artifact_sha") @db.VarChar(64)
  /// #879 — generated 1–2 sentence capability gloss for the family, passthrough
  /// from the A2 taxonomy `families[].definition` (schema tools-a2-v3, ReciterAI).
  /// Family-level (identical across a family's scholar rows); denormalized here the
  /// same way `family_label`/`exemplar_tools` are, joined by `family_id` at ETL
  /// time. RENDER-ONLY — never re-fed into any LLM/embedding/retrieval (the #886
  /// overview generator reads a projection without it). Nullable: a pre-v3 artifact
  /// or a family with no generated gloss leaves it null; the next full-replace
  /// ETL backfills it.
  definition        String?  @db.Text
  /// #879 — provenance for `definition`: "generated" when ReciterAI produced one,
  /// else null. The render layer gates the "AI-generated" disclaimer on
  /// `definition_source === "generated"`; stored raw (not coerced) like a tier.
  definitionSource  String?  @map("definition_source") @db.VarChar(32)
  refreshedAt       DateTime @default(now()) @map("refreshed_at")

  scholar Scholar @relation(fields: [cwid], references: [cwid], onDelete: Cascade)

  @@unique([cwid, familyId])
  @@index([cwid, pmidCount(sort: Desc)])
  @@index([supercategory])
  /// Backs the cross-scholar Method family page WHERE (the stable
  /// (supercategory, family_label) identity) without a full scan — see the
  /// standalone Method pages plan (`getFamilyScholars` / `getFamiliesForSupercategory`).
  @@index([supercategory, familyLabel])
  @@map("scholar_family")
}

/// #800 — editorial suppression overlay for the Methods lens: families that are
/// too generic to be informative ("Observational study design", "Descriptive
/// statistics") are hidden from the lens, the overview FACTS block, and any
/// public output — for EVERYONE (this is relevance, not access control). Applied
/// unconditionally in the data layer; an empty table is a no-op. Keyed on
/// (supercategory, family_label) NOT family_id, because A2 re-mints family_id on
/// every rebuild — the (supercategory, label) pair is the stable identity.
/// Curated/editorial-owned, gaps-only (mirrors the mesh_curated_alias pattern):
/// SPS only fills what the upstream A2 salience signals do not already suppress.
model FamilySuppressionOverlay {
  supercategory String   @db.VarChar(128)
  familyLabel   String   @map("family_label") @db.VarChar(255)
  sourceNote    String?  @map("source_note") @db.Text
  refreshedAt   DateTime @default(now()) @map("refreshed_at")
  /// Provenance so the seed reseed (`etl/family-suppression`) never clobbers a
  /// comms-steward edit: 'seed' = curated CSV bootstrap, 'steward' = a tier set
  /// from the /edit/methods surface. The reseed upserts only `source='seed'`.
  source        String   @default("seed") @db.VarChar(16)

  @@id([supercategory, familyLabel])
  @@map("family_suppression_overlay")
}

/// #801 — audience-gated sensitivity overlay for the Methods lens: families that
/// are scientifically legitimate but carry reputational/safety risk on a public
/// profile (curated live-animal-model families within `animal_cell_models`).
/// Distinct from suppression: these are hidden from the PUBLIC payload only when
/// `METHODS_LENS_SENSITIVE_GATE=on`, not removed for everyone. Same stable
/// (supercategory, family_label) key. Compliance/Communications-owned; dormant
/// pending External Affairs policy sign-off on the curated scope.
model FamilySensitivityOverlay {
  supercategory String   @db.VarChar(128)
  familyLabel   String   @map("family_label") @db.VarChar(255)
  sourceNote    String?  @map("source_note") @db.Text
  refreshedAt   DateTime @default(now()) @map("refreshed_at")
  /// Provenance so the seed reseed never clobbers a comms-steward edit:
  /// 'seed' = curated CSV bootstrap, 'steward' = a tier set from /edit/methods.
  /// The reseed upserts only `source='seed'` rows.
  source        String   @default("seed") @db.VarChar(16)

  @@id([supercategory, familyLabel])
  @@map("family_sensitivity_overlay")
}

/// Comms-steward Method-Family surfacing ledger
/// (`docs/comms-steward-methods-visibility-spec.md` §5/§6). A deterministic,
/// allow-by-default review queue: the surfacing pass decorates every distinct
/// `(supercategory, family_label)` in `scholar_family` with a structural or
/// lexical animal-model signal so a steward can review it. Keyed on the STABLE
/// family identity, independent of overlay membership — a family can be flagged
/// yet still public. NEVER changes a tier and NEVER hides anything; it only
/// records the signal, when it was first/last seen, and whether a steward has
/// cleared the nag (`reviewedAt`, which leaves the tier untouched).
model FamilyReviewFlag {
  supercategory  String    @db.VarChar(128)
  familyLabel    String    @map("family_label") @db.VarChar(255)
  reason         String    @db.VarChar(64) // e.g. 'supercategory:animal_cell_models', 'term:mouse'
  firstSeenAt    DateTime  @map("first_seen_at") // for the "new" signal
  lastSeenAt     DateTime  @map("last_seen_at")
  reviewedAt     DateTime? @map("reviewed_at") // steward cleared the nag (tier may stay public)
  reviewedByCwid String?   @map("reviewed_by_cwid") @db.VarChar(32)

  @@id([supercategory, familyLabel])
  @@map("family_review_flag")
}

/// A scholar's request for a personalized profile slug (#497 PR-3,
/// docs/slug-personalization-spec.md § 4.1). This is the *approval queue*, not
/// the source of truth: an approved request writes a FieldOverride(slug) row +
/// reconciles Scholar.slug (the authoritative override), then marks the request
/// `approved`. No FK to Scholar (mirrors FieldOverride / Suppression — a request
/// may concern a cwid not yet routable, e.g. an incoming hire).
model SlugRequest {
  id            String            @id @default(uuid()) @db.VarChar(64)
  cwid          String            @db.VarChar(32) // target scholar
  requestedSlug String            @map("requested_slug") @db.VarChar(255) // post-validate normalized form
  reason        String?           @db.Text
  status        SlugRequestStatus @default(pending)
  requestedBy   String            @map("requested_by") @db.VarChar(32) // actor cwid (= cwid in self-mode)
  createdAt     DateTime          @default(now()) @map("created_at")
  decidedBy     String?           @map("decided_by") @db.VarChar(32)
  decidedAt     DateTime?         @map("decided_at")
  decisionNote  String?           @map("decision_note") @db.Text

  @@index([status, createdAt]) // queue view: oldest pending first
  @@index([cwid])
  @@map("slug_request")
}

/// Lifecycle of a SlugRequest. `superseded` is set on the prior pending row when
/// a newer request for the same cwid arrives; `withdrawn` is the requester
/// cancelling their own pending request (#497 — kept distinct from `superseded`
/// for the audit trail).
enum SlugRequestStatus {
  pending
  approved
  rejected
  superseded
  withdrawn
}

/// Site-wide general-feedback submissions from the bottom-right feedback
/// badge (#538 / docs/feedback-badge-spec.md). Distinct from /edit
/// "Request a change" corrections (#160), which write nothing to this
/// table. One row per submitted form.
///
/// v1 is anonymous-by-default. `cwid` is user-typed (pre-filled from
/// session when present, but not server-enforced) — a `NULL` cwid is the
/// common case, not an error. All free-text columns are server-truncated
/// to their documented bounds before insert. `consent` is always true
/// (the form blocks submission otherwise); the column documents *which
/// version* of the consent text the respondent accepted.
///
/// Column names are intent-based (not Q-numbered) so reordering the form
/// in v1.x revisions does not drag a DB migration. See SPEC §
/// "The question instrument" for the rationale.
///
/// Conditional columns (`whatHelped`, `whatMissing`, `oneChange`,
/// `taskFailureIntent`) are written only when their triggering response
/// qualifies — see SPEC § "Conditional follow-ups". The submit server
/// action drops text from these fields when the trigger predicate fails,
/// so a hostile client cannot stuff prose into a non-qualifying row.
///
/// `mode` is load-bearing: a NULL `accuracy` row in contextual mode means
/// "user skipped / N/A"; the same NULL in generic mode means "the question
/// wasn't asked." Aggregating across modes without filtering is a
/// category error — see SPEC § "NULL semantics for conditional columns".
model FeedbackSubmission {
  id          String   @id @default(uuid()) @db.VarChar(64)
  submittedAt DateTime @default(now()) @map("submitted_at")

  // Mode — "contextual" (badge launch, page anchor known) or "generic"
  // (direct nav to /about/feedback, no anchor). Determines which questions
  // appear; analysts must segment by this column before aggregating any
  // per-page metric. Always set.
  mode FeedbackMode

  // Originating context. page_url is the client-reported URL, validated
  // server-side as same-origin (else stored NULL). page_route is the
  // matched Next.js route pattern (e.g. "/scholars/[slug]") derived
  // server-side from page_url at insert time; makes aggregate analysis
  // tractable without parsing URLs in SQL.
  pageUrl   String? @map("page_url") @db.Text
  pageRoute String? @map("page_route") @db.VarChar(255)

  // Identity. User-typed, optional. NULL is the default.
  cwid String? @db.VarChar(32)

  // Q1 — purpose of visit
  purpose      FeedbackPurpose?
  purposeOther String?          @map("purpose_other") @db.VarChar(200)

  // Q2 — task success
  taskSuccess FeedbackTaskSuccess? @map("task_success")

  // Q2a — task-failure detail (CONDITIONAL: stored only when task_success ∈ {no, partially})
  taskFailureIntent String? @map("task_failure_intent") @db.VarChar(500)

  // Q3 — perceived usefulness (1..5 or NULL for N/A / skipped)
  usefulness Int? @db.TinyInt

  // Q3a — what worked (CONDITIONAL: stored only when usefulness ∈ {4,5})
  whatHelped String? @map("what_helped") @db.VarChar(500)

  // Q3b — what was missing (CONDITIONAL: stored only when usefulness ∈ {1,2})
  whatMissing String? @map("what_missing") @db.VarChar(500)

  // Q4 — perceived accuracy (1..5 or NULL — also NULL if mode=generic or Q1=browse_unit, see SPEC)
  accuracy Int? @db.TinyInt

  // Q4a — what to change for accuracy (CONDITIONAL: stored only when accuracy ∈ {1,2,3})
  oneChange String? @map("one_change") @db.VarChar(500)

  // Q5 — would the respondent use Scholars again (1..5 or NULL).
  // Replaces NPS; see SPEC § "The question instrument".
  wouldUseAgain Int? @map("would_use_again") @db.TinyInt

  // Q6 — respondent context
  role      FeedbackRole?
  roleOther String?       @map("role_other") @db.VarChar(100)

  // Q7 — consent (always true; column records the accepted version)
  consent        Boolean
  consentVersion String  @map("consent_version") @db.VarChar(16)

  // Q8 — contact + follow-up. `cwid` (declared above under Identity) is
  // for WCM-internal follow-up; `contactEmail` is for everyone else. Both
  // nullable, never required, never required-together.
  contactEmail  String? @map("contact_email") @db.VarChar(255)
  followupOptin Boolean @default(false) @map("followup_optin")

  @@index([submittedAt]) // chronology, exports
  @@index([cwid, submittedAt]) // per-CWID activity (sparse — most rows NULL)
  @@index([pageRoute, submittedAt]) // per-surface aggregate
  @@index([mode, submittedAt]) // mode-segmented aggregates (analysts MUST filter by mode)
  @@map("feedback_submission")
}

/// Which mode the form was rendered in. Determines which downstream
/// questions were even *asked*, which is load-bearing for analysis.
enum FeedbackMode {
  contextual
  generic
}

/// Q1 — what the user was doing on the page.
enum FeedbackPurpose {
  lookup_person
  lookup_topic
  browse_unit
  research_story
  evaluate_scholars
  other
}

/// Q2 — task-success CSAT.
enum FeedbackTaskSuccess {
  yes_completely
  mostly
  partially
  no
  not_looking
}

/// Q6 — respondent self-classification. Pre-selected from
/// `Scholar.roleCategory` when a session is present (see SPEC §
/// "Q6 inference from roleCategory"), always user-editable.
enum FeedbackRole {
  wcm_faculty
  wcm_trainee
  wcm_staff
  external_researcher
  journalist
  patient_or_public
  prefer_not_say
  other
}
