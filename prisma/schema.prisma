// Scholars Profile System — local prototype schema.
// All FKs reference scholar.cwid (Q2': CWID-canonical).
// Soft-delete via scholar.deleted_at (Q4': 60-day retention window).
// cwid_aliases populated from ED replacement_cwid (Q2').
// slug_history records every former slug for 301 redirects (Q3').

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

/// One row per actively-affiliated WCM scholar. PK is CWID.
/// deleted_at != NULL marks a soft-deleted scholar; cleanup job hard-deletes after 60 days.
model Scholar {
  cwid              String    @id @db.VarChar(32)
  preferredName     String    @map("preferred_name") @db.VarChar(255)
  fullName          String    @map("full_name") @db.VarChar(255)
  /// Pre-concatenated degree string from `weillCornellEduDegree` on the WOOFA
  /// faculty SOR (e.g. "MD", "MD, MPH"). Appended after preferredName as a
  /// postnominal credential at render time. Null for scholars with no SOR
  /// row (postdocs, doctoral students, non-faculty).
  postnominal       String?   @db.VarChar(64)
  primaryTitle      String?   @map("primary_title") @db.VarChar(255)
  primaryDepartment String?   @map("primary_department") @db.VarChar(255)
  email             String?   @db.VarChar(255)
  headshotUrl       String?   @map("headshot_url") @db.VarChar(512)
  overview          String?   @db.Text
  overviewUpdatedAt DateTime? @map("overview_updated_at")
  slug              String    @unique @db.VarChar(255)
  status            String    @default("active") @db.VarChar(32) // 'active' | 'suppressed'
  // Phase 2: derived in ED ETL per design-spec-v1.7.1.md:352-356.
  // Drives the algorithmic-surface eligibility carve (lib/eligibility.ts).
  // Nullable so the additive migration applies cleanly to existing rows;
  // ED ETL backfills on next refresh.
  roleCategory      String?   @map("role_category") @db.VarChar(32)
  // Phase 3: org-unit FKs from ED LDAP. Nullable so additive migration applies cleanly;
  // backfilled on next ED ETL run. Joins on codes only per LOCKED constraint.
  deptCode          String?   @map("dept_code") @db.VarChar(64)
  divCode           String?   @map("div_code") @db.VarChar(64)
  /// Derived from LDAP personTypeCodes — true when the scholar carries a
  /// clinical or NYP-credentialed signal, indicating they likely have a
  /// public physician profile at weillcornell.org. Drives whether the
  /// "Clinical profile →" link appears in the profile sidebar (absence-as-
  /// default per design spec v1.7.1). Backfilled on next ED ETL run.
  hasClinicalProfile Boolean  @default(false) @map("has_clinical_profile")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  appointments         Appointment[]
  educations           Education[]
  grants               Grant[]
  authorships          PublicationAuthor[]
  topicAssignments     TopicAssignment[]
  publicationScores    PublicationScore[]
  publicationTopics    PublicationTopic[]
  cwidAliasesAsCurrent CwidAlias[]         @relation("AliasCurrent")
  slugHistoryAsCurrent SlugHistory[]       @relation("SlugHistoryCurrent")
  coiActivities        CoiActivity[]
  department           Department?         @relation(fields: [deptCode], references: [code], onDelete: SetNull)
  division             Division?           @relation(fields: [divCode], references: [code], onDelete: SetNull)

  @@index([deletedAt])
  @@index([status])
  @@index([roleCategory])
  @@index([deptCode])
  @@index([divCode])
  @@map("scholar")
}

/// Per-scholar appointments from Enterprise Directory.
/// Display logic per spec line 43: primary first, active only by default,
/// interim excluded if any non-interim exists.
model Appointment {
  id              String    @id @default(uuid()) @db.VarChar(64)
  cwid            String    @db.VarChar(32)
  scholar         Scholar   @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  title           String    @db.VarChar(255)
  organization    String    @db.VarChar(255)
  startDate       DateTime? @map("start_date") @db.Date
  endDate         DateTime? @map("end_date") @db.Date // NULL = current
  isPrimary       Boolean   @default(false) @map("is_primary")
  isInterim       Boolean   @default(false) @map("is_interim")
  externalId      String?   @map("external_id") @db.VarChar(128) // ED appointment ID for upsert
  source          String    @default("ED") @db.VarChar(32)
  lastRefreshedAt DateTime  @default(now()) @map("last_refreshed_at")

  @@index([cwid])
  @@index([cwid, isPrimary, endDate])
  @@map("appointment")
}

/// Education and training entries from ASMS.
model Education {
  id              String   @id @default(uuid()) @db.VarChar(64)
  cwid            String   @db.VarChar(32)
  scholar         Scholar  @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  degree          String   @db.VarChar(255)
  institution     String   @db.VarChar(255)
  year            Int?
  field           String?  @db.VarChar(255)
  externalId      String?  @map("external_id") @db.VarChar(128)
  source          String   @default("ASMS") @db.VarChar(32)
  lastRefreshedAt DateTime @default(now()) @map("last_refreshed_at")

  @@index([cwid])
  @@map("education")
}

/// Grants from InfoEd, filtered per spec line 125 (Confidential != 'Y',
/// program_type != 'Contract without funding', valid roles, valid dates).
model Grant {
  id              String   @id @default(uuid()) @db.VarChar(64)
  cwid            String   @db.VarChar(32)
  scholar         Scholar  @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  title           String   @db.Text
  role            String   @db.VarChar(64) // PI | PI-Subaward | Co-PI | Co-I | Key Personnel
  /// Pre-rendered display string (e.g. "NCI" or "NCI via Duke University").
  /// Retained for transition; UI is migrating to the structured fields below
  /// (issue #78 Wave C). Will be removed once all surfaces migrate.
  funder          String   @db.VarChar(255)
  startDate       DateTime @map("start_date") @db.Date
  endDate         DateTime @map("end_date") @db.Date
  externalId      String?  @map("external_id") @db.VarChar(128)
  /// Sponsor-issued award number (e.g. NIH "R01 AG067497"). Nullable —
  /// many grants don't have one (industry contracts, internal awards).
  /// Populated from InfoEd CONSOLIDATED_QUERY's Award_Number column.
  awardNumber     String?  @map("award_number") @db.VarChar(128)
  source          String   @default("InfoEd") @db.VarChar(32)
  lastRefreshedAt DateTime @default(now()) @map("last_refreshed_at")

  /// Issue #78 — InfoEd `program_type`. Possible values: Grant, Contract
  /// with funding, Fellowship, Career, Training, BioPharma Alliance
  /// Agreement, Equipment. Contract without funding is excluded at the
  /// ETL filter stage (issue #78 decision Q3).
  programType String @default("Grant") @map("program_type") @db.VarChar(64)

  /// Issue #78 F6 — original source of funds. Canonical short name
  /// (resolved via lib/sponsor-lookup) when matched; null when the raw
  /// sponsor isn't in the canonical lookup. Raw form is always populated
  /// in `primeSponsorRaw`.
  primeSponsor    String? @map("prime_sponsor") @db.VarChar(64)
  primeSponsorRaw String? @map("prime_sponsor_raw") @db.VarChar(255)

  /// Issue #78 F6 — institution that issued the subaward to WCM. Equal
  /// to prime when WCM holds the prime directly. Canonical short name
  /// when matched; raw form in `directSponsorRaw`.
  directSponsor    String? @map("direct_sponsor") @db.VarChar(64)
  directSponsorRaw String? @map("direct_sponsor_raw") @db.VarChar(255)

  /// Issue #78 F2 — derived from award-number prefix. NIH-funded only;
  /// null otherwise. e.g. "R01", "K23", "U01".
  mechanism String? @db.VarChar(16)

  /// Issue #78 F2 — derived from award-number IC infix. NIH-funded only;
  /// null otherwise. e.g. "NCI", "NHLBI".
  nihIc String? @map("nih_ic") @db.VarChar(8)

  /// Issue #78 F6 — true when the direct sponsor differs from the prime.
  isSubaward Boolean @default(false) @map("is_subaward")

  @@index([cwid])
  @@index([cwid, endDate]) // active-first ordering
  @@index([primeSponsor])
  @@index([programType])
  @@map("grant")
}

/// Publications are global (shared across authors). Keyed by PMID.
/// citationCount refreshes from reciter-db (spec line 78: weekly minimum).
/// authorsString holds the full pre-rendered author list including externals,
/// in canonical order (from analysis_summary_article.authors). PublicationAuthor
/// rows are inserted only for WCM scholars; profile rendering overlays
/// hyperlinks onto the matching substrings in authorsString.
model Publication {
  pmid              String    @id @db.VarChar(32)
  title             String    @db.Text
  authorsString     String?   @map("authors_string") @db.VarChar(2000)
  journal           String?   @db.VarChar(512)
  year              Int?
  publicationType   String?   @map("publication_type") @db.VarChar(64) // publicationTypeCanonical
  citationCount     Int       @default(0) @map("citation_count")
  dateAddedToEntrez DateTime? @map("date_added_to_entrez") @db.Date
  doi               String?   @db.VarChar(255)
  pubmedUrl         String?   @map("pubmed_url") @db.VarChar(512)
  /// MeSH keywords from accepted publications, used by the profile Topics
  /// section (issue #73). Format: `[{ ui: "D015316", label: "Genetic Therapy" }, ...]`.
  /// `ui` is null for the rare label that doesn't resolve to a `mesh.DescriptorUI`
  /// in reciterdb. Source: `reciterdb.person_article_keyword` joined to
  /// `reciterdb.mesh`. Keyword sets are per-PMID, not per-(person, pmid) —
  /// verified during ETL design.
  meshTerms         Json?     @map("mesh_terms")
  /// Plain-text article abstract from ReciterDB.reporting_abstracts.abstractVarchar
  /// (capped at 15000 chars at the source). Used by the search-index ETL to
  /// emit `publicationAbstracts` on the people document for thematic-query
  /// recall (issue #21). Nullable — many older publications and many
  /// non-research article types have no abstract.
  abstract          String?   @db.Text
  source            String    @default("ReCiter") @db.VarChar(32)
  lastRefreshedAt   DateTime  @default(now()) @map("last_refreshed_at")

  authors           PublicationAuthor[]
  publicationScores PublicationScore[]
  publicationTopics PublicationTopic[]

  @@index([year])
  @@index([dateAddedToEntrez])
  @@map("publication")
}

/// Join between scholars and publications. cwid is NULLABLE for non-WCM authors
/// (Q2' refinement; spec line 200 — render as plain text without profile link).
model PublicationAuthor {
  id              String      @id @default(uuid()) @db.VarChar(64)
  pmid            String      @db.VarChar(32)
  publication     Publication @relation(fields: [pmid], references: [pmid], onDelete: Cascade)
  cwid            String?     @db.VarChar(32) // NULL for non-WCM authors
  scholar         Scholar?    @relation(fields: [cwid], references: [cwid], onDelete: SetNull)
  externalName    String?     @map("external_name") @db.VarChar(255) // for non-WCM authors
  position        Int // 1-based author position
  totalAuthors    Int         @map("total_authors")
  isFirst         Boolean     @default(false) @map("is_first")
  isLast          Boolean     @default(false) @map("is_last")
  isPenultimate   Boolean     @default(false) @map("is_penultimate")
  isConfirmed     Boolean     @default(true) @map("is_confirmed") // ReCiter authorship-confirmation (spec line 118)
  lastRefreshedAt DateTime    @default(now()) @map("last_refreshed_at")

  @@index([cwid])
  @@index([pmid])
  @@index([cwid, isConfirmed])
  @@map("publication_author")
}

/// ReCiterAI topic assignments per scholar (Q6 minimal projection).
/// One of two fields that flow DynamoDB to MySQL via the projection Lambda.
model TopicAssignment {
  id              String   @id @default(uuid()) @db.VarChar(64)
  cwid            String   @db.VarChar(32)
  scholar         Scholar  @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  topic           String   @db.VarChar(255)
  score           Float
  source          String   @default("ReCiterAI-DynamoDB") @db.VarChar(64)
  lastRefreshedAt DateTime @default(now()) @map("last_refreshed_at")

  @@unique([cwid, topic])
  @@index([cwid])
  @@map("topic_assignment")
}

/// Parent topic catalog — projected 1:1 from TAXONOMY#taxonomy_v2.topics[].
/// 67 rows. Subtopics are NOT modeled as Topic rows under D-02 candidate (e);
/// they live as embedded fields on PublicationTopic. See 02-SCHEMA-DECISION.md.
model Topic {
  id          String   @id @db.VarChar(128) // slug, e.g. "cancer_genomics"
  label       String   @db.VarChar(255) // from TAXONOMY#.topics[].label
  description String?  @db.Text // from TAXONOMY#.topics[].description
  source      String   @db.VarChar(64) // "reciterai-taxonomy_v2"
  refreshedAt DateTime @default(now()) @map("refreshed_at")

  publications PublicationTopic[]
  subtopics    Subtopic[]

  @@map("topic")
}

/// Subtopic catalog. Sole writer: Hierarchy ETL (etl/hierarchy/index.ts), which
/// fetches s3://wcmc-reciterai-hierarchy/latest/hierarchy.json (a co-published JSON
/// Schema 2020-12 contract — see ~/Dropbox/GitHub/ReciterAI -ReCiter-Integration/docs/hierarchy-contract.md).
/// `display_name` and `short_description` are D-19 LOCKED UI fields; `label` and
/// `description` are LLM-canonical (synthesis-injected, no LLM use in SPS today).
/// NO FK from PublicationTopic.primarySubtopicId / subtopicIds — old slugs flush
/// out on the next Hierarchy ETL refresh (Phase 8 contract D-06: subtopic IDs are
/// NOT stable across annual recomputes; PublicationTopic FK remediation deferred
/// per CONTEXT.md A1-D1).
model Subtopic {
  id               String   @id @db.VarChar(128) // slug, e.g. "breast_screening_risk_prediction"
  parentTopicId    String   @map("parent_topic_id") @db.VarChar(128)
  parentTopic      Topic    @relation(fields: [parentTopicId], references: [id], onDelete: Cascade)
  label            String   @db.VarChar(255) // LLM-canonical label from artifact (synthesis-injected, no LLM use in SPS today)
  description      String?  @db.Text // null for long tail (D-06)
  displayName      String?  @map("display_name") @db.VarChar(255) // D-19 / D-05: UI card title; falls back to `label` when null/empty
  shortDescription String?  @map("short_description") @db.Text // D-19 / D-05: UI subtitle; rendered silently when null/empty (Phase 3 D-06 absence-as-default)
  activityCount    Int?     @map("activity_count") // D-05: ReCiterAI seed-PMID count; advisory only (D-06 keeps PublicationTopic count for rail order)
  totalWeight      Float?   @map("total_weight") // D-05: ReCiterAI sum of articleScores; advisory only
  source           String   @db.VarChar(64) // "reciterai-taxonomy_v2"
  refreshedAt      DateTime @default(now()) @map("refreshed_at")

  @@index([parentTopicId])
  @@map("subtopic")
}

/// WCM department from ED LDAP `weillCornellEduOrgUnit` level1.
/// `code` is the stable org-unit code from LDAP — joined on, never display names.
/// `chairCwid` is identified from appointment.title LIKE 'Chairman%' (D-03).
/// `slug` is derived via deriveSlug() from `name`. ETL upsert refreshes scholarCount.
model Department {
  code         String   @id @db.VarChar(64)
  name         String   @db.VarChar(255)
  slug         String   @unique @db.VarChar(255)
  description  String?  @db.Text
  /// Browse-page grouping bucket. Hand-curated via lib/department-categories.ts;
  /// the ED ETL preserves existing values rather than overwriting, so manual
  /// reclassification sticks across refreshes. Display label mapping ("mixed"
  /// renders as "Basic & Clinical") lives at the UI layer.
  /// Allowed values: "clinical" | "basic" | "mixed" | "administrative".
  category     String   @default("clinical") @map("category") @db.VarChar(32)
  chairCwid    String?  @map("chair_cwid") @db.VarChar(32)
  scholarCount Int      @default(0) @map("scholar_count")
  source       String   @default("ED") @db.VarChar(32)
  refreshedAt  DateTime @default(now()) @map("refreshed_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  divisions Division[]
  scholars  Scholar[]

  @@index([slug])
  @@map("department")
}

/// WCM division from ED LDAP `weillCornellEduOrgUnit` level2.
/// `code` is the stable division code from LDAP. `deptCode` FK enforces
/// the level2-belongs-to-level1 invariant. The two Cardiology divisions
/// (Medicine vs. Pediatrics) disambiguated by deptCode + slug per D-12.
model Division {
  code         String     @id @db.VarChar(64)
  deptCode     String     @map("dept_code") @db.VarChar(64)
  department   Department @relation(fields: [deptCode], references: [code], onDelete: Cascade)
  name         String     @db.VarChar(255)
  slug         String     @db.VarChar(255)
  description  String?    @db.Text
  chiefCwid    String?    @map("chief_cwid") @db.VarChar(32)
  scholarCount Int        @default(0) @map("scholar_count")
  source       String     @default("ED") @db.VarChar(32)
  refreshedAt  DateTime   @default(now()) @map("refreshed_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  scholars Scholar[]

  @@unique([deptCode, slug])
  @@index([deptCode])
  @@index([slug])
  @@map("division")
}

/// Cross-disciplinary research centers and institutes that span departments.
/// Faculty appointments roll up to a Department; center affiliations are
/// layered on top (no FK from Scholar — membership lives in a separate table
/// when sources land, e.g. reporting_cancer_center for the Meyer Cancer Center).
/// `code` is a stable slug-like identifier (e.g. "englander_ipm").
model Center {
  code         String   @id @db.VarChar(64)
  name         String   @db.VarChar(255)
  slug         String   @unique @db.VarChar(255)
  description  String?  @db.Text
  /// Presentation kind: "center" (default) or "institute". Drives the badge
  /// color in autocomplete and search results — institutes (typically NCI/NIH-
  /// designated, larger, more endowed) get their own teal badge; centers get
  /// purple. Backfilled by name match in 20260508120000_add_center_type.
  centerType   String   @default("center") @map("center_type") @db.VarChar(16)
  directorCwid String?  @map("director_cwid") @db.VarChar(32)
  scholarCount Int      @default(0) @map("scholar_count")
  sortOrder    Int      @default(0) @map("sort_order")
  source       String   @default("seed") @db.VarChar(32)
  refreshedAt  DateTime @default(now()) @map("refreshed_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  members CenterMembership[]

  @@index([slug])
  @@index([sortOrder])
  @@map("center")
}

/// Per-scholar membership in a Center. Sourced from manual exports
/// (e.g. data/center-members/meyer-cancer-center.txt) until upstream
/// systems land. Composite unique on (centerCode, cwid). Scholars deleted
/// from `scholar` cascade-remove the row; centers cascade-remove their
/// memberships.
model CenterMembership {
  centerCode      String   @map("center_code") @db.VarChar(64)
  cwid            String   @db.VarChar(32)
  source          String   @default("manual") @db.VarChar(64)
  lastRefreshedAt DateTime @default(now()) @map("last_refreshed_at")

  center  Center  @relation(fields: [centerCode], references: [code], onDelete: Cascade)

  @@id([centerCode, cwid])
  @@index([cwid])
  @@map("center_membership")
}

/// Per-publication × scholar × parent_topic triple, projected from TOPIC# rows.
/// One PublicationTopic row per `TOPIC#<parent_topic_id>` item in DynamoDB.
/// Subtopic data lives as embedded JSON fields here (no separate subtopic table).
model PublicationTopic {
  pmid                String   @db.VarChar(32)
  cwid                String   @db.VarChar(32)
  parentTopicId       String   @map("parent_topic_id") @db.VarChar(128)
  primarySubtopicId   String?  @map("primary_subtopic_id") @db.VarChar(128) // slug; NO FK
  subtopicIds         Json?    @map("subtopic_ids") // ["slug1","slug2",...]
  subtopicConfidences Json?    @map("subtopic_confidences") // {slug: score}
  score               Decimal  @db.Decimal(8, 4) // ReciterAI parent-topic score
  impactScore         Decimal? @map("impact_score") @db.Decimal(8, 4)
  authorPosition      String   @map("author_position") @db.VarChar(16)
  year                Int      @db.SmallInt

  publication Publication @relation(fields: [pmid], references: [pmid], onDelete: Cascade)
  scholar     Scholar     @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  topic       Topic       @relation(fields: [parentTopicId], references: [id], onDelete: Cascade)

  @@id([pmid, cwid, parentTopicId])
  @@index([cwid, parentTopicId, score(sort: Desc)]) // profile Selected highlights + chip-row aggregations
  @@index([parentTopicId, year(sort: Desc), score(sort: Desc)]) // /topics/{slug} Recent highlights
  @@index([cwid, year(sort: Desc)]) // profile most-recent feed (with D-16 dedup)
  @@index([parentTopicId, cwid]) // Top scholars chip row group-by
  @@map("publication_topic")
}

/// ReCiterAI publication scores per scholar+pmid pair (Q6 minimal projection).
/// The other of the two fields that flow DynamoDB to MySQL.
model PublicationScore {
  id              String      @id @default(uuid()) @db.VarChar(64)
  cwid            String      @db.VarChar(32)
  scholar         Scholar     @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  pmid            String      @db.VarChar(32)
  publication     Publication @relation(fields: [pmid], references: [pmid], onDelete: Cascade)
  score           Float
  source          String      @default("ReCiterAI-DynamoDB") @db.VarChar(64)
  lastRefreshedAt DateTime    @default(now()) @map("last_refreshed_at")

  @@unique([cwid, pmid])
  @@index([cwid])
  @@index([pmid])
  @@map("publication_score")
}

/// COI disclosures from v_coi_vivo_activity_group. Phase 1 spec amendment
/// (the spec didn't enumerate a Disclosures section but VIVO had one).
model CoiActivity {
  id                    String   @id @default(uuid()) @db.VarChar(64)
  cwid                  String   @db.VarChar(32)
  scholar               Scholar  @relation(fields: [cwid], references: [cwid], onDelete: Cascade)
  entity                String?  @db.VarChar(255)
  activityType          String?  @map("activity_type") @db.VarChar(255)
  value                 String?  @db.VarChar(64) // e.g. "0-$4,999"
  activityRelatesTo     String?  @map("activity_relates_to") @db.VarChar(64)
  wcmcFacilities        String?  @map("wcmc_facilities") @db.VarChar(8)
  purchasingProcurement String?  @map("purchasing_procurement") @db.VarChar(8)
  chairApproval         String?  @map("chair_approval") @db.VarChar(64)
  activityGroup         String?  @map("activity_group") @db.VarChar(128) // vivo_pops_activity_group
  description           String?  @db.Text
  source                String   @default("COI") @db.VarChar(32)
  lastRefreshedAt       DateTime @default(now()) @map("last_refreshed_at")

  @@index([cwid])
  @@index([cwid, activityGroup])
  @@map("coi_activity")
}

/// CWID aliases for redirects (Q2'). Auto-populated from ED replacement_cwid.
/// On detection: FKs migrate to current_cwid, old scholar row drops, alias row inserted.
model CwidAlias {
  oldCwid     String   @id @map("old_cwid") @db.VarChar(32)
  currentCwid String   @map("current_cwid") @db.VarChar(32)
  current     Scholar  @relation("AliasCurrent", fields: [currentCwid], references: [cwid], onDelete: Cascade)
  source      String   @default("ed_replacement_cwid") @db.VarChar(64) // 'ed_replacement_cwid' | 'admin_manual'
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([currentCwid])
  @@map("cwid_alias")
}

/// Slug history for 301 redirects (Q3'). Every former slug points to its current scholar.
model SlugHistory {
  oldSlug     String   @id @map("old_slug") @db.VarChar(255)
  currentCwid String   @map("current_cwid") @db.VarChar(32)
  current     Scholar  @relation("SlugHistoryCurrent", fields: [currentCwid], references: [cwid], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([currentCwid])
  @@map("slug_history")
}

/// ETL run log (Q5'). Tracks per-source success/failure for monitoring.
/// CloudWatch alarm trigger in production: max(completed_at) per source < now - 26h.
model EtlRun {
  id                      String    @id @default(uuid()) @db.VarChar(64)
  source                  String    @db.VarChar(64) // ED | ASMS | InfoEd | ReCiter | COI | ReCiterAI-projection | OpenSearch-index
  startedAt               DateTime  @default(now()) @map("started_at")
  completedAt             DateTime? @map("completed_at")
  status                  String    @db.VarChar(16) // 'running' | 'success' | 'failed'
  rowsProcessed           Int       @default(0) @map("rows_processed")
  errorMessage            String?   @map("error_message") @db.Text
  manifestSha256          String?   @map("manifest_sha256") @db.VarChar(64) // D-02 / Claude's Discretion: hex sha256 of last successful Hierarchy run's hierarchy.json bytes
  manifestTaxonomyVersion String?   @map("manifest_taxonomy_version") @db.VarChar(64) // D-02: persists manifest.taxonomy_version for drift detection (loud WARN on diff)

  @@index([source, startedAt])
  @@index([source, status, completedAt])
  @@map("etl_run")
}

/// Phase 6 ANALYTICS-03 — weekly profile completeness snapshot.
/// One row per weekly cron run (D-03). Historical rows kept for trending.
/// `belowThreshold` = true when completenessPercent < COMPLETENESS_THRESHOLD (70).
/// Read by /api/health/refresh-status (latest row only) per D-09; the
/// production CloudWatch alarm wires the boolean to PagerDuty.
model CompletenessSnapshot {
  id                  String   @id @default(uuid()) @db.VarChar(64)
  snapshotAt          DateTime @default(now()) @map("snapshot_at")
  totalScholars       Int      @map("total_scholars")
  completeCount       Int      @map("complete_count")
  completenessPercent Float    @map("completeness_percent")
  belowThreshold      Boolean  @map("below_threshold")

  @@index([snapshotAt(sort: Desc)])
  @@map("completeness_snapshot")
}

/// Phase 9 SPOTLIGHT-01 — projection of the ReciterAI spotlight artifact.
/// Sole writer is `etl/spotlight/index.ts` (Plan 09-02), which fetches
/// s3://wcmc-reciterai-artifacts/spotlight/latest/spotlight.json and treats
/// each publish as a full replacement.
///
/// `subtopicId` is the artifact's `subtopic_id`. NOT a Prisma FK to
/// `Subtopic.id`: the spotlight publish cycle is independent of the hierarchy
/// publish cycle, and a transient mismatch during a hierarchy recompute /
/// dual-publish window must not break inserts. D-06 (subtopic ID instability
/// across recomputes) carries through — never persist `subtopicId` as a FK in
/// other tables that outlive a single publish cycle.
///
/// `papers` stores the artifact's per-paper payload verbatim (PMID, title,
/// journal, year, first_author + last_author each shaped
/// `{personIdentifier, displayName, position}`). The DAL resolves
/// `personIdentifier` → Scholar headshot at read time.
///
/// D-19 LOCKED: `displayName`, `shortDescription`, and `lede` are UI-facing
/// only. NEVER pass them to an LLM, retrieval, or embedding path. The
/// LLM-canonical fields are `label` (here) and `description` (on `Subtopic`).
model Spotlight {
  subtopicId       String   @id @map("subtopic_id") @db.VarChar(128)
  parentTopicId    String   @map("parent_topic_id") @db.VarChar(128)
  label            String   @db.VarChar(255)
  displayName      String   @map("display_name") @db.VarChar(255)
  shortDescription String   @map("short_description") @db.Text
  lede             String   @db.Text
  papers           Json     @map("papers")
  artifactVersion  String   @map("artifact_version") @db.VarChar(32)
  refreshedAt      DateTime @map("refreshed_at")

  @@index([parentTopicId])
  @@map("spotlight")
}
