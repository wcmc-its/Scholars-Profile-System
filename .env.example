# =============================================================================
# Scholars Profile System — environment variables
# =============================================================================
# Copy this file to .env.local for local development.
# NEVER commit .env, .env.local, or any file containing real credentials.
# =============================================================================

# --- Local DB ---
# Connection string for host MariaDB on 127.0.0.1:3306 (homebrew). Aurora MySQL
# in production. See README.md "Database setup" — MariaDB is NOT in
# docker-compose.yml; the app talks to the host service. Run `npm run db:check`
# to confirm what this URL resolves to.
DATABASE_URL="mysql://scholars:scholars@127.0.0.1:3306/scholars"

# Optional read-replica connection string (B16 / #115). When set, `db.read` in
# lib/db.ts binds here (the Aurora reader endpoint) while writes stay on
# DATABASE_URL. Leave unset for local dev and single-endpoint deploys — reads
# then fall back to the writer (db.read and db.write share one client).
# DATABASE_URL_RO=""

# --- Local OpenSearch ---
OPENSEARCH_NODE="http://localhost:9200"
OPENSEARCH_USERNAME=""
OPENSEARCH_PASSWORD=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Canonical base URL used for SEO (metadataBase, sitemap, robots, JSON-LD).
# Set to https://scholars.weill.cornell.edu in production.
# Distinct from NEXT_PUBLIC_APP_URL — APP_URL may differ in dev (e.g., :3000 vs :3002).
NEXT_PUBLIC_SITE_URL="http://localhost:3002"

# ISR on-demand revalidation token used by the /api/revalidate route gate.
# ETL orchestrator and self-edit pipeline send this as an `Authorization:
# Bearer` token. Generate a strong random value in production; store in
# ~/.zshenv per project credential policy. Never commit a real value.
# SCHOLARS_REVALIDATE_TOKEN=""

# Previous revalidate token — set ONLY during a rotation window, when it is
# accepted alongside the current token so in-flight callers don't 401. Drop it
# once rotation completes. See docs/revalidate-token-rotation.md.
# SCHOLARS_REVALIDATE_TOKEN_PREVIOUS=""

# Base URL for the Next.js app, used by ETL orchestrator to call /api/revalidate.
# Defaults to http://localhost:3000 when unset. Override in production.
# SCHOLARS_BASE_URL="https://scholars.weill.cornell.edu"

# --- Source-system credentials (Phase 4) ---
# All credentials live in ~/.zshrc as env vars per global security policy.
# Reference them in code via process.env.<NAME>; do NOT hardcode.
# These placeholders document the variables the ETL expects.

# Enterprise Directory (LDAPS) — SCHOLARS_LDAP_* namespace to avoid collisions
# SCHOLARS_LDAP_URL=""
# SCHOLARS_LDAP_BIND_PASSWORD=""
# SCHOLARS_LDAP_BIND_DN=""              # e.g., cn=yourcn,ou=binds,dc=weill,dc=cornell,dc=edu
# SCHOLARS_LDAP_SEARCH_BASE=""          # e.g., ou=people,dc=weill,dc=cornell,dc=edu
# SCHOLARS_LDAP_ACTIVE_FILTER=""        # e.g., (objectClass=weillCornellEduPerson)

# ReCiter MySQL (publications, citation counts)
# RECITER_DB_URL=""

# ReCiterAI DynamoDB (publication_score, topic_assignments — Q6 minimal projection)
# AWS_REGION=""
# RECITERAI_DYNAMO_TABLE=""

# ReciterDB (MySQL/MariaDB) — publications, authorship, citations
# Used by etl/reciter/* scripts. The Next.js web app does not connect to
# ReciterDB at runtime, so these are only needed when running those ETLs.
#
# Convention: there is only one ReciterDB instance — production. We do not
# maintain a separate dev ReciterDB. Local ETL development reads from prod
# (read-only access in practice; the etl/reciter/* scripts only SELECT).
# Values come from the global DB_* vars in ~/.zshrc (DB_HOST, DB_USERNAME,
# DB_PASSWORD), copied into .env.local with the SCHOLARS_RECITERDB_* prefix.
# SCHOLARS_RECITERDB_HOST=""           # = $DB_HOST from ~/.zshrc
# SCHOLARS_RECITERDB_PORT="3306"
# SCHOLARS_RECITERDB_USERNAME=""       # = $DB_USERNAME from ~/.zshrc
# SCHOLARS_RECITERDB_PASSWORD=""       # = $DB_PASSWORD from ~/.zshrc
# SCHOLARS_RECITERDB_DATABASE="reciterdb"

# ASMS (MS SQL Server) — education and training records
# SCHOLARS_ASMS_HOST=""
# SCHOLARS_ASMS_PORT="1433"
# SCHOLARS_ASMS_USERNAME=""
# SCHOLARS_ASMS_PASSWORD=""
# SCHOLARS_ASMS_DATABASE="asms"

# InfoEd (MS SQL Server) — grants from VIVO view
# Target view: WC_InfoEdProd_Integration.dbo.VIVO
# SCHOLARS_INFOED_DB_URL=""        # full JDBC URL: jdbc:sqlserver://...;DatabaseName=...;...
# SCHOLARS_INFOED_USERNAME=""
# SCHOLARS_INFOED_PASSWORD=""

# Jenzabar (MS SQL Server) — graduate-student advisor/advisee view
# Target view: WCN_IDM_GS_ADVISOR_ADVISEE_View (ADVISOR_TYPE = 'MAJSP')
# SCHOLARS_JENZABAR_SERVER=""
# SCHOLARS_JENZABAR_PORT="1433"
# SCHOLARS_JENZABAR_DATABASE=""    # optional; omit to use the login's default DB
# SCHOLARS_JENZABAR_USERNAME=""
# SCHOLARS_JENZABAR_PASSWORD=""

# COI (MS SQL Server) — disclosures from v_coi_vivo_activity_group
# SCHOLARS_COI_URL=""        # JDBC URL or plain hostname
# SCHOLARS_COI_PORT="1433"
# SCHOLARS_COI_USERNAME=""
# SCHOLARS_COI_PASSWORD=""
# SCHOLARS_COI_DATABASE=""   # required if URL is plain hostname

# AWS DynamoDB — ReciterAI minimal projection (Q6: topic_assignment from FACULTY# partition)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_DEFAULT_REGION=""
# DYNAMODB_RECITERAI_TABLE="reciterai"

# --- Auth: B01 SSO — Shibboleth SAML (issue #100) ---
# Session cookie + SAML SP config for the /edit and /api/edit gate.
# Production sources these from AWS Secrets Manager (B06 #105); locally they
# live in .env.local. See lib/auth/config.ts.

# Session cookie. SESSION_COOKIE_SECRET must be >= 32 chars (iron-session) —
# generate a strong random value. For local http, set a plain cookie name and
# SESSION_COOKIE_SECURE=false.
# SESSION_COOKIE_SECRET=""
# SESSION_COOKIE_NAME="sps_session"          # default: __Secure-sps_session
# SESSION_COOKIE_SECURE="false"              # default: true (production HTTPS)
# SESSION_COOKIE_DOMAIN=""                   # prod: scholars.weill.cornell.edu; unset locally
# SESSION_MAX_AGE_SECONDS="28800"            # default and hard cap: 28800 (8h)

# SAML — WCM Shibboleth IdP. The IdP values were delivered by the WCM identity
# team on 2026-05-21 (issue #100). Non-prod authenticates against the SAME
# production IdP — no separate non-prod IdP exists — so these three values are
# environment-invariant. Source of truth is the IdP metadata document at
# https://login-proxy.weill.cornell.edu/idp/saml2/idp/metadata.php — re-pull it
# if any value drifts (especially SAML_IDP_CERT during a cert rollover).
# SAML_IDP_ENTITY_ID="https://login-proxy.weill.cornell.edu/idp"
# SAML_IDP_SSO_URL="https://login-proxy.weill.cornell.edu/idp/profile/SAML2/Redirect/SSO"
# SAML_IDP_CERT=""                           # IdP signing certificate(s) (PEM).
#                                            # Single PEM or, during a rollover, multiple PEM blocks
#                                            # (-----BEGIN CERTIFICATE----- … -----END CERTIFICATE-----)
#                                            # concatenated with whitespace between them — the SP will
#                                            # trust an assertion signed by ANY of them. See
#                                            # docs/saml-sp.md for the cert-rollover procedure;
#                                            # the active 2016 cert expires 2026-08-19.
# SAML_SP_ENTITY_ID="https://scholars.weill.cornell.edu/api/auth/saml/metadata"
# SAML_SP_ACS_URL="https://scholars.weill.cornell.edu/api/auth/saml/callback"
# SAML_SP_PRIVATE_KEY=""                     # SP private key (PEM) — signs requests, decrypts assertions
# SAML_SP_CERT=""                            # SP certificate (PEM) — published in SP metadata
# SAML_CWID_ATTRIBUTE="CWID"                 # SAML attribute carrying the bare CWID (confirmed against a live WCM assertion); unset = use the NameID
# SAML_EPPN_ATTRIBUTE="urn:oid:1.3.6.1.4.1.5923.1.1.1.6"  # eppn attribute, the federated-login CWID fallback (default = standard eppn OID)
# SAML_EPPN_TRUSTED_SCOPES="nyp.org,qatar-med.cornell.edu"  # comma-separated eppn scopes whose local-part may be taken as CWID (NYP confirmed; WCM-Q anticipated); empty = fallback off
# SAML_WANT_AUTHN_RESPONSE_SIGNED="false"    # require the response envelope signed (the assertion is always required signed)
# SAML_CLOCK_SKEW_MS="5000"                  # accepted SP/IdP clock skew, milliseconds
# SAML_NAMEID_FORMAT=""                      # requested NameID format; unset lets the IdP choose
# SAML_DEFAULT_RETURN_PATH="/edit"           # post-login destination when RelayState is absent or rejected

# --- Auth: B02 superuser tier (issue #101) ---
# The admin tier of /api/edit authorization: a signed-in scholar who is a
# member of the superuser-role Enterprise Directory group is a superuser.
# Membership is checked live per request by an LDAPS query (lib/auth/superuser.ts)
# — it reuses the Enterprise Directory bind above (SCHOLARS_LDAP_*), which must
# be configured for the superuser tier to work. Unset = no superusers; dormant.
# SCHOLARS_SUPERUSER_GROUP_CN=""  # cn of the ED group, e.g. ITS:Library:Scholars/superuser-role

# --- "View as" impersonation (#637, docs/impersonation-spec.md) ---
# Lets a superuser render and act on the app AS another user. The whole feature
# is dark until enabled: with IMPERSONATION_ENABLED unset/off the /api/impersonation
# routes 404, the switcher is hidden, and any overlay present in a session cookie
# is ignored (lib/auth/effective-identity.ts). Initiator gate reuses superuser-role
# above — no new LDAP group. See lib/auth/effective-identity.ts.

# Master kill-switch for impersonation. Must be exactly "true" to enable; off by default.
# IMPERSONATION_ENABLED="false"

# Read-time auto-expiry of a "view as" overlay, seconds. Default 1800 (30 min);
# the hard cap is always the 8h cookie exp. An overlay older than this is ignored.
# IMPERSONATION_TTL_SECONDS="1800"

# Client-visible mirror of the TTL above, read by the amber banner's countdown
# (components/site/impersonation-banner.tsx) so it expires in lockstep with the
# server's read-time gate. Keep it equal to IMPERSONATION_TTL_SECONDS; the banner
# falls back to 1800 if unset. NEXT_PUBLIC_* is inlined at build time and is not a
# security boundary — the authoritative expiry is always the server seam.
# NEXT_PUBLIC_IMPERSONATION_TTL_SECONDS="1800"

# Optional view-only mode. When "true", impersonated sessions cannot write —
# default is edit-enabled (edits authorize as the target, attributed to the real
# actor + impersonated_cwid per R3). Leave false unless a site wants view-only.
# IMPERSONATION_READONLY="false"

# --- Observability: B24 distributed tracing (issue #123) ---
# The OTel SDK boots from instrumentation.ts on the server runtime. In production
# the ADOT collector sidecar bundled in the AppStack task definition listens on
# localhost:4318 and exports to AWS X-Ray; the env vars below are what the SDK
# reads at boot.
#
# Sampling lives at the collector (tail_sampling: errors + slow >1500 ms + 5%
# baseline). The SDK runs at AlwaysOn so the collector sees every span. Do NOT
# set OTEL_TRACES_SAMPLER / OTEL_TRACES_SAMPLER_ARG here -- the SDK would drop
# spans before the collector could evaluate them.
#
# Locally: leave these unset (no collector running) or run a stdout collector
# per docs/tracing.md "Local smoke test".
# OTEL_SERVICE_NAME="sps-app"
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
# OTEL_PROPAGATORS="tracecontext,xray"
# SPS_ENV=""                                 # propagates to deployment.environment resource attr
# SPS_IMAGE_SHA=""                           # propagates to service.version resource attr

# B24 redaction kill switch -- emergency only, ASK BEFORE FLIPPING.
# Redaction is default-on in every env: identifier-ish span attributes (cwid,
# email, pmid, ...) and Prisma parameter values are hashed to sha256:<first-12>
# before export. Per-span opt-out is span.setAttribute("sps.trace.redact", "off").
# SPS_TRACE_REDACT="off"                    # global bypass -- never set in normal operation

# ---------------------------------------------------------------------------
# Feedback badge (#538, docs/feedback-badge-spec.md). All disabled by default;
# the badge does not render and /about/feedback returns 404 until enabled.
# PR-1 (this PR) ships the schema + lib only; PR-2 wires the UI, PR-3 the
# export endpoint + B03 audit, PR-4 the weekly digest mailer.
# ---------------------------------------------------------------------------

# Master kill-switch for the badge + form route. Off by default.
# FEEDBACK_BADGE_ENABLED="off"

# Comma-separated CWIDs allowed to hit /api/feedback/export (PR-3).
# Superuser alone is NOT sufficient -- the IRB protocol governs raw access.
# FEEDBACK_EXPORT_ALLOWLIST=""

# When "on", form writes go to feedback_submission_shadow (PR-2). Used for
# pre-launch smoke-testing without polluting the analytical dataset.
# FEEDBACK_SHADOW_MODE="off"

# Same-origin allowlist for the client-reported pageUrl. Comma-separated; if
# unset, NEXT_PUBLIC_SITE_URL is used. Submissions with an off-origin URL keep
# every answer but store pageUrl as NULL.
# FEEDBACK_SITE_ORIGIN=""

# Weekly digest email (PR-4). Empty disables the digest.
# FEEDBACK_DIGEST_RECIPIENT=""
# FEEDBACK_DIGEST_BEARER=""                  # bearer token for POST /api/feedback/digest
# FEEDBACK_DIGEST_CRON="0 14 * * MON"        # 09:00 ET Monday (adjust for DST)

# ---------------------------------------------------------------------------
# Launch-period "Beta" badge (#760). A small pill beside the Scholars wordmark
# in the header. DEFAULT ON: the header shows it unless this is exactly "off".
# Set to "off" to retire it at full launch (no code change). Reads process.env
# only -- never cookies -- so it stays CloudFront-cache compatible.
# ---------------------------------------------------------------------------
# SHOW_BETA_BADGE="off"

# ---------------------------------------------------------------------------
# Overview-statement generator (#742, docs/overview-statement-generator-spec.md).
# The in-SPS, single-scholar "✨ Generate a draft" action in the /edit Overview
# panel: server-assembled facts → Claude on Amazon Bedrock → sanitized draft
# loaded into the editor (NEVER auto-published; the owner still Saves). All
# disabled by default — the flag stays OFF in every deployed env until the gated
# validation run passes (≥4/5 drafts publishable, zero faithfulness violations).
# Validate with:
#   npm run edit:overview-validate -- --dry-run   # facts + prompt, no AWS calls
#   npm run edit:overview-validate                # live — Bedrock, uses AWS creds
# ---------------------------------------------------------------------------

# Master kill-switch for the Generate action. Must be exactly "on" to enable;
# off/unset by default → the panel hides the button and POST /api/edit/overview/
# generate returns 404 (mirrors the slug-request route).
# SELF_EDIT_OVERVIEW_GENERATE="on"

# Per-scholar hourly cap on generation attempts (reuses request_change_rate_limit,
# keyed `ovgen:<cwid>`). Default 10/hour.
# SELF_EDIT_OVERVIEW_GENERATE_RATE_LIMIT="10"

# Bedrock model + sampling temperature for generation. Defaults shown; override
# only to tune. The model is an Amazon Bedrock inference-profile id; the app task
# role grants bedrock:InvokeModel on the claude-sonnet-4-* family (cdk app-stack).
# OVERVIEW_GENERATE_MODEL="us.anthropic.claude-sonnet-4-5-20250929-v1:0"
# OVERVIEW_GENERATE_TEMPERATURE="0.4"

# AI Gateway key — used ONLY by the #594 seo:llm-rank / seo:llm-mention tooling
# (multi-provider citation-RAG; docs/seo-llm-rank-tracking.md). NOT used by the
# overview generator or its validation run — those call Claude on Amazon Bedrock
# via the AWS credential chain (the app task role in deploy, your shell creds
# locally), so there is no key to wire into the App task. Operator-run from
# ~/.zshrc per project convention; never committed, never logged.
# AI_GATEWAY_API_KEY=""
