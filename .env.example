# =============================================================================
# Scholars Profile System — environment variables
# =============================================================================
# Copy this file to .env.local for local development.
# NEVER commit .env, .env.local, or any file containing real credentials.
# =============================================================================

# --- Local DB ---
# Connection string for host MariaDB on 127.0.0.1:3306 (homebrew). Aurora MySQL
# in production. See README.md "Database setup" — MariaDB is NOT in
# docker-compose.yml; the app talks to the host service. Run `npm run db:check`
# to confirm what this URL resolves to.
DATABASE_URL="mysql://scholars:scholars@127.0.0.1:3306/scholars"

# --- Local OpenSearch ---
OPENSEARCH_NODE="http://localhost:9200"
OPENSEARCH_USERNAME=""
OPENSEARCH_PASSWORD=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Canonical base URL used for SEO (metadataBase, sitemap, robots, JSON-LD).
# Set to https://scholars.weill.cornell.edu in production.
# Distinct from NEXT_PUBLIC_APP_URL — APP_URL may differ in dev (e.g., :3000 vs :3002).
NEXT_PUBLIC_SITE_URL="http://localhost:3002"

# ISR on-demand revalidation token used by /api/revalidate route gate.
# ETL orchestrator and self-edit pipeline (Phase 7) send this in the
# x-revalidate-token header. Generate a strong random value in production;
# store in ~/.zshenv per project credential policy. Never commit a real value.
# SCHOLARS_REVALIDATE_TOKEN=""

# Base URL for the Next.js app, used by ETL orchestrator to call /api/revalidate.
# Defaults to http://localhost:3000 when unset. Override in production.
# SCHOLARS_BASE_URL="https://scholars.weill.cornell.edu"

# --- Source-system credentials (Phase 4) ---
# All credentials live in ~/.zshrc as env vars per global security policy.
# Reference them in code via process.env.<NAME>; do NOT hardcode.
# These placeholders document the variables the ETL expects.

# Enterprise Directory (LDAPS) — SCHOLARS_LDAP_* namespace to avoid collisions
# SCHOLARS_LDAP_URL=""
# SCHOLARS_LDAP_BIND_PASSWORD=""
# SCHOLARS_LDAP_BIND_DN=""              # e.g., cn=yourcn,ou=binds,dc=weill,dc=cornell,dc=edu
# SCHOLARS_LDAP_SEARCH_BASE=""          # e.g., ou=people,dc=weill,dc=cornell,dc=edu
# SCHOLARS_LDAP_ACTIVE_FILTER=""        # e.g., (objectClass=weillCornellEduPerson)

# ReCiter MySQL (publications, citation counts)
# RECITER_DB_URL=""

# ReCiterAI DynamoDB (publication_score, topic_assignments — Q6 minimal projection)
# AWS_REGION=""
# RECITERAI_DYNAMO_TABLE=""

# ReciterDB (MySQL/MariaDB) — publications, authorship, citations
# Used by etl/reciter/* scripts. The Next.js web app does not connect to
# ReciterDB at runtime, so these are only needed when running those ETLs.
#
# Convention: there is only one ReciterDB instance — production. We do not
# maintain a separate dev ReciterDB. Local ETL development reads from prod
# (read-only access in practice; the etl/reciter/* scripts only SELECT).
# Values come from the global DB_* vars in ~/.zshrc (DB_HOST, DB_USERNAME,
# DB_PASSWORD), copied into .env.local with the SCHOLARS_RECITERDB_* prefix.
# SCHOLARS_RECITERDB_HOST=""           # = $DB_HOST from ~/.zshrc
# SCHOLARS_RECITERDB_PORT="3306"
# SCHOLARS_RECITERDB_USERNAME=""       # = $DB_USERNAME from ~/.zshrc
# SCHOLARS_RECITERDB_PASSWORD=""       # = $DB_PASSWORD from ~/.zshrc
# SCHOLARS_RECITERDB_DATABASE="reciterdb"

# ASMS (MS SQL Server) — education and training records
# SCHOLARS_ASMS_HOST=""
# SCHOLARS_ASMS_PORT="1433"
# SCHOLARS_ASMS_USERNAME=""
# SCHOLARS_ASMS_PASSWORD=""
# SCHOLARS_ASMS_DATABASE="asms"

# InfoEd (MS SQL Server) — grants from VIVO view
# Target view: WC_InfoEdProd_Integration.dbo.VIVO
# SCHOLARS_INFOED_DB_URL=""        # full JDBC URL: jdbc:sqlserver://...;DatabaseName=...;...
# SCHOLARS_INFOED_USERNAME=""
# SCHOLARS_INFOED_PASSWORD=""

# Jenzabar (MS SQL Server) — graduate-student advisor/advisee view
# Target view: WCN_IDM_GS_ADVISOR_ADVISEE_View (ADVISOR_TYPE = 'MAJSP')
# SCHOLARS_JENZABAR_SERVER=""
# SCHOLARS_JENZABAR_PORT="1433"
# SCHOLARS_JENZABAR_DATABASE=""    # optional; omit to use the login's default DB
# SCHOLARS_JENZABAR_USERNAME=""
# SCHOLARS_JENZABAR_PASSWORD=""

# COI (MS SQL Server) — disclosures from v_coi_vivo_activity_group
# SCHOLARS_COI_URL=""        # JDBC URL or plain hostname
# SCHOLARS_COI_PORT="1433"
# SCHOLARS_COI_USERNAME=""
# SCHOLARS_COI_PASSWORD=""
# SCHOLARS_COI_DATABASE=""   # required if URL is plain hostname

# AWS DynamoDB — ReciterAI minimal projection (Q6: topic_assignment from FACULTY# partition)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_DEFAULT_REGION=""
# DYNAMODB_RECITERAI_TABLE="reciterai"

# --- Auth: B01 SSO — Shibboleth SAML (issue #100) ---
# Session cookie + SAML SP config for the /edit and /api/edit gate.
# Production sources these from AWS Secrets Manager (B06 #105); locally they
# live in .env.local. See lib/auth/config.ts.

# Session cookie. SESSION_COOKIE_SECRET must be >= 32 chars (iron-session) —
# generate a strong random value. For local http, set a plain cookie name and
# SESSION_COOKIE_SECURE=false.
# SESSION_COOKIE_SECRET=""
# SESSION_COOKIE_NAME="sps_session"          # default: __Secure-sps_session
# SESSION_COOKIE_SECURE="false"              # default: true (production HTTPS)
# SESSION_COOKIE_DOMAIN=""                   # prod: scholars.weill.cornell.edu; unset locally
# SESSION_MAX_AGE_SECONDS="28800"            # default and hard cap: 28800 (8h)

# SAML — WCM Shibboleth IdP. The IdP values come from the WCM identity team
# during SP registration; until then the /api/auth/saml/* routes return 503,
# but the rest of the app builds and serves normally.
# SAML_IDP_ENTITY_ID=""                      # IdP entityID (verifies the assertion Issuer)
# SAML_IDP_SSO_URL=""                        # IdP SSO service URL (AuthnRequest destination)
# SAML_IDP_CERT=""                           # IdP signing certificate (PEM)
# SAML_SP_ENTITY_ID="https://scholars.weill.cornell.edu/api/auth/saml/metadata"
# SAML_SP_ACS_URL="https://scholars.weill.cornell.edu/api/auth/saml/callback"
# SAML_SP_PRIVATE_KEY=""                     # SP private key (PEM) — signs requests, decrypts assertions
# SAML_SP_CERT=""                            # SP certificate (PEM) — published in SP metadata
# SAML_CWID_ATTRIBUTE=""                     # SAML attribute carrying the CWID; unset = use the NameID
# SAML_WANT_AUTHN_RESPONSE_SIGNED="false"    # require the response envelope signed (the assertion is always required signed)
# SAML_CLOCK_SKEW_MS="5000"                  # accepted SP/IdP clock skew, milliseconds
# SAML_NAMEID_FORMAT=""                      # requested NameID format; unset lets the IdP choose
# SAML_DEFAULT_RETURN_PATH="/edit"           # post-login destination when RelayState is absent or rejected

# --- Auth: B02 superuser tier (issue #101) ---
# The admin tier of /api/edit authorization: a signed-in scholar who is a
# member of the superuser-role Enterprise Directory group is a superuser.
# Membership is checked live per request by an LDAPS query (lib/auth/superuser.ts)
# — it reuses the Enterprise Directory bind above (SCHOLARS_LDAP_*), which must
# be configured for the superuser tier to work. Unset = no superusers; dormant.
# SCHOLARS_SUPERUSER_GROUP_CN=""  # cn of the ED group, e.g. ITS:Library:Scholars/superuser-role
